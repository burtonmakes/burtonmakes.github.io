<style is:global>
  .recruiter-onepage .recruiter-hero-grid {
    grid-template-columns: minmax(0, 1fr) !important;
  }

  .recruiter-onepage .match-flow-card {
    display: none !important;
  }

  .recruiter-onepage .recruiter-hero-copy h1 {
    max-width: 18ch !important;
    font-size: clamp(2.2rem, 4vw, 4.25rem) !important;
  }

  .recruiter-onepage .recruiter-hero-copy > p:last-child {
    max-width: 62ch !important;
    font-size: 0.92rem !important;
  }

  .recruiter-onepage .matcher-panel {
    max-width: 980px;
    width: 100%;
    margin-inline: auto;
  }

  .recruiter-onepage .matcher-heading p {
    max-width: 68ch;
    font-size: 0.84rem;
  }

  .recruiter-onepage .role-text-field > span {
    color: var(--muted-2) !important;
    font-size: 0.84rem !important;
    font-weight: 650 !important;
    letter-spacing: 0 !important;
    line-height: 1.35 !important;
    text-transform: none !important;
  }

  .recruiter-onepage .role-text-field textarea {
    min-height: 210px;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 450;
    line-height: 1.5;
  }

  .recruiter-onepage .action-row {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px !important;
  }

  .recruiter-onepage .action-row .button {
    width: 100%;
  }

  .recruiter-onepage .action-row .match-status {
    grid-column: 1 / -1;
    justify-content: center;
  }

  .recruiter-onepage [data-edit-context] {
    border-color: rgba(255, 194, 98, 0.72) !important;
    background: linear-gradient(135deg, var(--graph-amber), var(--graph-coral)) !important;
    color: #07101a !important;
  }

  .recruiter-onepage [data-ai-run],
  .recruiter-onepage [data-fuzzy-run] {
    border-color: var(--line) !important;
    background: rgba(255, 255, 255, 0.035) !important;
    color: var(--text) !important;
  }

  .recruiter-onepage [data-clear] {
    display: none !important;
  }

  .recruiter-onepage .detected-heading {
    align-items: center !important;
  }

  .recruiter-onepage .detected-heading-tools {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .recruiter-onepage .clear-tags-button {
    min-height: 30px;
    padding: 0 11px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.025);
    color: var(--muted-2);
    font: inherit;
    font-size: 0.72rem;
    font-weight: 750;
    cursor: pointer;
  }

  .recruiter-onepage .clear-tags-button:hover {
    border-color: rgba(232, 111, 78, 0.5);
    color: var(--text);
  }

  .recruiter-onepage .results-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    max-width: 980px;
    width: 100%;
    margin-inline: auto;
  }

  .recruiter-onepage .score-card,
  .recruiter-onepage .role-read-card,
  .recruiter-onepage .match-list-card {
    padding: 18px !important;
  }

  .recruiter-onepage .score-card > span,
  .recruiter-onepage .role-read-card > span,
  .recruiter-onepage .match-list-card h2 {
    font-size: 0.76rem !important;
    letter-spacing: 0.04em !important;
    text-transform: none !important;
  }

  .recruiter-onepage .score-card > strong {
    font-size: clamp(3rem, 6vw, 4.4rem) !important;
  }

  .recruiter-onepage .metric-stack {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .recruiter-onepage .metric-stack div {
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 5px !important;
    padding: 10px;
    border: 1px solid var(--line-soft);
    border-radius: 8px;
  }

  .recruiter-onepage .metric-stack div i {
    grid-column: 1 !important;
  }

  @media (max-width: 720px) {
    .recruiter-onepage .action-row,
    .recruiter-onepage .results-grid,
    .recruiter-onepage .metric-stack {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  const setupRecruiterMatcherEnhancements = () => {
    const page = document.querySelector("[data-recruiter-onepage]");
    if (!page || page.dataset.flowEnhanced === "true") return;
    page.dataset.flowEnhanced = "true";

    const textarea = page.querySelector("[data-match-input]");
    const textareaLabel = textarea?.closest("label")?.querySelector(":scope > span");
    if (textareaLabel) {
      textareaLabel.textContent = "Paste the full job description, requirements, or a list of keywords below.";
    }
    if (textarea) {
      textarea.placeholder = "Paste or dump the job posting here. Include responsibilities, required skills, preferred qualifications, and any important keywords.";
    }

    const heading = page.querySelector(".detected-heading");
    const count = heading?.querySelector("[data-detected-count]");
    if (heading && count && !heading.querySelector("[data-clear-tags]")) {
      const tools = document.createElement("div");
      tools.className = "detected-heading-tools";
      const clearTags = document.createElement("button");
      clearTags.type = "button";
      clearTags.className = "clear-tags-button";
      clearTags.dataset.clearTags = "true";
      clearTags.textContent = "Clear all tags";
      clearTags.addEventListener("click", () => {
        page.querySelectorAll("[data-detected-skills] .skill-chip button").forEach((button) => button.click());
      });
      count.replaceWith(tools);
      tools.append(count, clearTags);
    }

    const actionRow = page.querySelector(".action-row");
    if (actionRow && !actionRow.querySelector("[data-edit-context]")) {
      const editContext = document.createElement("a");
      editContext.href = "/recruiter/";
      editContext.className = "button";
      editContext.dataset.editContext = "true";
      editContext.textContent = "Go back and edit recruiter context";
      actionRow.prepend(editContext);
    }

    const aiButton = page.querySelector("[data-ai-run]");
    if (aiButton) aiButton.textContent = "Continue with AI Compare";

    const scoreLabel = page.querySelector(".score-card > span");
    if (scoreLabel) scoreLabel.textContent = "Overall match";
    const roleLabel = page.querySelector(".role-read-card > span");
    if (roleLabel) roleLabel.textContent = "Role type";
    const listHeadings = page.querySelectorAll(".match-list-card h2");
    if (listHeadings[0]) listHeadings[0].textContent = "Strong matches";
    if (listHeadings[1]) listHeadings[1].textContent = "Needs manual review";
  };

  document.addEventListener("astro:page-load", setupRecruiterMatcherEnhancements);
  setupRecruiterMatcherEnhancements();
</script>
