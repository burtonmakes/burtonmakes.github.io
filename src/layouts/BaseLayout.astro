---
import BackgroundEffects from "../components/BackgroundEffects.jsx";
import GlobalEffects from "../components/GlobalEffects.jsx";
import { navigation, siteMeta } from "../data/site";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description = siteMeta.siteDescription, eyebrow } = Astro.props;
const pageTitle = title === siteMeta.siteTitle ? title : `${title} | ${siteMeta.siteTitle}`;
const defaultPlausibleScriptUrl = "https://plausible.io/js/pa-gczhG5VDj-KpJH97UfP9Y.js";
const plausibleScriptUrl = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_URL || defaultPlausibleScriptUrl;
const analyticsEnabled = import.meta.env.PROD && plausibleScriptUrl.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <ClientRouter />
    {analyticsEnabled && <script async src={plausibleScriptUrl}></script>}
    {analyticsEnabled && (
      <script is:inline>
        window.plausible = window.plausible || function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
        window.plausible.init = window.plausible.init || function (i) {
          window.plausible.o = i || {};
        };
        window.plausible.init();
      </script>
    )}
  </head>

  <body>
    <BackgroundEffects client:load transition:persist />
    <div class="site-backdrop" aria-hidden="true"></div>
    <GlobalEffects client:load />
    <a class="skip-link" href="#main">Skip to content</a>

    <aside class="site-notice" aria-label="Site status notice">
      <strong>Site in progress.</strong>
      <span>Information has not been fully validated and may change. Do not rely on it as final or verified.</span>
    </aside>

    <header class="site-header">
      <nav class="nav-shell" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label={`${siteMeta.personName} home`}>
          <span class="brand-mark">
            <img src="/logo.svg" alt="" width="40" height="40" />
          </span>
          <span class="brand-stack">
            <span class="brand-site">{siteMeta.personName}</span>
          </span>
        </a>

        <button class="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-nav-toggle>
          <span></span>
          <span></span>
        </button>

        <div class="nav-links" data-mobile-nav data-site-nav>
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </nav>
    </header>

    <main id="main">
      {eyebrow && (
        <section class="page-intro">
          <div class="section">
            <p class="eyebrow reveal">{eyebrow}</p>
          </div>
        </section>
      )}

      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <a class="brand brand-footer" href="/">
            <span class="brand-mark">
              <img src="/logo.svg" alt="" width="40" height="40" />
            </span>
            <span class="brand-stack">
              <span class="brand-site">{siteMeta.personName}</span>
            </span>
          </a>

          <p class="footer-copy">
            Engineering portfolio for medical sensors, wearable systems, hardware R&D,
            validation, data workflows, and ML/AI-enabled tools.
          </p>
        </div>

        <div class="footer-links">
          <a href={siteMeta.links.linkedin}>LinkedIn</a>
          <span>|</span>
          <a href={siteMeta.links.github}>GitHub</a>
          <span>|</span>
          <a href={siteMeta.links.scholar}>Google Scholar</a>
          <span>|</span>
          <a href={siteMeta.links.sourcecode}>Source Code</a>
        </div>
      </div>
    </footer>

    <style is:global>
      :root {
        --surface-window: rgba(6, 16, 28, 0.97);
        --surface-window-strong: rgba(9, 22, 38, 0.97);
        --surface-window-soft: rgba(255, 255, 255, 0.035);
        --surface-window-line: rgba(255, 255, 255, 0.16);
        --surface-window-line-soft: rgba(255, 255, 255, 0.1);
        --panel: var(--surface-window);
        --panel-strong: var(--surface-window-strong);
        --panel-soft: var(--surface-window-soft);
        --line: var(--surface-window-line);
        --line-soft: var(--surface-window-line-soft);
      }

      :is(
        .nav-shell,
        .capability-card,
        .metric-card,
        .project-card,
        .project-feature,
        .project-detail,
        .timeline-item,
        .timeline-card,
        .career-panel,
        .career-stop,
        .career-scan-item,
        .branch-expansion,
        .tag-panel,
        .dog-card,
        .hobby-mini-card,
        .hobby-sticky-copy,
        .hobby-section-box,
        .contact-card,
        .contact-method,
        .contact-panel,
        .resume-card,
        .stat-card,
        .feature-card,
        .archive-card,
        .info-card,
        .card,
        .panel
      ) {
        border-color: var(--surface-window-line) !important;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)),
          var(--surface-window) !important;
      }

      :is(
        .capability-card:hover,
        .metric-card:hover,
        .project-card:hover,
        .career-stop:hover,
        .career-stop[aria-selected="true"],
        .career-scan-item:hover,
        .career-scan-item.is-active,
        .hobby-mini-card:hover,
        .contact-card:hover,
        .contact-method:hover,
        .card:hover,
        .panel:hover
      ) {
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.014)),
          var(--surface-window-strong) !important;
      }

      body::after {
        background:
          linear-gradient(180deg, rgba(1, 4, 9, 0.66), rgba(1, 4, 9, 0.56)),
          radial-gradient(circle at 50% 32%, transparent 0 28%, rgba(1, 4, 9, 0.38) 68%);
      }
    </style>
  </body>
</html>