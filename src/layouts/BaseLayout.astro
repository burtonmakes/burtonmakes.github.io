---
import BackgroundEffects from "../components/BackgroundEffects.jsx";
import GlobalEffects from "../components/GlobalEffects.jsx";
import RecruiterGateway from "../components/RecruiterGateway.astro";
import { navigation, siteMeta } from "../data/site";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description = siteMeta.siteDescription, eyebrow } = Astro.props;
const pageTitle = title === siteMeta.siteTitle ? title : `${title} | ${siteMeta.siteTitle}`;
const defaultPlausibleScriptUrl = "https://plausible.io/js/pa-gczhG5VDj-KpJH97UfP9Y.js";
const plausibleScriptUrl = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_URL || defaultPlausibleScriptUrl;
const analyticsEnabled = import.meta.env.PROD && plausibleScriptUrl.length > 0;
const showRecruiterGateway = /^\/recruiter\/?$/.test(Astro.url.pathname);
const recruiterBuildId = import.meta.env.PROD ? String(Date.now()) : "dev";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <ClientRouter />
    {analyticsEnabled && <script async src={plausibleScriptUrl}></script>}
    {analyticsEnabled && (
      <script is:inline>
        window.plausible = window.plausible || function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
        window.plausible.init = window.plausible.init || function (i) {
          window.plausible.o = i || {};
        };
        window.plausible.init();
      </script>
    )}
  </head>

  <body>
    <BackgroundEffects client:load transition:persist />
    <div class="site-backdrop" aria-hidden="true"></div>
    <GlobalEffects client:load />
    <a class="skip-link" href="#main">Skip to content</a>

    <aside class="site-notice" aria-label="Site status notice">
      <strong>Site in progress.</strong>
      <span>Information has not been fully validated and may change. Do not rely on it as final or verified.</span>
    </aside>

    <header class="site-header">
      <nav class="nav-shell" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label={`${siteMeta.personName} home`}>
          <span class="brand-mark">
            <img src="/logo.svg" alt="" width="40" height="40" />
          </span>
          <span class="brand-stack">
            <span class="brand-site">{siteMeta.personName}</span>
          </span>
        </a>

        <button class="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-nav-toggle>
          <span></span>
          <span></span>
        </button>

        <div class="nav-links" data-mobile-nav data-site-nav>
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </nav>
    </header>

    <main id="main">
      {eyebrow && (
        <section class="page-intro">
          <div class="section">
            <p class="eyebrow reveal">{eyebrow}</p>
          </div>
        </section>
      )}

      {showRecruiterGateway && <RecruiterGateway />}
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <a class="brand brand-footer" href="/">
            <span class="brand-mark">
              <img src="/logo.svg" alt="" width="40" height="40" />
            </span>
            <span class="brand-stack">
              <span class="brand-site">{siteMeta.personName}</span>
            </span>
          </a>

          <p class="footer-copy">
            Engineering portfolio for medical sensors, wearable systems, hardware R&D,
            validation, data workflows, and ML/AI-enabled tools.
          </p>
        </div>

        <div class="footer-links">
          <a href={siteMeta.links.linkedin}>LinkedIn</a>
          <span>|</span>
          <a href={siteMeta.links.github}>GitHub</a>
          <span>|</span>
          <a href={siteMeta.links.scholar}>Google Scholar</a>
          <span>|</span>
          <a href={siteMeta.links.sourcecode}>Source Code</a>
        </div>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #000000;
        --bg-2: #010102;
        --surface-window: rgba(1, 5, 10, 0.999);
        --surface-window-strong: rgba(3, 9, 16, 0.999);
        --surface-window-line: rgba(255, 255, 255, 0.16);
        --surface-window-line-soft: rgba(255, 255, 255, 0.1);
        --panel: var(--surface-window);
        --panel-strong: var(--surface-window-strong);
        --panel-soft: var(--surface-window);
        --text: #f6faff;
        --muted: #a9bcd7;
        --muted-2: #e6eef8;
        --line: var(--surface-window-line);
        --line-soft: var(--surface-window-line-soft);
        --blue-glow: rgba(32, 64, 120, 0.27);
        --coral-glow: rgba(92, 40, 28, 0.22);
      }

      body {
        background:
          radial-gradient(circle at 18% 12%, rgba(32, 64, 120, 0.27), transparent 28%),
          radial-gradient(circle at 82% 24%, rgba(38, 85, 112, 0.22), transparent 30%),
          radial-gradient(circle at 76% 82%, rgba(92, 40, 28, 0.12), transparent 24%),
          linear-gradient(180deg, var(--bg), var(--bg-2) 45%, var(--bg)) !important;
      }

      :is(
        .nav-shell,
        .capability-card,
        .feature-card,
        .story-card,
        .metric-card,
        .metric-tile,
        .publication-card,
        .notice-card,
        .timeline-card,
        .timeline-item,
        .project-card,
        .project-feature,
        .project-detail,
        .project-list-card,
        .explore-link,
        .hero-stat-card,
        .locked-panel,
        .tag-panel,
        .career-panel,
        .career-stop,
        .career-scan-item,
        .branch-expansion,
        .branch-panel,
        .hobby-mini-card,
        .hobby-sticky-copy,
        .hobby-section-box,
        .contact-card,
        .contact-method,
        .contact-panel,
        .resume-card,
        .stat-card,
        .info-card
      ) {
        border-color: var(--surface-window-line) !important;
        background: var(--surface-window) !important;
      }

      :is(
        .capability-card:hover,
        .feature-card:hover,
        .story-card:hover,
        .metric-card:hover,
        .metric-tile:hover,
        .publication-card:hover,
        .timeline-card:hover,
        .timeline-item:hover,
        .project-card:hover,
        .project-feature:hover,
        .project-detail:hover,
        .project-list-card:hover,
        .explore-link:hover,
        .hero-stat-card:hover,
        .locked-panel:hover,
        .career-stop:hover,
        .career-stop[aria-selected="true"],
        .career-scan-item:hover,
        .career-scan-item.is-active,
        .branch-panel:hover,
        .hobby-mini-card:hover,
        .contact-card:hover,
        .contact-method:hover,
        .resume-card:hover,
        .stat-card:hover,
        .info-card:hover
      ) {
        background: var(--surface-window-strong) !important;
      }

      :is(
        .capability-grid,
        .card-grid,
        .metrics-card-grid,
        .project-grid,
        .project-card-grid,
        .branch-card-grid,
        .career-scan-grid,
        .hero-panel-grid,
        .summary-grid,
        .recruiter-grid,
        .feature-work-grid,
        .explore-grid,
        .media-grid,
        .hobby-card-grid,
        .hobby-scroll-list,
        .hobby-row-grid,
        .filters-shell,
        .profile-list,
        .summary-blocks,
        .compact-stack,
        .skill-map,
        .timeline-stack
      ) {
        border-color: transparent !important;
        background: transparent !important;
        box-shadow: none !important;
      }

      .recruiter-onepage .context-panel,
      .recruiter-onepage .match-flow-card {
        display: none !important;
      }

      .recruiter-onepage .recruiter-workspace,
      .recruiter-onepage .recruiter-hero-grid {
        grid-template-columns: minmax(0, 1fr) !important;
      }

      .recruiter-onepage .matcher-heading > span {
        display: none !important;
      }
    </style>

    {showRecruiterGateway && (
      <script define:vars={{ recruiterBuildId }}>
        const recruiterSubmissionKey = "burton-recruiter-match-submissions-v1";
        const recruiterBuildKey = "burton-recruiter-match-build-v1";

        const simplifyManualReview = () => {
          const list = document.querySelector("[data-gap-list]");
          if (!list) return;

          list.querySelectorAll("li").forEach((item) => {
            const text = item.textContent?.replace(/\s+/g, " ").trim() || "";
            const reviewMatch = text.match(/^Review\s+([^:]+):/i);

            if (reviewMatch) {
              item.textContent = `Manual review needed: ${reviewMatch[1].trim()}.`;
              return;
            }

            if (/^No evidence\b/i.test(text)) {
              const topic = text
                .replace(/^No evidence\s+(?:of|for|that)\s*/i, "")
                .replace(/[.!]+$/, "")
                .trim();
              item.textContent = topic
                ? `Manual review needed: ${topic}.`
                : "Manual review needed for this topic.";
            }
          });
        };

        const setupRecruiterDeploymentState = () => {
          try {
            if (window.localStorage.getItem(recruiterBuildKey) !== recruiterBuildId) {
              window.localStorage.removeItem(recruiterSubmissionKey);
              window.localStorage.setItem(recruiterBuildKey, recruiterBuildId);
            }
          } catch {
            // Browser storage is optional.
          }

          simplifyManualReview();
          const observer = new MutationObserver(simplifyManualReview);
          observer.observe(document.body, { childList: true, subtree: true, characterData: true });
        };

        document.addEventListener("astro:page-load", setupRecruiterDeploymentState);
        setupRecruiterDeploymentState();
      </script>
    )}
  </body>
</html>
