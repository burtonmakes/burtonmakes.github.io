---
import BackgroundEffects from "../components/BackgroundEffects.jsx";
import GlobalEffects from "../components/GlobalEffects.jsx";
import { navigation, siteMeta } from "../data/site";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description = siteMeta.siteDescription, eyebrow } = Astro.props;
const pageTitle = title === siteMeta.siteTitle ? title : `${title} | ${siteMeta.siteTitle}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline src="/recruiter-response-guard.js"></script>
    <script is:inline src="/recruiter-state-bridge.js"></script>
  </head>

  <body>
    <BackgroundEffects client:load transition:persist />
    <div class="site-backdrop" aria-hidden="true"></div>
    <GlobalEffects client:load />
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <nav class="nav-shell" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label={`${siteMeta.brandName} home`}>
          <span class="brand-mark">
            <img src="/logo.svg" alt="" width="40" height="40" />
          </span>
          <span class="brand-stack">
            <span class="brand-site">{siteMeta.brandName}</span>
          </span>
        </a>

        <button class="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-nav-toggle>
          <span></span>
          <span></span>
        </button>

        <div class="nav-links" data-mobile-nav data-site-nav>
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </nav>
    </header>

    <main id="main">
      {eyebrow && (
        <section class="page-intro">
          <div class="section">
            <p class="eyebrow reveal">{eyebrow}</p>
          </div>
        </section>
      )}

      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <a class="brand brand-footer" href="/">
            <span class="brand-mark">
              <img src="/logo.svg" alt="" width="40" height="40" />
            </span>
            <span class="brand-stack">
              <span class="brand-site">{siteMeta.brandName}</span>
            </span>
          </a>

          <p class="footer-copy">
            Engineering portfolio for medical sensors, wearable systems, hardware R&D,
            validation, data workflows, and ML/AI-enabled tools.
          </p>
        </div>

        <div class="footer-links">
          <a href={siteMeta.links.linkedin}>LinkedIn</a>
          <span>|</span>
          <a href={siteMeta.links.github}>GitHub</a>
          <span>|</span>
          <a href={siteMeta.links.scholar}>Google Scholar</a>
          <span>|</span>
          <a href={siteMeta.links.sourcecode}>Source Code</a>
        </div>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #000000;
        --bg-2: #010102;
        --surface-window: rgba(1, 5, 10, 0.999);
        --surface-window-strong: rgba(3, 9, 16, 0.999);
        --surface-window-line: rgba(255, 255, 255, 0.16);
        --surface-window-line-soft: rgba(255, 255, 255, 0.1);
        --panel: var(--surface-window);
        --panel-strong: var(--surface-window-strong);
        --panel-soft: var(--surface-window);
        --text: #f6faff;
        --muted: #a9bcd7;
        --muted-2: #e6eef8;
        --line: var(--surface-window-line);
        --line-soft: var(--surface-window-line-soft);
        --blue-glow: rgba(32, 64, 120, 0.27);
        --coral-glow: rgba(92, 40, 28, 0.22);
      }

      body {
        background:
          radial-gradient(circle at 18% 12%, rgba(32, 64, 120, 0.27), transparent 28%),
          radial-gradient(circle at 82% 24%, rgba(38, 85, 112, 0.22), transparent 30%),
          radial-gradient(circle at 76% 82%, rgba(92, 40, 28, 0.12), transparent 24%),
          linear-gradient(180deg, var(--bg), var(--bg-2) 45%, var(--bg)) !important;
      }

      :is(
        .nav-shell,
        .capability-card,
        .feature-card,
        .story-card,
        .metric-card,
        .metric-tile,
        .publication-card,
        .notice-card,
        .timeline-card,
        .timeline-item,
        .project-card,
        .project-feature,
        .project-detail,
        .project-list-card,
        .explore-link,
        .hero-stat-card,
        .locked-panel,
        .tag-panel,
        .career-panel,
        .career-stop,
        .career-scan-item,
        .branch-expansion,
        .branch-panel,
        .hobby-mini-card,
        .hobby-sticky-copy,
        .hobby-section-box,
        .contact-card,
        .contact-method,
        .contact-panel,
        .resume-card,
        .stat-card,
        .info-card
      ) {
        border-color: var(--surface-window-line) !important;
        background: var(--surface-window) !important;
      }

      :is(
        .capability-card:hover,
        .feature-card:hover,
        .story-card:hover,
        .metric-card:hover,
        .metric-tile:hover,
        .publication-card:hover,
        .timeline-card:hover,
        .timeline-item:hover,
        .project-card:hover,
        .project-feature:hover,
        .project-detail:hover,
        .project-list-card:hover,
        .explore-link:hover,
        .hero-stat-card:hover,
        .locked-panel:hover,
        .career-stop:hover,
        .career-stop[aria-selected="true"],
        .career-scan-item:hover,
        .career-scan-item.is-active,
        .branch-panel:hover,
        .hobby-mini-card:hover,
        .contact-card:hover,
        .contact-method:hover,
        .resume-card:hover,
        .stat-card:hover,
        .info-card:hover
      ) {
        background: var(--surface-window-strong) !important;
      }

      :is(
        .capability-grid,
        .card-grid,
        .metrics-card-grid,
        .project-grid,
        .project-card-grid,
        .branch-card-grid,
        .career-scan-grid,
        .hero-panel-grid,
        .summary-grid,
        .recruiter-grid,
        .feature-work-grid,
        .explore-grid,
        .media-grid,
        .hobby-card-grid,
        .hobby-scroll-list,
        .hobby-row-grid,
        .filters-shell,
        .profile-list,
        .summary-blocks,
        .compact-stack,
        .skill-map,
        .timeline-stack
      ) {
        border-color: transparent !important;
        background: transparent !important;
        box-shadow: none !important;
      }

      .site-header {
        padding: 0;
        border-bottom: 1px solid var(--line-soft);
        background: rgba(0, 3, 7, 0.88);
        backdrop-filter: blur(18px) saturate(120%);
        -webkit-backdrop-filter: blur(18px) saturate(120%);
      }

      .nav-shell {
        min-height: 76px;
        padding: 0 40px;
        border: 0 !important;
        border-radius: 0;
        background: transparent !important;
        box-shadow: none;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        box-shadow: none;
      }

      .brand-site {
        font-size: 1.05rem;
        font-weight: 750;
      }

      @media (max-width: 760px) {
        .nav-shell {
          min-height: 68px;
          padding: 0 20px;
        }

        .brand-mark {
          width: 38px;
          height: 38px;
        }
      }
    </style>
  </body>
</html>