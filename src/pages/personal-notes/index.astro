---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { personalNotesSections } from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Personal Notes"
  description="Lightweight public notes on interests, gear, and non-work systems for Alex Burton."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Personal notes</p>
      <h1>Secondary to the recruiter path, but still part of the public archive.</h1>
      <p class="hero-text">
        This section stays lighter and more personal: interests, trips, gear, and small systems that do not need to sit inside the professional overview.
      </p>
    </div>
    <div class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="profile-list">
        <div><span>Role in site</span><strong>Personal context without disrupting recruiter scanning.</strong></div>
        <div><span>Tone</span><strong>Light, structured, and clearly separate from professional proof.</strong></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Sections</p>
      <h2>Personal categories that can grow over time.</h2>
    </div>
    <div class="card-grid">
      {personalNotesSections.map((item) => (
        <article class="feature-card reveal">
          <h3>{item}</h3>
          <p>Placeholder note surface for photos, logs, lightweight writeups, or collections later on.</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
