---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  siteMeta,
  skillsDemonstrated,
  workHistory,
  workMetrics,
  workstreams,
} from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Professional Work"
  description="Structured, public-safe professional engineering evidence for Alex Burton."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Professional work</p>
      <h1>Structured evidence, not a resume clone.</h1>
      <p class="hero-text">
        This section focuses on public-safe summaries of engineering work, what those efforts prove, and how they connect to the broader recruiter narrative.
      </p>
    </div>
    <div class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="profile-list">
        <div><span>What this proves</span><strong>Medical-device depth with practical range across hardware, data, software, and validation.</strong></div>
        <div><span>Disclosure note</span><strong>Confidential details, internal diagrams, and private documents are intentionally omitted.</strong></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Work history</p>
      <h2>Public-safe role framing with responsibilities, outcomes, and linked skills.</h2>
    </div>
    <div class="timeline-stack">
      {workHistory.map((role) => (
        <article class="timeline-card reveal">
          <div class="timeline-top">
            <div>
              <h3>{role.title}</h3>
              <p class="muted">{role.dates}</p>
            </div>
            <span class="chip">Public-safe summary</span>
          </div>
          <p>{role.context}</p>
          <p>{role.summary}</p>
          <div class="dual-list">
            <div>
              <strong>Responsibilities</strong>
              <ul>
                {role.responsibilities.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div>
              <strong>Accomplishments</strong>
              <ul>
                {role.accomplishments.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
          <div class="tag-row">
            {role.skills.map((skill) => <span class="tag">{skill}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="workstreams">
    <div class="section-heading reveal">
      <p class="eyebrow">Workstreams / case studies</p>
      <h2>Major evidence lanes that explain what the work actually consisted of.</h2>
    </div>
    <div class="card-grid">
      {workstreams.map((item) => (
        <article class="feature-card reveal">
          <h3>{item}</h3>
          <p>Placeholder public-safe case-study framing that can later expand into metrics, role context, and technical contribution detail.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Metrics & outcomes</p>
      <h2>Public-safe proof surfaces that stay useful even with redaction.</h2>
    </div>
    <div class="card-grid metrics-card-grid">
      {workMetrics.map(([label, value]) => (
        <article class="metric-card reveal">
          <strong>{label}</strong>
          <p>{value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="skills-demonstrated">
    <div class="section-heading reveal">
      <p class="eyebrow">Skills demonstrated</p>
      <h2>The practical capabilities these workstreams support.</h2>
    </div>
    <div class="tag-panel reveal">
      {skillsDemonstrated.map((item) => <span class="tag tag-large">{item}</span>)}
    </div>
  </section>

  <section class="section" id="public-safe-notes">
    <div class="section-heading reveal">
      <p class="eyebrow">Public-safe notes</p>
      <h2>Confidential details stay out of the public site.</h2>
    </div>
    <article class="notice-card reveal">
      <p>Confidential details omitted. Internal diagrams omitted. Private company documents omitted. Summaries focus on role, skills, public-safe metrics, and evidence suitable for a public portfolio.</p>
      <p class="muted">{siteMeta.renameHint}</p>
    </article>
  </section>
</BaseLayout>
