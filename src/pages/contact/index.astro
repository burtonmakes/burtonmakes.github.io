---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteMeta } from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Contact"
  description="Contact Alex Burton about engineering roles, medical devices, wearable sensing, hardware systems, and AI tooling."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Contact</p>
      <h1>Reach out about a role, collaboration, or technical project.</h1>
      <p class="hero-text">
        For recruiting, engineering conversations, project questions, or relevant
        collaboration, send a short note with context and the best way to follow up.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={siteMeta.links.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a class="button button-secondary" href={siteMeta.links.github} target="_blank" rel="noreferrer noopener">GitHub</a>
        <a class="button button-tertiary" href={siteMeta.links.scholar} target="_blank" rel="noreferrer noopener">Publications</a>
        <a class="button button-quaternary" href={siteMeta.links.sourcecode} target="_blank" rel="noreferrer noopener">Source Code</a>
      </div>
    </div>

    <div class="interface-shell contact-shell reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>

      <form class="contact-form" id="contact-form" action="#" method="POST">
        <input type="hidden" name="subject" value="New message from burtonmakes.github.io" />
        <input type="hidden" name="from_name" value="Burton Makes Contact Form" />
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="contact-honeypot" aria-hidden="true" />

        <div class="contact-form-heading">
          <span>Direct message</span>
          <strong>Share the context that matters.</strong>
        </div>

        <div class="contact-field-grid">
          <label>
            <span>Name</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>

          <label>
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
        </div>

        <label>
          <span>Message</span>
          <textarea name="message" rows="6" required></textarea>
        </label>

        <div class="contact-form-footer">
          <button class="button button-primary" type="submit">Send message</button>
          <p class="contact-status" id="contact-status" role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("contact-status");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    if (!status) return;
    status.textContent = "This archived feature is no longer available. Use one of the public profile links instead.";
    status.dataset.state = "archived";
  });
</script>
