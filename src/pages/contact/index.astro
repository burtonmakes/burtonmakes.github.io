---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteMeta } from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Contact"
  description="Contact Alex Burton about engineering roles, medical devices, wearable sensing, hardware systems, and AI tooling."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Contact</p>
      <h1>Reach out about a role, collaboration, or technical project.</h1>
      <p class="hero-text">
        For recruiting, engineering conversations, project questions, or relevant
        collaboration, send a short note with context and the best way to follow up.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={siteMeta.links.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a class="button button-secondary" href={siteMeta.links.github} target="_blank" rel="noreferrer noopener">GitHub</a>
        <a class="button button-tertiary" href={siteMeta.links.scholar} target="_blank" rel="noreferrer noopener">Publications</a>
        <a class="button button-quaternary" href={siteMeta.links.sourcecode} target="_blank" rel="noreferrer noopener">Source Code</a>
      </div>
    </div>

    <div class="interface-shell contact-shell reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>

      <form class="contact-form" id="contact-form" action="https://cocometric.com/contact/" method="GET" autocomplete="off">
        <div class="contact-form-heading">
          <span>Direct message</span>
          <strong>Use the current Cocometric contact form.</strong>
        </div>

        <p class="hero-text">
          The current contact form is hosted at cocometric.com so messages are handled by the active site.
        </p>

        <div class="contact-form-footer">
          <button class="button button-primary" type="submit">Open contact form</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
