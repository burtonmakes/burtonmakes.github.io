---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteMeta } from "../../data/site";
import "../../styles/global.css";
import "../../styles/contact.css";
---

<BaseLayout
  title="Contact"
  description="Contact Alex Burton about engineering roles, medical devices, wearable sensing, hardware systems, and AI tooling."
>
  <section class="section hero-grid contact-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Contact</p>
      <h1>Reach out about a role, collaboration, or technical project.</h1>
      <p class="hero-text">
        For recruiting, engineering conversations, project questions, or relevant
        collaboration, send a short note with context and the best way to follow up.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={siteMeta.links.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a class="button button-secondary" href={siteMeta.links.github} target="_blank" rel="noreferrer noopener">GitHub</a>
        <a class="button button-tertiary" href={siteMeta.links.scholar} target="_blank" rel="noreferrer noopener">Publications</a>
        <a class="button button-quaternary" href={siteMeta.links.sourcecode} target="_blank" rel="noreferrer noopener">Source Code</a>
      </div>
    </div>

    <div class="contact-card reveal">
      <form class="contact-form" id="contact-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="53d6c7c6-13c6-4da5-b029-517d7dc7fd0a" />
        <input type="hidden" name="subject" value="New message from burtonmakes.github.io" />
        <input type="hidden" name="from_name" value="Burton Makes Contact Form" />
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="contact-honeypot" aria-hidden="true" />

        <div class="contact-form-heading">
          <strong>Send a note.</strong>
          <span>Context, timing, and best follow-up.</span>
        </div>

        <div class="contact-field-grid">
          <label>
            <span>Name</span>
            <input type="text" name="name" autocomplete="name" required />
          </label>

          <label>
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" required />
          </label>
        </div>

        <label>
          <span>Message</span>
          <textarea name="message" rows="5" required></textarea>
        </label>

        <div class="contact-form-footer">
          <button class="button button-primary" type="submit">Send message</button>
          <p class="contact-status" id="contact-status" role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("contact-status");
  const submitButton = form?.querySelector("button[type='submit']");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!submitButton || !status) {
      return;
    }

    const formData = new FormData(form);
    const originalText = submitButton.textContent || "Send message";

    submitButton.textContent = "Sending...";
    submitButton.disabled = true;
    status.textContent = "";
    status.dataset.state = "";

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData,
      });
      const data = await response.json();

      if (response.ok && data.success) {
        form.reset();
        status.textContent = "Message sent. I will follow up soon.";
        status.dataset.state = "success";
      } else {
        status.textContent = data.message || "Could not send the message. Please try again.";
        status.dataset.state = "error";
      }
    } catch {
      status.textContent = "Could not send the message. Please try again.";
      status.dataset.state = "error";
    } finally {
      submitButton.textContent = originalText;
      submitButton.disabled = false;
    }
  });
</script>
