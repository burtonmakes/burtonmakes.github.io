---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteMeta } from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Contact"
  description="Contact links for Alex Burton."
>
  <section class="section contact-hero contact-hero-compact">
    <div class="hero-copy reveal">
      <p class="eyebrow">Contact</p>
      <h1>Simple public links.</h1>
      <p class="hero-text">
        Public surfaces for recruiting, collaboration, technical review, and research context.
        These open in a new tab so the portfolio stays available.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href={siteMeta.links.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a class="button button-secondary" href={siteMeta.links.github} target="_blank" rel="noreferrer noopener">GitHub</a>
        <a class="button button-tertiary" href={siteMeta.links.scholar} target="_blank" rel="noreferrer noopener">Google Scholar</a>
      </div>
    </div>

    <div class="contact-link-grid reveal" aria-label="Public contact links">
      <a class="publication-card tilt-card" href={siteMeta.links.linkedin} target="_blank" rel="noreferrer noopener">
        <span>LinkedIn</span>
        <strong>Profile and message surface</strong>
        <p>Best for recruiter outreach and job conversation.</p>
      </a>

      <a class="publication-card tilt-card" href={siteMeta.links.github} target="_blank" rel="noreferrer noopener">
        <span>GitHub</span>
        <strong>Code and project history</strong>
        <p>Best for reviewing technical work and active repositories.</p>
      </a>

      <a class="publication-card tilt-card" href={siteMeta.links.scholar} target="_blank" rel="noreferrer noopener">
        <span>Google Scholar</span>
        <strong>Publication and citation record</strong>
        <p>Best for research and publication context.</p>
      </a>

      <a class="publication-card tilt-card" href="/projects/">
        <span>Projects</span>
        <strong>Work and home project index</strong>
        <p>Best for seeing professional builds separated from personal systems.</p>
      </a>
    </div>
  </section>
</BaseLayout>
