---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { futureIdeas, researchAreas, researchLinks } from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Research Notes"
  description="Active technical directions, linked project ideas, and future research areas for Alex Burton."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Research notes</p>
      <h1>Current technical directions and future project seeds.</h1>
      <p class="hero-text">
        This section tracks what is actively interesting, how ideas connect to projects, and where future builds may come from.
      </p>
    </div>
    <div class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="profile-list">
        <div><span>Purpose</span><strong>Capture learning, direction, and project candidates before they become full builds.</strong></div>
        <div><span>Relationship</span><strong>Research notes cross-link to projects, skills, and future archive entries.</strong></div>
      </div>
    </div>
  </section>

  <section class="section" id="active-research">
    <div class="section-heading reveal">
      <p class="eyebrow">Active research areas</p>
      <h2>Technical themes currently worth watching.</h2>
    </div>
    <div class="card-grid">
      {researchAreas.map((area) => (
        <article class="feature-card reveal">
          <h3>{area}</h3>
          <p>Placeholder public-safe notes can later expand this direction into experiments, references, and linked builds.</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Research-to-project links</p>
      <h2>How ideas convert into concrete project homes.</h2>
    </div>
    <div class="timeline-stack">
      {researchLinks.map((item) => (
        <a class="timeline-card reveal" href={item.href}>
          <strong>{item.note}</strong>
          <p>Related project: {item.project}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Future ideas</p>
      <h2>Placeholder concept cards for what may become the next builds.</h2>
    </div>
    <div class="card-grid">
      {futureIdeas.map((idea) => (
        <article class="story-card reveal">
          <span class="feature-kicker">Future idea</span>
          <h3>{idea}</h3>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
