---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
---

<BaseLayout
  title="Private"
  description="Placeholder page for private notes, admin materials, and sensitive project details not included in the public site."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Private placeholder</p>
      <h1>Private notes, admin materials, and sensitive project details are not included in the public site.</h1>
      <p class="hero-text">
        This page is intentionally a placeholder only. No authentication is implemented here, and no private content is exposed.
      </p>
    </div>
    <article class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="locked-panel">
        <span class="label">Status</span>
        <strong>Private area placeholder</strong>
        <p>Login or access controls can be designed later if there is a real public-safe reason to add them.</p>
      </div>
    </article>
  </section>
</BaseLayout>
