      border-radius: 11px;
    }

    .portfolio-chat .chat-usage {
      display: none;
    }

    .chat-context {
      margin: 10px 0 12px;
      font-size: 0.84rem;
    }

    .chat-messages {
      max-height: 34vh;
      padding-right: 0;
    }

    .chat-message {
      max-width: 100%;
      padding: 12px 14px;
