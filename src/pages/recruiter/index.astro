---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { capabilityTaxonomy } from "../../data/capability-map";
import { recruiterRoleProfiles, recruiterSkillTags } from "../../data/recruiter-normalizer";
import { projects, workHistory } from "../../data/site";
import "../../styles/global.css";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const sourceTagsByKey = new Map<string, string[]>();

workHistory.forEach((role) => {
  sourceTagsByKey.set(`work:${slugify(role.title)}:${slugify(role.company)}`, [...role.skills]);
});

projects.forEach((project) => {
  sourceTagsByKey.set(`project:${project.slug}`, [
    ...project.skills,
    ...project.labels,
    ...project.stack,
    project.section,
    project.type,
  ]);
});

const matcherData = capabilityTaxonomy.flatMap((group) =>
  group.nodes.map((node) => ({
    group: group.label,
    id: node.id,
    label: node.label,
    summary: node.summary,
    yearsActive: node.yearsActive,
    yearsScore: node.yearsScore,
    skillTags: node.skillTags,
    evidence: node.evidence.map((item) => ({
      key: item.key,
      kind: item.kind,
      title: item.title,
      href: item.href,
      period: item.period,
      summary: item.summary,
      note: item.note,
      highlights: item.highlights.slice(0, 2),
      tags: sourceTagsByKey.get(item.key) ?? [],
    })),
  }))
);

const portfolioEvidence = new Map<string, {
  id: string;
  title: string;
  kind: string;
  href: string;
  summary: string;
  tags: string[];
  highlights: readonly string[];
  capabilities: string[];
}>();

matcherData.forEach((node) => {
  node.evidence.forEach((item) => {
    const current = portfolioEvidence.get(item.key);
    portfolioEvidence.set(item.key, {
      id: item.key,
      title: item.title,
      kind: item.kind,
      href: item.href,
      summary: item.summary,
      tags: [...new Set([...(current?.tags ?? []), ...item.tags, ...node.skillTags, node.label, node.group])].slice(0, 18),
      highlights: item.highlights,
      capabilities: [...new Set([...(current?.capabilities ?? []), node.label])],
    });
  });
});

const matcherJson = JSON.stringify(matcherData);
const portfolioJson = JSON.stringify([...portfolioEvidence.values()]);
const normalizerJson = JSON.stringify(recruiterSkillTags);
const roleProfilesJson = JSON.stringify(recruiterRoleProfiles);
const recruiterMatchApi = import.meta.env.PUBLIC_RECRUITER_MATCH_API || "";
---

<BaseLayout
  title="Recruiter Match"
  description="Recruiter-facing role comparison for Alex Burton's engineering portfolio."
>
  <section class="section recruiter-onepage" data-recruiter-onepage>
    <div class="recruiter-shell reveal">
      <div class="recruiter-hero-grid">
        <div class="recruiter-hero-copy">
          <p class="eyebrow">Recruiter fast path</p>
          <h1>Compare your role with Alex Burton’s evidence.</h1>
          <p>
            Add hiring context, paste the role, and get a common-match score between the recruiter’s needs
            and Alex’s mapped work history, projects, skills, and portfolio evidence.
          </p>
        </div>

        <div class="match-flow-card" aria-label="Recruiter role context is compared with Alex Burton portfolio evidence.">
          <div class="flow-node">
            <span>Recruiter</span>
            <small>Name · company · target role</small>
          </div>
          <div class="flow-common">
            <small>Metric shown below</small>
            <strong>Common match</strong>
            <i></i>
            <span>role requirements ↔ evidence</span>
          </div>
          <div class="flow-node">
            <span>Alex Burton</span>
            <small>Portfolio · projects · work history</small>
          </div>
        </div>
      </div>

      <div class="recruiter-workspace">
        <aside class="context-panel" aria-label="Recruiter context">
          <div class="panel-heading">
            <span>Step 1</span>
            <h2>Hiring context</h2>
            <p>These details improve the comparison by telling the matcher what kind of role is being filled.</p>
          </div>

          <div class="context-fields">
            <label for="recruiter-name">
              <span>Your name</span>
              <input id="recruiter-name" data-recruiter-name type="text" autocomplete="name" placeholder="Jordan Lee" />
            </label>

            <label for="recruiter-company">
              <span>Company</span>
              <input id="recruiter-company" data-recruiter-company type="text" autocomplete="organization" placeholder="Company or team" />
            </label>

            <label for="recruiter-role">
              <span>Role being filled</span>
              <input id="recruiter-role" data-recruiter-role type="text" placeholder="Senior sensor hardware engineer" />
            </label>
          </div>

          <button class="context-skip" type="button" data-skip-context>Skip context</button>

          <div class="context-quality" data-context-quality>
            <strong>Context improves accuracy</strong>
            <p>Without role title, company, and recruiter intent, the matcher can still run, but the comparison has less signal.</p>
          </div>

          <div class="data-path-card">
            <strong>Data path</strong>
            <ul>
              <li>Fuzzy Compare runs in the browser against Alex’s public portfolio map.</li>
              <li>AI Compare sends the pasted role, recruiter context, and portfolio index to a Cloudflare Worker.</li>
              <li>The Worker uses Cloudflare Workers AI: <code>@cf/qwen/qwen3-30b-a3b-fp8</code>.</li>
              <li>Current session text can be stored in this browser so the page does not clear while reviewing.</li>
            </ul>
            <div class="data-link-row">
              <a href="https://developers.cloudflare.com/workers-ai/models/qwen3-30b-a3b-fp8/" target="_blank" rel="noreferrer">Model details</a>
              <a href="https://developers.cloudflare.com/workers-ai/platform/data-usage/" target="_blank" rel="noreferrer">Data usage</a>
            </div>
          </div>
        </aside>

        <main class="matcher-panel" aria-label="Role comparison tool">
          <div class="panel-heading matcher-heading">
            <span>Step 2</span>
            <h2>Role comparison</h2>
            <p>Paste a job description, requirements section, or recruiter skill list. The result is a screening aid, not a hiring decision.</p>
          </div>

          <label class="role-text-field" for="role-text">
            <span>Job description, requirements, or keywords</span>
            <textarea
              id="role-text"
              data-match-input
              rows="9"
              maxlength="20000"
              placeholder="Paste the job description, responsibilities, requirements, or comma-separated skills."
            ></textarea>
          </label>
          <span class="character-limit" data-character-limit>0 / 20,000 characters</span>

          <div class="manual-skill-row">
            <label for="manual-skill">
              <span>Add or force a skill</span>
              <input id="manual-skill" data-manual-skill type="text" placeholder="board bring-up, FPC layout, NPI" />
            </label>
            <button class="button button-secondary" type="button" data-add-manual-skill>Add</button>
          </div>

          <div class="action-row">
            <button class="button button-primary" type="button" data-ai-run>AI Compare</button>
            <button class="button button-secondary" type="button" data-fuzzy-run>Fuzzy Compare</button>
            <button class="button button-secondary subtle" type="button" data-clear>Clear</button>
            <p class="match-status" data-match-status>Ready.</p>
          </div>

          <div class="detected-strip">
            <div class="detected-heading">
              <span>Detected role skills</span>
              <div class="detected-heading-actions">
                <strong data-detected-count>0 tags</strong>
                <button class="clear-tags-button" type="button" data-clear-detected-skills hidden>Clear all tags</button>
              </div>
            </div>
            <div class="detected-list" data-detected-skills>
              <p>Paste role text and run a comparison to review the normalized skills.</p>
            </div>
          </div>
        </main>
      </div>

      <section class="results-grid" aria-live="polite">
        <article class="score-card">
          <span>Common match score</span>
          <strong data-match-score>0%</strong>
          <p data-match-summary>Paste a role and compare it against mapped portfolio evidence.</p>
          <div class="metric-stack" data-match-metrics>
            <div>
              <small>Technical match</small>
              <b>0%</b>
              <i style="width:0%"></i>
            </div>
            <div>
              <small>Execution readiness</small>
              <b>0%</b>
              <i style="width:0%"></i>
            </div>
            <div>
              <small>Evidence strength</small>
              <b>0%</b>
              <i style="width:0%"></i>
            </div>
          </div>
        </article>

        <article class="role-read-card">
          <span>Role read</span>
          <strong data-role-profile>No role profile yet</strong>
          <p data-role-profile-summary>Detected skill categories will appear after comparison.</p>
          <div class="category-list" data-role-categories></div>
        </article>

        <article class="match-list-card">
          <h2>What matches well</h2>
          <ul data-match-list>
            <li>Waiting for role text.</li>
          </ul>
        </article>

        <article class="match-list-card">
          <h2>Review manually</h2>
          <ul data-gap-list>
            <li>Nothing checked yet.</li>
          </ul>
        </article>
      </section>

      <section class="evidence-section">
        <div class="section-heading compact">
          <p class="eyebrow">Evidence</p>
          <h2>Projects and work pulled forward by the match.</h2>
        </div>
        <div class="evidence-grid" data-evidence-list>
          <article class="evidence-empty">
            <strong>No evidence selected yet.</strong>
            <p>Run AI Compare or Fuzzy Compare to pull forward the closest work history and project evidence.</p>
          </article>
        </div>
      </section>
    </div>

    <dialog class="context-dialog" data-context-dialog aria-labelledby="context-dialog-title">
      <form method="dialog" class="context-modal">
        <span class="warning-dot" aria-hidden="true">!</span>
        <h2 id="context-dialog-title">Continue with less context?</h2>
        <p>
          The matcher can run without recruiter context, but accuracy is lower without the recruiter name,
          company, and role being filled. Those fields help the next step compare the role against Alex’s evidence.
        </p>
        <div class="dialog-actions">
          <button class="button button-secondary" value="cancel" type="submit">Go back</button>
          <button class="button button-primary" value="continue" type="submit" data-confirm-limited-context>Continue anyway</button>
        </div>
      </form>
    </dialog>
  </section>
</BaseLayout>

<style>
