    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.2;
  }

  .context-quality p {
    margin: 0;
    color: var(--muted-2);
    font-size: 0.8rem;
    line-height: 1.4;
  }

  .data-path-card ul {
