  .chat-form textarea {
    height: 82px;
    min-height: 82px;
    max-height: 150px;
    resize: none;
    padding: 13px 14px;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .chat-form textarea:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .recruiter-dialog,
  .source-dialog {
    width: min(780px, calc(100% - 28px));
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: #06101c;
    color: var(--text);
    box-shadow: 0 28px 100px rgba(0, 0, 0, 0.7);
  }

  .recruiter-dialog::backdrop,
  .source-dialog::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(4px);
