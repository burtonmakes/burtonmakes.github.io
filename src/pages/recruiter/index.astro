  .chat-message.user {
    max-width: 88%;
    margin-left: auto;
    border: 1px solid rgba(76, 141, 255, 0.22);
    background: linear-gradient(180deg, rgba(22, 49, 90, 0.94), rgba(19, 36, 68, 0.95));
  }

  .chat-message .source-chip-row {
    margin-top: 9px;
  }

  .suggested-questions {
    display: grid;
    grid-template-columns: 1fr;
