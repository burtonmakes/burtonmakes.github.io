    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .character-limit[data-state="warning"] {
    color: var(--cta-1);
  }

  .character-limit[data-state="full"] {
