    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.05), var(--shadow-soft);
  }

  .match-flow-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 8px;
    padding: 12px;
  }

