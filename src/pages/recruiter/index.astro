---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { capabilityTaxonomy } from "../../data/capability-map";
import { recruiterRoleProfiles, recruiterSkillTags } from "../../data/recruiter-normalizer";
import { projects, workHistory } from "../../data/site";
import "../../styles/global.css";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const sourceTagsByKey = new Map<string, string[]>();

workHistory.forEach((role) => {
  sourceTagsByKey.set(`work:${slugify(role.title)}:${slugify(role.company)}`, [...role.skills]);
});

projects.forEach((project) => {
  sourceTagsByKey.set(`project:${project.slug}`, [
    ...project.skills,
    ...project.labels,
    ...project.stack,
    project.section,
    project.type,
  ]);
});

const matcherData = capabilityTaxonomy.flatMap((group) =>
  group.nodes.map((node) => ({
    group: group.label,
    id: node.id,
    label: node.label,
    summary: node.summary,
    yearsActive: node.yearsActive,
    yearsScore: node.yearsScore,
    skillTags: node.skillTags,
    evidence: node.evidence.map((item) => ({
      key: item.key,
      kind: item.kind,
      title: item.title,
      href: item.href,
      period: item.period,
      summary: item.summary,
      note: item.note,
      highlights: item.highlights.slice(0, 2),
      tags: sourceTagsByKey.get(item.key) ?? [],
    })),
  }))
);

const portfolioEvidence = new Map<string, {
  id: string;
  title: string;
  kind: string;
  href: string;
  summary: string;
  tags: string[];
  highlights: readonly string[];
  capabilities: string[];
}>();

matcherData.forEach((node) => {
  node.evidence.forEach((item) => {
    const current = portfolioEvidence.get(item.key);
    portfolioEvidence.set(item.key, {
      id: item.key,
      title: item.title,
      kind: item.kind,
      href: item.href,
      summary: item.summary,
      tags: [...new Set([...(current?.tags ?? []), ...item.tags, ...node.skillTags, node.label, node.group])].slice(0, 18),
      highlights: item.highlights,
      capabilities: [...new Set([...(current?.capabilities ?? []), node.label])],
    });
  });
});

const matcherJson = JSON.stringify(matcherData);
const portfolioJson = JSON.stringify([...portfolioEvidence.values()]);
const normalizerJson = JSON.stringify(recruiterSkillTags);
const roleProfilesJson = JSON.stringify(recruiterRoleProfiles);
const recruiterMatchApi = import.meta.env.PUBLIC_RECRUITER_MATCH_API || "";
---

<BaseLayout
  title="Recruiter Match"
  description="Quick recruiter skill matcher for Alex Burton's biomedical systems engineering portfolio."
>
  <section class="section recruiter-match-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Recruiter fast path</p>
      <h1>Paste the role keywords. See where the portfolio matches.</h1>
      <p class="hero-text">
        Paste a job description or skill list. The tool pulls out likely role skills, normalizes the
        wording into clean tags, then compares those tags against mapped portfolio evidence.
      </p>
    </div>

    <div class="recruiter-match-shell reveal" data-recruiter-matcher>
      <div class="match-input-panel">
        <label for="recruiter-keywords">
          <span>Job description, requirements, or keywords</span>
          <textarea
            id="recruiter-keywords"
            data-match-input
            rows="8"
            placeholder="Paste a job description, responsibilities section, or comma-separated skills."
          ></textarea>
        </label>

        <div class="match-actions">
          <button class="button button-primary" type="button" data-ai-run>Analyze with AI</button>
          <button class="button button-secondary" type="button" data-extract-run>Local fallback</button>
          <button class="button button-tertiary" type="button" data-match-clear>Clear</button>
        </div>
        <p class="match-status" data-match-status>
          AI matching needs a Cloudflare Worker URL. Local fallback is available.
        </p>

        <section class="detected-skill-panel">
          <div class="detected-skill-heading">
            <span>Detected role skills</span>
            <strong data-detected-count>0 tags</strong>
          </div>
          <label class="manual-skill-field" for="manual-skill">
            <span>Add skill</span>
            <div class="manual-skill-row">
              <input id="manual-skill" data-manual-skill type="text" placeholder="board bring-up, FPC layout, NPI" />
              <button class="button button-secondary" type="button" data-add-manual-skill>Add</button>
            </div>
          </label>

          <div class="detected-skill-list" data-detected-skills>
            <p>Paste role text and extract skills to review the normalized tags.</p>
          </div>
        </section>
      </div>

      <div class="match-results-panel" aria-live="polite">
        <div class="match-summary-grid">
          <div class="match-score-card">
            <span>Candidate match</span>
            <strong data-match-score>0%</strong>
            <p data-match-summary>Extract or enter role skills to compare them against mapped portfolio evidence.</p>
          </div>

          <div class="role-insight-card">
            <span>Role read</span>
            <strong data-role-profile>No role profile yet</strong>
            <p data-role-profile-summary>Detected skill categories will appear after extraction.</p>
            <div class="role-category-list" data-role-categories></div>
          </div>
        </div>

        <div class="match-breakdown-grid">
          <section class="match-list-card">
            <h2>Matched / partial</h2>
            <ul data-match-list>
              <li>Waiting for keywords.</li>
            </ul>
          </section>

          <section class="match-list-card">
            <h2>Gaps</h2>
            <ul data-gap-list>
              <li>Nothing checked yet.</li>
            </ul>
          </section>
        </div>
      </div>
    </div>
  </section>

  <section class="section match-evidence-section">
    <div class="section-heading reveal">
      <p class="eyebrow">Evidence</p>
      <h2>Relevant work and projects appear here after matching.</h2>
    </div>

    <div class="match-evidence-grid reveal" data-evidence-list>
      <article class="evidence-empty">
        <strong>No keywords matched yet.</strong>
        <p>Paste requirements above to pull forward the closest capabilities, projects, and work history.</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .recruiter-match-hero {
    display: grid;
    gap: clamp(20px, 3vw, 34px);
    align-content: center;
  }

  .recruiter-match-hero .hero-copy {
    max-width: 1040px;
