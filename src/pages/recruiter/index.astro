    font-size: 0.76rem;
    line-height: 1.38;
  }

  .data-path-card code {
    color: var(--text);
    font-size: 0.74rem;
  }

  .data-link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
