---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { capabilityTaxonomy } from "../../data/capability-map";
import { projects, workHistory } from "../../data/site";
import "../../styles/global.css";
import "../../styles/recruiter.css";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const sourceTagsByKey = new Map<string, string[]>();
const sourcePeriodByKey = new Map<string, string>();

workHistory.forEach((role) => {
  const key = `work:${slugify(role.title)}:${slugify(role.company)}`;
  sourceTagsByKey.set(key, [
    ...role.skills,
  ]);
  sourcePeriodByKey.set(key, role.dates);
});

projects.forEach((project) => {
  const key = `project:${project.slug}`;
  sourceTagsByKey.set(key, [
    ...project.skills,
    ...project.labels,
    ...project.stack,
    project.section,
    project.type,
  ]);
  sourcePeriodByKey.set(key, project.timeline);
});

const portfolioEvidence = new Map<
  string,
  {
    id: string;
    title: string;
    kind: string;
    href: string;
    summary: string;
    period: string;
    tags: string[];
    highlights: readonly string[];
    capabilities: string[];
  }
>();

capabilityTaxonomy.forEach((group) => {
  group.nodes.forEach((node) => {
    node.evidence.forEach((item) => {
      const current = portfolioEvidence.get(item.key);
      portfolioEvidence.set(item.key, {
        id: item.key,
        title: item.title,
        kind: item.kind,
        href: item.href,
        summary: item.summary,
        period: current?.period || sourcePeriodByKey.get(item.key) || "",
        tags: [
          ...new Set([
            ...(current?.tags ?? []),
            ...(sourceTagsByKey.get(item.key) ?? []),
            ...node.skillTags,
            node.label,
            group.label,
          ]),
        ].slice(0, 18),
        highlights: item.highlights.slice(0, 3),
        capabilities: [
          ...new Set([...(current?.capabilities ?? []), node.label]),
        ],
      });
    });
  });
});

const portfolioJson = JSON.stringify([...portfolioEvidence.values()]);
const recruiterAssistantApi =
  import.meta.env.PUBLIC_RECRUITER_MATCH_API ||
  "https://burton-recruiter-match.burtonmakes.workers.dev/match";
---

<BaseLayout
  title="Portfolio Chat"
  description="Ask the recruiter match agent about Alex Burton's work and project evidence."
>
  <section class="section recruiter-portal" data-recruiter-portal>
    <div class="portal-header">
      <div class="portal-header-copy">
        <p class="eyebrow">Portfolio chat</p>
        <h1>Ask the portfolio assistant</h1>
        <p class="portal-intro">
          Ask a follow-up about the role, experience, or evidence. Answers are grounded in the public portfolio.
        </p>
      </div>
    </div>

    <div class="portal-grid">
      <main class="portal-main">
        <section class="role-entry-panel" aria-labelledby="role-text-heading">
          <div class="panel-heading-row">
            <div>
              <span class="section-label">Role review</span>
              <h2 id="role-text-heading">What are you hiring for?</h2>
              <p>
                Paste the job description or the key requirements.
              </p>
            </div>
            <div class="usage-summary" aria-label="Daily usage limits">
              <span data-analysis-remaining>3 questions left today</span>
            </div>
          </div>

          <label class="role-text-label" for="recruiter-role-text">
            <span class="sr-only">Job description or role information</span>
            <textarea
              id="recruiter-role-text"
              data-role-text
              rows="9"
              maxlength="10000"
              placeholder="Paste the job description, requirements, or recruiter notes here."
            ></textarea>
          </label>

          <div class="role-entry-footer">
            <span class="character-count" data-character-count>
              0 / 10,000 characters
            </span>
            <div class="role-actions">
              <button
                class="button button-secondary compact-button"
                type="button"
                data-clear-role
              >
                Clear role
              </button>
              <button
                class="button button-primary"
                type="button"
                data-analyze-role
              >
                Analyze role
              </button>
            </div>
          </div>
          <p class="portal-status" data-portal-status role="status">
            Ready for a role description.
          </p>
        </section>

        <section class="analysis-shell" data-analysis-shell hidden>
          <section class="role-summary-panel">
            <div class="section-heading-inline">
              <div>
                <span class="section-label section-label-numbered">
                  <span aria-hidden="true">01</span>
                  Role summary
                </span>
                <h2>The role you’re trying to fill</h2>
              </div>
              <span class="analysis-stale" data-analysis-stale hidden>
                Role text changed. Analyze again before using chat.
              </span>
            </div>
            <p class="summary-role-title" data-role-summary-title>Role summary</p>
            <p data-role-summary-copy></p>
            <div class="theme-list" data-role-themes></div>
          </section>

          <section class="coverage-panel" aria-labelledby="coverage-heading">
            <div class="coverage-heading">
              <span class="section-label section-label-numbered">
                <span aria-hidden="true">02</span>
                Evidence coverage
              </span>
              <h2 id="coverage-heading">How the documented experience lines up</h2>
            </div>
            <div class="coverage-grid">
              <article>
                <span>Supported by work</span>
                <strong data-work-coverage>0</strong>
                <p>Requirements linked to professional work-history evidence.</p>
              </article>
              <article>
                <span>Supported by projects</span>
                <strong data-project-coverage>0</strong>
                <p>
                  Requirements linked to commercial, research, or technical
                  project evidence.
                </p>
              </article>
            </div>
          </section>

          <section class="evidence-panel" aria-labelledby="evidence-heading">
            <div class="section-heading-inline evidence-heading-row">
              <div>
                <span class="section-label section-label-numbered">
                  <span aria-hidden="true">03</span>
                  Relevant evidence
                </span>
                <h2 id="evidence-heading">Recruiter-relevant evidence</h2>
              </div>
              <div class="evidence-filters" role="group" aria-label="Evidence filters">
                <button type="button" data-evidence-filter="all" data-active="true">
                  All
                </button>
                <button type="button" data-evidence-filter="work">Work</button>
                <button type="button" data-evidence-filter="project">
                  Projects
                </button>
              </div>
            </div>
            <div class="evidence-list" data-evidence-list></div>

            <template data-card-template="evidence">
              <button class="recruiter-card evidence-card" type="button" data-card-open>
                <header class="evidence-card-header">
                  <div>
                    <span class="evidence-type" data-card-type></span>
                    <h3 data-card-title></h3>
                  </div>
                  <div class="evidence-card-meta">
                    <span class="evidence-period" data-card-period></span>
                    <span class="card-support-label" data-card-support></span>
                  </div>
                </header>
                <p class="evidence-summary" data-card-summary></p>
                <div class="card-tag-row" data-card-requirements></div>
              </button>
            </template>
          </section>
        </section>
      </main>

      <aside
        class="portfolio-chat"
        data-minimized="true"
        aria-labelledby="chat-heading"
      >
        <div class="chat-header">
          <div class="chat-brand">
            <img src="/logo.svg" alt="Coco the husky" class="chat-avatar" />
            <div>
              <span class="section-label">AI evidence retrieval</span>
              <h2 id="chat-heading">Recruiter Match Agent</h2>
            </div>
          </div>
          <div class="chat-header-actions">
            <button
              class="chat-minimize"
              type="button"
              data-chat-toggle
              aria-controls="portfolio-chat-body"
              aria-expanded="false"
              aria-label="Open Recruiter Match Agent"
            >
              <span aria-hidden="true">+</span>
            </button>
          </div>
        </div>

        <div class="chat-body" id="portfolio-chat-body">
          <span class="chat-usage" data-chat-remaining>3 questions left today</span>

          <div class="chat-messages" data-chat-messages aria-live="polite">
            <article class="chat-message assistant">
              <span class="chat-speaker">Recruiter match agent</span>
              <p>
                Ask about Alex's work, projects, or role fit.
              </p>
            </article>
          </div>

          <div class="suggested-questions" data-suggested-questions hidden>
            <button type="button">What AI integration experience is documented?</button>
            <button type="button">Show hardware design and documentation evidence.</button>
          </div>

          <form class="chat-form" data-chat-form>
            <label for="portfolio-chat-input" class="sr-only">
              Ask the recruiter match agent
            </label>
            <textarea
              id="portfolio-chat-input"
              data-chat-input
              rows="3"
              maxlength="1200"
              placeholder="Ask the recruiter match agent"
              disabled
            ></textarea>
            <div class="chat-form-footer">
              <span data-chat-count>0 / 1,200</span>
              <button
                class="chat-reset"
                type="button"
                data-chat-reset
                aria-label="Start a new chat"
              >
                New chat
              </button>
              <button
                class="button button-primary compact-button"
                type="submit"
                data-chat-submit
                disabled
              >
                Send
              </button>
            </div>
          </form>
          <p class="chat-status" data-chat-status role="status"></p>
        </div>
      </aside>
    </div>

    <dialog class="recruiter-dialog" data-context-dialog>
      <form method="dialog" class="dialog-panel" data-context-form>
        <div class="dialog-heading">
          <div>
            <span class="section-label">Recruiter information</span>
            <h2>Edit the role context.</h2>
            <p>
              These fields help the analysis understand who is reviewing the
              portfolio and which role is being filled.
            </p>
          </div>
          <button type="button" class="dialog-close" data-close-context aria-label="Close">
            ×
          </button>
        </div>

        <div class="dialog-fields">
          <label>
            <span>Your name</span>
            <input
              type="text"
              data-recruiter-name
              maxlength="120"
              autocomplete="name"
              placeholder="Jordan Lee"
            />
          </label>
          <label>
            <span>Company or team</span>
            <input
              type="text"
              data-recruiter-company
              maxlength="160"
              autocomplete="organization"
              placeholder="Company or team"
            />
          </label>
          <label>
            <span>Role being filled</span>
            <input
              type="text"
              data-recruiter-role
              maxlength="180"
              placeholder="Senior sensor hardware engineer"
            />
          </label>
        </div>

        <div class="dialog-actions">
          <button
            class="button button-secondary"
            type="button"
            data-skip-context
          >
            Continue with missing information
          </button>
          <button class="button button-primary" type="submit">
            Save recruiter information
          </button>
        </div>
      </form>
    </dialog>

    <dialog class="source-dialog" data-source-dialog>
      <article class="source-dialog-panel">
        <div class="dialog-heading">
          <div>
            <span class="section-label" data-source-type>Portfolio source</span>
            <h2 data-source-title>Evidence source</h2>
          </div>
          <button type="button" class="dialog-close" data-close-source aria-label="Close">
            ×
          </button>
        </div>
        <p class="source-excerpt" data-source-excerpt></p>
        <div class="source-dialog-actions">
          <a class="button button-primary" data-source-link href="/">
            Open full portfolio page
          </a>
        </div>
      </article>
    </dialog>

    <dialog class="source-dialog evidence-dialog" data-evidence-dialog>
      <article class="source-dialog-panel">
        <div class="dialog-heading">
          <div>
            <span class="section-label" data-evidence-type>Portfolio evidence</span>
            <h2 data-evidence-title>Evidence detail</h2>
          </div>
          <button type="button" class="dialog-close" data-close-evidence aria-label="Close">
            ×
          </button>
        </div>
        <p class="source-excerpt" data-evidence-excerpt></p>
        <div class="source-chip-row" data-evidence-requirements></div>
        <div class="source-dialog-actions">
          <button class="button button-secondary compact-button" type="button" data-evidence-back>
            Go back
          </button>
          <a class="button button-primary compact-button" data-evidence-link href="/">
            Open detail
          </a>
        </div>
      </article>
    </dialog>

    <dialog class="source-dialog limit-dialog" data-limit-dialog>
      <article class="source-dialog-panel">
        <div class="dialog-heading">
          <div>
            <span class="section-label">Recruiter assistant</span>
            <h2 data-limit-title>Today's AI credits are used</h2>
          </div>
          <button type="button" class="dialog-close" data-close-limit aria-label="Close">
            ×
          </button>
        </div>
        <p class="source-excerpt" data-limit-copy>
          You can keep browsing the portfolio, or contact Alex directly to continue the conversation.
        </p>
        <div class="source-dialog-actions limit-dialog-actions">
          <button class="button button-secondary compact-button" type="button" data-close-limit-action>
            Keep browsing
          </button>
          <a class="button button-primary compact-button" href="/contact/">
            Contact Alex directly
          </a>
        </div>
      </article>
    </dialog>
  </section>
</BaseLayout>


<script
  define:vars={{
    portfolioJson,
    recruiterAssistantApi,
  }}
>
  const portfolioIndex = JSON.parse(portfolioJson);
  const apiEndpoint = recruiterAssistantApi;
  const storageKey = "burton-recruiter-onepage-session-v5";
  const legacyStorageKey = "burton-recruiter-onepage-session-v4";
  const maxRoleCharacters = 10000;
  const maxChatCharacters = 1200;

  const page = document.querySelector("[data-recruiter-portal]");

  if (page && page.dataset.ready !== "true") {
    page.dataset.ready = "true";

    const elements = {
      contextDialog: page.querySelector("[data-context-dialog]"),
      contextForm: page.querySelector("[data-context-form]"),
      closeContext: page.querySelector("[data-close-context]"),
      skipContext: page.querySelector("[data-skip-context]"),
      recruiterName: page.querySelector("[data-recruiter-name]"),
      recruiterCompany: page.querySelector("[data-recruiter-company]"),
      recruiterRole: page.querySelector("[data-recruiter-role]"),
      roleText: page.querySelector("[data-role-text]"),
      characterCount: page.querySelector("[data-character-count]"),
      clearRole: page.querySelector("[data-clear-role]"),
      analyzeRole: page.querySelector("[data-analyze-role]"),
      portalStatus: page.querySelector("[data-portal-status]"),
      analysisRemaining: page.querySelector("[data-analysis-remaining]"),
      analysisShell: page.querySelector("[data-analysis-shell]"),
      analysisStale: page.querySelector("[data-analysis-stale]"),
      roleSummaryTitle: page.querySelector("[data-role-summary-title]"),
      roleSummaryCopy: page.querySelector("[data-role-summary-copy]"),
      roleThemes: page.querySelector("[data-role-themes]"),
      workCoverage: page.querySelector("[data-work-coverage]"),
      projectCoverage: page.querySelector("[data-project-coverage]"),
      evidenceList: page.querySelector("[data-evidence-list]"),
      evidenceTemplate: page.querySelector("[data-card-template=\"evidence\"]"),
      evidenceFilters: [...page.querySelectorAll("[data-evidence-filter]")],
      chatRemaining: page.querySelector("[data-chat-remaining]"),
      chatPanel: page.querySelector(".portfolio-chat"),
      chatToggle: page.querySelector("[data-chat-toggle]"),
      chatReset: page.querySelector("[data-chat-reset]"),
      chatMessages: page.querySelector("[data-chat-messages]"),
      suggestedQuestions: page.querySelector("[data-suggested-questions]"),
      chatForm: page.querySelector("[data-chat-form]"),
      chatInput: page.querySelector("[data-chat-input]"),
      chatSubmit: page.querySelector("[data-chat-submit]"),
      chatCount: page.querySelector("[data-chat-count]"),
      chatStatus: page.querySelector("[data-chat-status]"),
      sourceDialog: page.querySelector("[data-source-dialog]"),
      sourceType: page.querySelector("[data-source-type]"),
      sourceTitle: page.querySelector("[data-source-title]"),
      sourceExcerpt: page.querySelector("[data-source-excerpt]"),
      sourceLink: page.querySelector("[data-source-link]"),
      closeSource: page.querySelector("[data-close-source]"),
      evidenceDialog: page.querySelector("[data-evidence-dialog]"),
      evidenceType: page.querySelector("[data-evidence-type]"),
      evidenceTitle: page.querySelector("[data-evidence-title]"),
      evidenceExcerpt: page.querySelector("[data-evidence-excerpt]"),
      evidenceRequirements: page.querySelector("[data-evidence-requirements]"),
      evidenceLink: page.querySelector("[data-evidence-link]"),
      closeEvidence: page.querySelector("[data-close-evidence]"),
      evidenceBack: page.querySelector("[data-evidence-back]"),
      limitDialog: page.querySelector("[data-limit-dialog]"),
      limitTitle: page.querySelector("[data-limit-title]"),
      limitCopy: page.querySelector("[data-limit-copy]"),
      closeLimit: [...page.querySelectorAll("[data-close-limit], [data-close-limit-action]")],
    };

    const defaultState = {
      recruiterContext: {
        name: "",
        company: "",
        hiringFor: "",
        skipped: false,
      },
      jobText: "",
      analysis: null,
      conversation: [],
      analysisRemaining: 10,
      chatRemaining: 5,
      activeEvidenceFilter: "all",
      analysisStale: false,
    };

    const readStoredState = () => {
      try {
        const current = window.localStorage.getItem(storageKey);
        if (current) return { ...defaultState, ...JSON.parse(current) };

        const legacy = window.localStorage.getItem(legacyStorageKey);
        if (legacy) {
          const parsed = JSON.parse(legacy);
          return {
            ...defaultState,
            recruiterContext:
              parsed.recruiterContext || defaultState.recruiterContext,
            jobText: parsed.jobText || "",
          };
        }
      } catch {}
      return { ...defaultState };
    };

    let state = readStoredState();
    let sourceMap = new Map();
    let analyzing = false;
    let chatting = false;

    const writeState = () => {
      try {
        window.localStorage.setItem(storageKey, JSON.stringify(state));
      } catch {}
    };

    if (
      state.conversation.some(
        (message) => message.role === "assistant" && !message.evidencePoints?.length,
      )
    ) {
      state.conversation = [];
      writeState();
    }

    const setStatus = (element, message, mode = "") => {
      element.textContent = message;
      if (mode) element.dataset.state = mode;
      else delete element.dataset.state;
    };

    const contextComplete = () => {
      const context = state.recruiterContext;
      return Boolean(
        context.name?.trim() &&
          context.company?.trim() &&
          context.hiringFor?.trim(),
      );
    };

    const renderContext = () => {
      const context = state.recruiterContext;
      if (elements.recruiterName) elements.recruiterName.value = context.name || "";
      if (elements.recruiterCompany) elements.recruiterCompany.value = context.company || "";
      if (elements.recruiterRole) elements.recruiterRole.value = context.hiringFor || "";
    };

    const renderUsage = () => {
      const analyses = Math.max(0, Number(state.analysisRemaining ?? 10));
      const chats = Math.max(0, Number(state.chatRemaining ?? 5));
      elements.analysisRemaining.textContent = `${analyses} role ${
        analyses === 1 ? "analysis" : "analyses"
      } left today`;
      elements.chatRemaining.textContent = `${chats} ${
        chats === 1 ? "question" : "questions"
      } left today`;
      elements.analyzeRole.disabled = analyzing || analyses <= 0;
      elements.chatSubmit.disabled =
        chatting ||
        chats <= 0 ||
        !elements.chatInput.value.trim();
    };

    const updateCharacterCounts = () => {
      const roleCount = elements.roleText.value.length;
      elements.characterCount.textContent = `${roleCount.toLocaleString()} / ${maxRoleCharacters.toLocaleString()} characters`;
      const chatCount = elements.chatInput.value.length;
      elements.chatCount.textContent = `${chatCount.toLocaleString()} / ${maxChatCharacters.toLocaleString()}`;
    };

    const syncUsage = async () => {
      if (!apiEndpoint) return;
      try {
        const response = await fetch(apiEndpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ action: "usage" }),
        });
        const result = await response.json().catch(() => null);
        if (!response.ok || !result?.usage) return;
        state.analysisRemaining = Number(result.usage.analysisRemaining ?? 10);
        state.chatRemaining = Number(result.usage.chatRemaining ?? 5);
        writeState();
        renderUsage();
      } catch {}
    };

    const clearElement = (element) => {
      while (element.firstChild) element.firstChild.remove();
    };

    const closeEvidenceDialog = () => {
      if (elements.evidenceDialog?.open) {
        elements.evidenceDialog.close();
      }
    };

    const closeLimitDialog = () => {
      if (elements.limitDialog?.open) elements.limitDialog.close();
    };

    const openLimitDialog = (action, reason = "client") => {
      if (!elements.limitDialog) return;
      const isAnalysis = action === "analyze";
      if (elements.limitTitle) {
        elements.limitTitle.textContent = isAnalysis
          ? "Today's role-analysis credits are used"
          : "Today's chat credits are used";
      }
      if (elements.limitCopy) {
        const scope = reason === "global" ? "for the site" : "for this connection";
        elements.limitCopy.textContent = isAnalysis
          ? `The role-analysis allowance ${scope} is used for today. You can keep browsing the portfolio, or contact Alex directly to continue the conversation.`
          : `The portfolio-chat allowance ${scope} is used for today. You can keep browsing the portfolio, or contact Alex directly to continue the conversation.`;
      }
      if (!elements.limitDialog.open) elements.limitDialog.showModal();
    };

    const appendSourceButtons = (container, sourceIds) => {
      const row = document.createElement("div");
      row.className = "source-chip-row";

      sourceIds.forEach((sourceId) => {
        const source = sourceMap.get(sourceId);
        if (!source) return;
        const chip = document.createElement("span");
        chip.className = "source-chip";
        chip.textContent = source.title;
        row.append(chip);
      });

      if (row.childElementCount) container.append(row);
    };

    const appendEvidencePoints = (container, points = []) => {
      const list = document.createElement("div");
      list.className = "chat-evidence-list";

      points.slice(0, 2).forEach((item) => {
        const source = sourceMap.get(item.sourceId);
        const point = String(item.point || "").trim();
        if (!point) return;

        const evidence = document.createElement("article");
        evidence.className = "chat-evidence-item";
        const title = document.createElement("strong");
        title.textContent = source?.title || "Relevant evidence";
        const copy = document.createElement("p");
        copy.textContent = point;
        evidence.append(title, copy);
        list.append(evidence);
      });

      if (list.childElementCount) container.append(list);
    };

    const openSource = (sourceId) => {
      const source = sourceMap.get(sourceId);
      if (!source || !elements.sourceDialog || !elements.sourceType || !elements.sourceTitle) return;
      elements.sourceType.textContent =
        source.type === "work" ? "Work evidence" : "Project evidence";
      elements.sourceTitle.textContent = source.title;
      if (elements.sourceExcerpt) {
        elements.sourceExcerpt.textContent =
          source.excerpt || "Open the full portfolio page for more detail.";
      }
      if (elements.sourceLink && source.href) {
        elements.sourceLink.href = source.href;
      }
      if (!elements.sourceDialog.open) {
        elements.sourceDialog.showModal();
      }
    };

    const openEvidence = (source, sourceIndexItem, requirementIds = []) => {
      if (!source || !elements.evidenceDialog || !elements.evidenceType || !elements.evidenceTitle) return;

      elements.evidenceType.textContent =
        source.type === "work" ? "Work evidence" : "Project evidence";
      elements.evidenceTitle.textContent = source.title;
      if (elements.evidenceExcerpt) {
        elements.evidenceExcerpt.textContent =
          source.summary || source.excerpt || sourceIndexItem?.summary || "Documented public portfolio evidence.";
      }
      if (elements.evidenceLink && source.href) {
        elements.evidenceLink.href = source.href;
      }

      if (elements.evidenceRequirements) {
        clearElement(elements.evidenceRequirements);
        const requirements = new Map(
          (state.analysis?.requirements || []).map((requirement) => [
            requirement.id,
            requirement.label,
          ]),
        );
        [...new Set((requirementIds || []).map((id) => requirements.get(id)).filter(Boolean))].slice(0, 4).forEach((label) => {
          const chip = document.createElement("span");
          chip.className = "source-chip evidence-match-label";
          chip.textContent = label;
          elements.evidenceRequirements.append(chip);
        });
      }

      if (!elements.evidenceDialog.open) {
        elements.evidenceDialog.showModal();
      }
    };

    const rebuildSourceMap = (sources = []) => {
      sources.forEach((source) => {
        if (source?.id) sourceMap.set(source.id, source);
      });
    };

    const appendEvidenceMatchLabels = (container, sourceId, requirementIds) => {
      const requirements = new Map(
        (state.analysis?.requirements || []).map((requirement) => [
          requirement.id,
          requirement.label,
        ]),
      );
      const labels = [...new Set(
        (requirementIds || [])
          .map((id) => requirements.get(id))
          .filter(Boolean),
      )].slice(0, 4);
      if (!labels.length) return;

      const row = document.createElement("div");
      row.className = "source-chip-row evidence-match-labels";
      labels.forEach((label) => {
        const chip = document.createElement("span");
        chip.className = "source-chip evidence-match-label";
        chip.textContent = label;
        row.append(chip);
      });
      container.append(row);
    };

    const visibleEvidence = () => {
      const evidence = state.analysis?.evidence || [];
      const filter = state.activeEvidenceFilter || "all";
      if (filter === "all") return evidence;
      return evidence.filter((item) => {
        const source = sourceMap.get(item.sourceId);
        return source?.type === filter;
      });
    };

    const renderEvidence = () => {
      clearElement(elements.evidenceList);
      const evidence = visibleEvidence();

      if (!evidence.length) {
        const empty = document.createElement("p");
        empty.textContent = "No evidence is available for this filter.";
        elements.evidenceList?.append(empty);
        return;
      }

      evidence.forEach((item) => {
        const source = sourceMap.get(item.sourceId);
        if (!source) return;

        const article = elements.evidenceTemplate.content.firstElementChild.cloneNode(true);
        const type = article.querySelector("[data-card-type]");
        const title = article.querySelector("[data-card-title]");
        const summary = article.querySelector("[data-card-summary]");
        const periodElement = article.querySelector("[data-card-period]");
        const count = article.querySelector("[data-card-support]");
        const requirements = article.querySelector("[data-card-requirements]");

        type.textContent = source.type === "work" ? "Work" : "Project";
        title.textContent = source.title;
        summary.textContent = source.summary;
        const requirementCount = item.requirementIds?.length || 0;
        count.textContent = `Supports ${requirementCount} ${
          requirementCount === 1 ? "requirement" : "requirements"
        }`;

        const sourceIndexItem = portfolioIndex.find(
          (candidate) =>
            candidate.id === source.id ||
            candidate.href === source.href ||
            candidate.title === source.title,
        );
        const period = source.period || sourceIndexItem?.period;
        periodElement.textContent = period || "";
        periodElement.hidden = !period;
        appendEvidenceMatchLabels(requirements, item.sourceId, item.requirementIds);
        summary.textContent =
          item.whyRelevant ||
          source.summary ||
          sourceIndexItem?.summary ||
          source.excerpt ||
          "Documented public portfolio evidence.";
        article.addEventListener("click", () => {
          openEvidence(source, sourceIndexItem, item.requirementIds);
        });
        article.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            openEvidence(source, sourceIndexItem, item.requirementIds);
          }
        });
        elements.evidenceList?.append(article);
      });
    };

    const renderAnalysis = () => {
      if (!state.analysis) {
        elements.analysisShell.hidden = true;
        elements.chatInput.disabled = false;
        elements.chatInput.placeholder =
          "Ask about Alex's portfolio, a role, or a specific piece of evidence.";
        elements.suggestedQuestions.hidden = state.conversation.length > 0;
        setStatus(
          elements.chatStatus,
          "Ask about Alex's portfolio. Add role info only if you want a sharper match.",
        );
        renderUsage();
        return;
      }

      rebuildSourceMap(state.analysis.sources || []);
      elements.analysisShell.hidden = false;
      elements.roleSummaryTitle.textContent =
        state.analysis.roleSummary?.title || "Role summary";
      elements.roleSummaryCopy.textContent =
        state.analysis.roleSummary?.summary || "";
      clearElement(elements.roleThemes);
      (state.analysis.roleSummary?.themes || []).forEach((theme) => {
        const chip = document.createElement("span");
        chip.textContent = theme;
        elements.roleThemes.append(chip);
      });

      elements.workCoverage.textContent = String(
        state.analysis.coverage?.work || 0,
      );
      elements.projectCoverage.textContent = String(
        state.analysis.coverage?.projects || 0,
      );
      elements.analysisStale.hidden = !state.analysisStale;

      elements.evidenceFilters.forEach((button) => {
        button.dataset.active = String(
          button.dataset.evidenceFilter === state.activeEvidenceFilter,
        );
      });

      renderEvidence();

      const chatReady = !state.analysisStale;
      elements.chatInput.disabled = !chatReady;
      elements.chatInput.placeholder = chatReady
        ? "Ask the recruiter match agent about the role or Alex's documented experience."
        : "Analyze the edited role before continuing the chat.";
      elements.suggestedQuestions.hidden = !chatReady || state.conversation.length > 0;
      setStatus(
        elements.chatStatus,
        chatReady ? "" : "Re-analyze the role to continue chatting with the recruiter match agent.",
      );
      renderUsage();
    };

    const renderConversation = () => {
      clearElement(elements.chatMessages);
      if (elements.suggestedQuestions) {
        elements.suggestedQuestions.hidden = state.conversation.length > 0;
      }

      if (!state.conversation.length) {
        const article = document.createElement("article");
        article.className = "chat-message assistant";
        const speaker = document.createElement("span");
        speaker.className = "chat-speaker";
        speaker.textContent = "Assistant";
        const copy = document.createElement("p");
        copy.textContent = state.analysis
          ? "Ask about a requirement, work example, or project."
          : "Ask about Alex's work, projects, or role fit.";
        article.append(speaker, copy);
        elements.chatMessages?.append(article);
        return;
      }

      state.conversation.forEach((message) => {
        const article = document.createElement("article");
        article.className = `chat-message ${message.role}`;
        const speaker = document.createElement("span");
        speaker.className = "chat-speaker";
        speaker.textContent = message.role === "user" ? "You" : "Recruiter match agent";
        const copy = document.createElement("p");
        copy.textContent = message.content;
        article.append(speaker, copy);

        if (message.role === "assistant") {
          if (message.evidencePoints?.length) {
            appendEvidencePoints(article, message.evidencePoints);
          } else if (message.sourceIds?.length) {
            appendSourceButtons(article, message.sourceIds);
          }
        }

        elements.chatMessages?.append(article);
      });

      if (elements.chatMessages) {
        elements.chatMessages.scrollTop = elements.chatMessages.scrollHeight;
      }
    };

    const saveContextFromFields = (skipped = false) => {
      state.recruiterContext = {
        name: elements.recruiterName.value.trim(),
        company: elements.recruiterCompany.value.trim(),
        hiringFor: elements.recruiterRole.value.trim(),
        skipped,
      };
      writeState();
      renderContext();
    };

    const runAnalysis = async () => {
      if (analyzing) return;
      const jobText = elements.roleText.value.trim();

      if (jobText.length < 40) {
        setStatus(
          elements.portalStatus,
          "Paste at least 40 characters of role information before analyzing.",
          "error",
        );
        elements.roleText.focus();
        return;
      }

      if (!apiEndpoint) {
        setStatus(
          elements.portalStatus,
          "The recruiter assistant endpoint is not configured for this build.",
          "error",
        );
        return;
      }

      analyzing = true;
      state.jobText = elements.roleText.value;
      state.analysisStale = false;
      renderUsage();
      setStatus(
        elements.portalStatus,
        "Retrieving portfolio evidence and analyzing the role...",
        "loading",
      );

      try {
        const response = await fetch(apiEndpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            action: "analyze",
            recruiterContext: state.recruiterContext,
            jobText: state.jobText,
            portfolioIndex,
          }),
        });
        const result = await response.json().catch(() => null);

        if (!response.ok) {
          if (result?.usage?.analysisRemaining !== undefined) {
            state.analysisRemaining = result.usage.analysisRemaining;
            writeState();
          }
          if (response.status === 429) {
            openLimitDialog(
              "analyze",
              result?.code?.includes("global") ? "global" : "client",
            );
          }
          throw new Error(
            result?.error || `Role analysis failed with ${response.status}.`,
          );
        }

        state.analysis = {
          roleSummary: result.roleSummary,
          requirements: result.requirements,
          coverage: result.coverage,
          reasons: result.reasons,
          evidence: result.evidence,
          sources: result.sources,
        };
        state.analysisRemaining =
          result.usage?.analysisRemaining ?? state.analysisRemaining;
        state.analysisStale = false;
        sourceMap = new Map();
        writeState();
        renderAnalysis();
        renderConversation();
        if (Number(state.analysisRemaining) <= 0) openLimitDialog("analyze");
        setStatus(
          elements.portalStatus,
          "Role analysis complete. Review the summary and open any source for more detail.",
        );
        elements.analysisShell.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      } catch (error) {
        setStatus(
          elements.portalStatus,
          error?.message || "Role analysis failed.",
          "error",
        );
      } finally {
        analyzing = false;
        renderUsage();
      }
    };

    const submitChat = async (question) => {
      if (chatting) return;
      const trimmed = question.trim();
      if (!trimmed) return;
      if (!apiEndpoint) {
        setStatus(
          elements.chatStatus,
          "The recruiter assistant endpoint is not configured.",
          "error",
        );
        return;
      }

      state.conversation.push({ role: "user", content: trimmed });
      elements.chatInput.value = "";
      updateCharacterCounts();
      renderConversation();

      chatting = true;
      renderUsage();
      setStatus(elements.chatStatus, "Searching portfolio evidence...", "loading");

      try {
        const response = await fetch(apiEndpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            action: "chat",
            recruiterContext: state.recruiterContext,
            jobText: state.jobText,
            analysisContext: state.analysis
              ? {
                  roleSummary: state.analysis.roleSummary,
                  requirements: state.analysis.requirements,
                }
              : null,
            conversation: state.conversation.slice(0, -1).slice(-6),
            question: trimmed,
            portfolioIndex,
          }),
        });
        const result = await response.json().catch(() => null);

        if (!response.ok) {
          if (result?.usage?.chatRemaining !== undefined) {
            state.chatRemaining = result.usage.chatRemaining;
            writeState();
          }
          if (response.status === 429) {
            openLimitDialog(
              "chat",
              result?.code?.includes("global") ? "global" : "client",
            );
          }
          throw new Error(
            result?.error || `Portfolio chat failed with ${response.status}.`,
          );
        }

        rebuildSourceMap(result.sources || []);
        state.conversation.push({
          role: "assistant",
          content: result.answer,
          sourceIds: result.sourceIds || [],
          evidencePoints: result.evidence || [],
        });
        state.chatRemaining =
          result.usage?.chatRemaining ?? state.chatRemaining;
        writeState();
        renderConversation();
        if (Number(state.chatRemaining) <= 0) openLimitDialog("chat");
        setStatus(elements.chatStatus, "");
      } catch (error) {
        state.conversation.push({
          role: "assistant",
          content:
            error?.message ||
            "The portfolio chat could not complete that request.",
        });
        writeState();
        renderConversation();
        setStatus(
          elements.chatStatus,
          error?.message || "Portfolio chat failed.",
          "error",
        );
      } finally {
        chatting = false;
        renderUsage();
      }
    };

    if (elements.closeContext && elements.contextDialog) {
      elements.closeContext.addEventListener("click", () => {
        elements.contextDialog.close();
      });
    }

    if (elements.contextForm && elements.contextDialog) {
      elements.contextForm.addEventListener("submit", (event) => {
        event.preventDefault();
        saveContextFromFields(false);
        elements.contextDialog.close();
      });
    }

    if (elements.skipContext && elements.contextDialog) {
      elements.skipContext.addEventListener("click", () => {
        saveContextFromFields(true);
        elements.contextDialog.close();
      });
    }

    elements.roleText?.addEventListener("input", () => {
      state.jobText = elements.roleText.value;
      if (state.analysis) state.analysisStale = true;
      writeState();
      updateCharacterCounts();
      renderAnalysis();
      if (state.analysisStale) {
        setStatus(
          elements.portalStatus,
          "Role text changed. Analyze again to refresh the evidence and chat context.",
        );
      }
    });

    elements.clearRole?.addEventListener("click", () => {
      elements.roleText.value = "";
      state.jobText = "";
      state.analysis = null;
      state.conversation = [];
      state.analysisStale = false;
      sourceMap = new Map();
      writeState();
      updateCharacterCounts();
      renderAnalysis();
      renderConversation();
      setStatus(elements.portalStatus, "Role description cleared.");
      elements.roleText.focus();
    });

    elements.analyzeRole?.addEventListener("click", runAnalysis);

    elements.evidenceFilters.forEach((button) => {
      button.addEventListener("click", () => {
        state.activeEvidenceFilter = button.dataset.evidenceFilter || "all";
        writeState();
        renderAnalysis();
      });
    });

    elements.chatInput?.addEventListener("input", () => {
      updateCharacterCounts();
      renderUsage();
    });

    elements.chatInput?.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        if (!elements.chatSubmit.disabled) {
          submitChat(elements.chatInput.value);
        }
      }
    });

    const setChatMinimized = (minimized) => {
      if (!elements.chatPanel || !elements.chatToggle) return;
      elements.chatPanel.dataset.minimized = String(minimized);
      elements.chatToggle.setAttribute("aria-expanded", String(!minimized));
      elements.chatToggle.setAttribute(
        "aria-label",
        minimized ? "Open Recruiter Match Agent" : "Minimize Recruiter Match Agent",
      );
      const toggleMark = elements.chatToggle.querySelector("span");
      if (toggleMark) toggleMark.textContent = minimized ? "+" : "−";
    };

    elements.chatToggle?.addEventListener("click", () => {
      setChatMinimized(elements.chatPanel.dataset.minimized !== "true");
    });

    elements.chatReset?.addEventListener("click", () => {
      state.conversation = [];
      elements.chatInput.value = "";
      writeState();
      renderConversation();
      updateCharacterCounts();
      renderUsage();
      setStatus(elements.chatStatus, "New chat started.");
      elements.chatInput.focus();
    });

    elements.chatForm?.addEventListener("submit", (event) => {
      event.preventDefault();
      submitChat(elements.chatInput.value);
    });

    elements.suggestedQuestions?.querySelectorAll("button").forEach((button) => {
      button.addEventListener("click", () => {
        elements.chatInput.value = button.textContent.trim();
        updateCharacterCounts();
        renderUsage();
        elements.chatInput.focus();
      });
    });

    elements.closeSource?.addEventListener("click", () => {
      elements.sourceDialog.close();
    });

    elements.closeEvidence?.addEventListener("click", closeEvidenceDialog);
    elements.evidenceBack?.addEventListener("click", closeEvidenceDialog);
    elements.closeLimit.forEach((button) => {
      button.addEventListener("click", closeLimitDialog);
    });

    elements.roleText.value = String(state.jobText || "").slice(
      0,
      maxRoleCharacters,
    );
    setChatMinimized(true);
    renderContext();
    renderAnalysis();
    renderConversation();
    renderUsage();
    updateCharacterCounts();
    syncUsage();

    if (elements.contextDialog && !contextComplete() && !state.recruiterContext.skipped) {
      window.requestAnimationFrame(() => {
        elements.contextDialog.showModal();
      });
    }
  }
</script>
