  .flow-common {
    border: 1px solid var(--line);
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.018);
    padding: 13px;
  }

  .flow-node {
    display: grid;
    gap: 4px;
  }

  .flow-node span,
  .flow-common strong {
    color: var(--text);
    font-size: 1.02rem;
    font-weight: 900;
    line-height: 1.12;
  }

  .flow-node small,
  .flow-common small,
  .flow-common span {
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .flow-common {
    display: grid;
    gap: 8px;
    background: linear-gradient(180deg, rgba(111, 211, 255, 0.07), rgba(255, 255, 255, 0.014));
  }

  .flow-common i {
    display: block;
    height: 7px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--graph-amber), var(--graph-coral));
  }

  .recruiter-workspace {
    display: grid;
    grid-template-columns: minmax(300px, 0.38fr) minmax(0, 1fr);
    gap: 14px;
    align-items: start;
  }

  .context-panel,
  .matcher-panel {
    display: grid;
    gap: 14px;
    padding: clamp(16px, 2vw, 22px);
  }

  .panel-heading {
    display: grid;
    gap: 6px;
  }

  .panel-heading span,
  .role-text-field span,
  .manual-skill-row label span,
  .score-card span,
  .role-read-card span,
  .detected-heading span,
  .evidence-card span {
    color: var(--accent-2);
    font-size: 0.72rem;
    font-weight: 880;
    letter-spacing: 0.1em;
