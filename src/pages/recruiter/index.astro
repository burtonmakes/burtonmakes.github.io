  .match-score-card {
    padding: clamp(14px, 1.6vw, 18px);
  }

  .role-insight-card {
    display: grid;
    gap: 7px;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.014);
  }

  .role-insight-card span {
    color: var(--accent-2);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .role-insight-card strong {
    color: var(--text);
    font-size: clamp(1rem, 1.18vw, 1.2rem);
    line-height: 1.16;
  }

  .role-insight-card p {
    margin: 0;
    color: var(--muted-2);
    font-size: 0.84rem;
    line-height: 1.38;
  }

  .role-category-list {
    display: grid;
    gap: 6px;
    margin-top: 2px;
  }

  .role-category-row {
    display: grid;
    grid-template-columns: minmax(96px, 0.42fr) minmax(0, 1fr) auto;
    gap: 8px;
    align-items: center;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .role-category-bar {
    height: 6px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
  }

  .role-category-bar i {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--graph-amber), var(--graph-coral));
  }

  .match-score-card strong {
    display: block;
    margin: 8px 0 8px;
    color: var(--text);
    font-size: clamp(3.2rem, 6.8vw, 5.8rem);
    line-height: 0.88;
    letter-spacing: 0;
  }

  .match-score-card p {
    max-width: 58ch;
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .match-breakdown-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .match-list-card {
    padding: 20px;
  }

  .match-list-card h2 {
    margin-bottom: 14px;
    font-size: clamp(1.18rem, 1.5vw, 1.45rem);
  }

  .match-list-card ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .match-list-card li {
    color: var(--muted-2);
    font-size: 0.94rem;
    line-height: 1.42;
  }

  .match-list-card li + li {
    margin-top: 10px;
  }

  .match-evidence-section {
    align-content: start !important;
  }

  .match-evidence-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .evidence-empty,
  .match-evidence-card {
    padding: 22px;
  }

  .evidence-empty {
    grid-column: 1 / -1;
  }

  .evidence-empty strong,
  .match-evidence-card strong {
    display: block;
    color: var(--text);
    font-size: 1.08rem;
    line-height: 1.25;
  }

  .match-evidence-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 280px;
  }

  .match-evidence-card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.48;
  }

  .match-evidence-card ul {
    margin: 0;
    padding-left: 18px;
    color: var(--muted-2);
    font-size: 0.9rem;
  }

  .match-evidence-card .tag-row {
    margin-top: auto;
    padding-top: 4px;
  }

  @media (max-width: 1100px) {
    .recruiter-match-shell,
    .match-evidence-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .match-summary-grid,
    .match-breakdown-grid {
      grid-template-columns: 1fr;
    }

    .match-actions {
      flex-direction: column;
    }

    .manual-skill-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script define:vars={{ matcherJson, portfolioJson, normalizerJson, roleProfilesJson, recruiterMatchApi }}>
  const matcherData = JSON.parse(matcherJson);
  const portfolioIndex = JSON.parse(portfolioJson);
  const normalizerTags = JSON.parse(normalizerJson);
  const roleProfiles = JSON.parse(roleProfilesJson);
  const aiMatchEndpoint = recruiterMatchApi;

  const normalize = (value) =>
    String(value)
      .toLowerCase()
      .replace(/&/g, " and ")
      .replace(/[^a-z0-9+#.]+/g, " ")
      .replace(/\s+/g, " ")
      .trim();

  const tokenize = (value) => normalize(value).split(" ").filter((token) => token.length > 1);

  const titleCase = (value) =>
    normalize(value)
      .split(" ")
      .map((part) => {
        const upper = part.toUpperCase();
        if (["ble", "nfc", "fpc", "pcb", "npi", "cm", "jdm", "dsp", "ml", "ai", "ecg", "hrv"].includes(part)) return upper;
        return part.charAt(0).toUpperCase() + part.slice(1);
      })
      .join(" ")
      .replace(/\bAnd\b/g, "and");

  const escapeRegExp = (value) => String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

  const parseExplicitKeywords = (value) => {
    const direct = String(value)
      .split(/[,;\n|]+/)
      .map((item) => item.trim())
      .filter(Boolean);

    if (direct.length > 1) return [...new Set(direct)];

    return [...new Set(String(value).split(/\s{2,}|[,;\n|]+/).map((item) => item.trim()).filter(Boolean))];
  };

  const parseManualSkills = (value) =>
    [...new Set(String(value).split(/[,;\n|]+/).map((item) => item.trim()).filter(Boolean))];

  const phrasePatterns = [
    /\b(?:sensor|sensing|hardware|board|circuit|schematic|analog|embedded|mobile|factory|lab|reliability|quality|manufacturing|prototype|validation|verification|optoelectronics|optical|flexible|fpc|pcb|npi|consumer|medical|wearable|physiological)\s+[a-z0-9+#/.-]+(?:\s+[a-z0-9+#/.-]+){0,3}\b/g,
    /\b[a-z0-9+#/.-]+\s+(?:integration|architecture|design|debugging|validation|verification|testing|layout|bring-up|bring up|readiness|manufacturing|electronics|sensing|sensors|systems|workflow|workflows)\b/g,
  ];

  const skipExtractedPhrase = (value) => {
    const cleaned = normalize(value);
    return [
      "bachelor",
      "degree",
      "minimum qualifications",
      "related field",
      "work experience",
      "physics",
      "mathematics",
      "equivalent experience",
      "responsibilities",
    ].some((skip) => cleaned.includes(skip));
  };

  const addDetectedSkill = (skills, label, source, score = 0.72, alias = "") => {
    const normalized = normalize(label);
    if (!normalized || normalized.length < 2) return;

    const existing = skills.get(normalized);
    if (!existing || score > existing.score) {
      skills.set(normalized, {
        label,
        normalized,
        source,
        score,
        alias,
      });
    }
  };

  const extractRoleSkills = (value) => {
    const text = String(value);
    const normalizedText = ` ${normalize(text)} `;
    const skills = new Map();

    normalizerTags.forEach((tag) => {
      const aliases = [tag.label, ...tag.aliases];
      let bestAlias = "";
      let bestScore = 0;

      aliases.forEach((alias) => {
        const normalizedAlias = normalize(alias);
        if (!normalizedAlias) return;
        const pattern = new RegExp(`(^|\\\\s)${escapeRegExp(normalizedAlias)}(\\\\s|$)`);
        if (pattern.test(normalizedText)) {
          const aliasScore = Math.min(1, 0.72 + tag.priority / 400 + Math.min(0.08, normalizedAlias.length / 240));
          if (aliasScore > bestScore) {
            bestScore = aliasScore;
            bestAlias = alias;
          }
        }
      });

      if (bestScore > 0) {
        addDetectedSkill(skills, tag.label, "normalized", bestScore, bestAlias);
      }
    });

    const explicitKeywords = parseExplicitKeywords(text);
    const looksLikeSkillList = text.length < 520 || explicitKeywords.length <= 10;

    explicitKeywords.forEach((keyword) => {
      const cleaned = normalize(keyword);
      if (skipExtractedPhrase(cleaned)) return;
      if (cleaned.split(" ").length <= 6 && cleaned.length >= 3 && cleaned.length <= 64) {
        const bestTag = normalizerTags
          .map((tag) => ({
            tag,
            score: Math.max(scorePhrase(cleaned, tag.label), ...tag.aliases.map((alias) => scorePhrase(cleaned, alias))),
          }))
          .sort((a, b) => b.score - a.score)[0];

        if (bestTag?.score >= 0.72) {
          addDetectedSkill(skills, bestTag.tag.label, "normalized", bestTag.score, keyword);
        } else if (looksLikeSkillList && (text.includes(",") || text.includes(";") || text.includes("|"))) {
          addDetectedSkill(skills, titleCase(keyword), "typed", 0.58, keyword);
        }
      }
    });

    phrasePatterns.forEach((pattern) => {
      const matches = normalizedText.match(pattern) ?? [];
      matches.forEach((match) => {
        const cleaned = normalize(match);
        const tokens = cleaned.split(" ");
        if (tokens.length < 2 || tokens.length > 5 || cleaned.length > 56) return;
        if (skipExtractedPhrase(cleaned)) return;

        const bestTag = normalizerTags
          .map((tag) => ({
            tag,
            score: Math.max(scorePhrase(cleaned, tag.label), ...tag.aliases.map((alias) => scorePhrase(cleaned, alias))),
          }))
          .sort((a, b) => b.score - a.score)[0];

        if (bestTag?.score >= 0.64) {
          addDetectedSkill(skills, bestTag.tag.label, "normalized", bestTag.score, cleaned);
        } else if (tokens.some((token) => ["sensor", "sensing", "hardware", "board", "circuit", "embedded", "validation", "manufacturing", "reliability", "factory", "fpc", "pcb", "npi"].includes(token))) {
          addDetectedSkill(skills, titleCase(cleaned), "extracted", 0.52, cleaned);
        }
      });
    });

    return [...skills.values()]
      .sort((a, b) => b.score - a.score || a.label.localeCompare(b.label))
      .slice(0, 24);
  };

  const diceCoefficient = (left, right) => {
    const a = normalize(left);
    const b = normalize(right);
    if (!a || !b) return 0;
    if (a === b) return 1;
    if (a.length < 2 || b.length < 2) return a === b ? 1 : 0;

    const pairs = (value) => {
      const output = [];
      for (let index = 0; index < value.length - 1; index += 1) {
        output.push(value.slice(index, index + 2));
      }
      return output;
    };

    const leftPairs = pairs(a);
    const rightPairs = pairs(b);
    const used = new Array(rightPairs.length).fill(false);
    let matches = 0;

    leftPairs.forEach((pair) => {
      const matchIndex = rightPairs.findIndex((candidate, index) => !used[index] && candidate === pair);
      if (matchIndex >= 0) {
        used[matchIndex] = true;
        matches += 1;
      }
    });

    return (2 * matches) / (leftPairs.length + rightPairs.length);
  };

  const scorePhrase = (keyword, candidate) => {
    const key = normalize(keyword);
    const target = normalize(candidate);
    if (!key || !target) return 0;
    if (key === target) return 1;
    if (target.includes(key)) return 0.9;
    if (key.includes(target)) {
      return tokenize(target).length >= 2 ? 0.82 : 0;
    }

    const keyTokens = tokenize(key);
    const targetTokens = new Set(tokenize(target));
    const tokenOverlap = keyTokens.length
      ? keyTokens.filter((token) => targetTokens.has(token)).length / keyTokens.length
      : 0;

    return Math.max(diceCoefficient(key, target), tokenOverlap * 0.86);
  };

  const bestNodeMatch = (keyword, node) => {
    const matchedNormalizerTag = normalizerTags.find((tag) => normalize(tag.label) === normalize(keyword));
    const keywordTerms = [
      { term: keyword, mapped: false },
      ...(matchedNormalizerTag?.portfolioTerms ?? []).map((term) => ({ term, mapped: true })),
    ];
    const candidates = [
      node.label,
      node.group,
      node.summary,
      ...node.skillTags,
      ...node.evidence.flatMap((item) => [item.title, item.summary, item.note, ...item.highlights, ...item.tags]),
    ];

    const best = candidates.reduce(
      (current, candidate) => {
        const bestTerm = keywordTerms
          .map((item) => ({
            mapped: item.mapped,
            score: scorePhrase(item.term, candidate) * (item.mapped ? 0.82 : 1),
          }))
          .sort((a, b) => b.score - a.score)[0];
        return bestTerm.score > current.score ? { score: bestTerm.score, label: candidate, mapped: bestTerm.mapped } : current;
      },
      { score: 0, label: "", mapped: false },
    );

    return best;
  };

  const getGrade = (score) => {
    if (score >= 82) return "Strong initial fit";
    if (score >= 62) return "Good partial fit";
    if (score >= 38) return "Some overlap";
    return "Limited mapped overlap";
  };

  const formatMatchLabel = (label) => {
    const value = String(label || "").trim();
    if (value.length <= 54) return value;
    return "portfolio evidence";
  };

  const renderList = (element, items, emptyText) => {
    element.innerHTML = "";
    const content = items.length ? items : [emptyText];
    content.forEach((item) => {
      const li = document.createElement("li");
      li.textContent = item;
      element.append(li);
    });
  };

  const renderDetectedSkills = (element, countElement, skills, onRemove) => {
    element.innerHTML = "";
    countElement.textContent = `${skills.length} tag${skills.length === 1 ? "" : "s"}`;

    if (skills.length === 0) {
      const empty = document.createElement("p");
      empty.textContent = "Paste role text and extract skills to review the normalized tags.";
      element.append(empty);
      return;
    }

    skills.forEach((skill) => {
      const chip = document.createElement("span");
      chip.className = "detected-skill-chip";
      chip.dataset.source = skill.source;
      chip.title = skill.alias ? `Detected from: ${skill.alias}` : skill.label;

      const label = document.createElement("span");
      label.textContent = skill.label;

      const button = document.createElement("button");
      button.type = "button";
      button.setAttribute("aria-label", `Remove ${skill.label}`);
      button.textContent = "x";
      button.addEventListener("click", () => onRemove(skill.normalized));

      chip.append(label, button);
      element.append(chip);
    });
  };

  const getSkillMetadata = (label) => normalizerTags.find((tag) => normalize(tag.label) === normalize(label));

  const getRoleProfile = (skills) => {
    if (skills.length === 0) return null;
    const skillLabels = skills.map((skill) => skill.label);
    return roleProfiles
      .map((profile) => {
        const score = profile.terms.reduce((total, term) => {
          const best = Math.max(...skillLabels.map((skill) => scorePhrase(term, skill)));
          return total + (best >= 0.86 ? 1 : best >= 0.68 ? 0.55 : 0);
        }, 0);
        return {
          ...profile,
          score: score / Math.max(1, profile.terms.length),
        };
      })
      .sort((a, b) => b.score - a.score)[0];
  };

  const getCategoryCoverage = (skills) => {
    const labels = {
      hardware: "Hardware",
      sensors: "Sensors",
      validation: "Validation",
      manufacturing: "Manufacturing",
      "software-data": "Software/data",
      leadership: "Leadership",
      domain: "Domain",
    };
    const counts = new Map();
    skills.forEach((skill) => {
      const category = getSkillMetadata(skill.label)?.category || "domain";
      counts.set(category, (counts.get(category) || 0) + 1);
    });

    const max = Math.max(1, ...counts.values());
    return [...counts.entries()]
      .map(([category, count]) => ({
        category,
        label: labels[category] || titleCase(category),
        count,
        width: Math.max(18, Math.round((count / max) * 100)),
      }))
      .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));
  };

  const renderRoleInsights = (profileElement, summaryElement, categoriesElement, skills) => {
    const profile = getRoleProfile(skills);
    if (!profile || profile.score <= 0) {
      profileElement.textContent = "No role profile yet";
      summaryElement.textContent = "Detected skill categories will appear after extraction.";
      categoriesElement.innerHTML = "";
      return;
    }

    profileElement.textContent = profile.label;
    summaryElement.textContent = profile.summary;
    categoriesElement.innerHTML = "";

    getCategoryCoverage(skills).slice(0, 5).forEach((item) => {
      const row = document.createElement("div");
      row.className = "role-category-row";
      row.innerHTML = `
        <span>${item.label}</span>
        <div class="role-category-bar" aria-hidden="true"><i style="width:${item.width}%"></i></div>
        <strong>${item.count}</strong>
      `;
      categoriesElement.append(row);
    });
  };

  const renderEvidence = (element, matches) => {
    element.innerHTML = "";

    const evidenceMap = new Map();
    matches.forEach((match) => {
      match.node.evidence.forEach((item) => {
        const current = evidenceMap.get(item.key);
        const nextScore = Math.max(match.score, current?.score || 0);
        evidenceMap.set(item.key, {
          ...item,
          score: nextScore,
          capabilities: [...new Set([...(current?.capabilities || []), match.node.label])],
          keywords: [...new Set([...(current?.keywords || []), match.keyword])],
          tags: [...new Set([...(current?.tags || []), ...item.tags])],
        });
      });
    });

    const evidence = [...evidenceMap.values()].sort((a, b) => b.score - a.score).slice(0, 6);

    if (evidence.length === 0) {
      const empty = document.createElement("article");
      empty.className = "evidence-empty";
      empty.innerHTML = "<strong>No strong matches yet.</strong><p>Try a job-description skill list, separated by commas or new lines.</p>";
      element.append(empty);
      return;
    }

    evidence.forEach((item) => {
      const card = document.createElement("article");
      card.className = "match-evidence-card";

      const highlights = item.highlights.map((highlight) => `<li>${highlight}</li>`).join("");
      const tags = item.capabilities
        .concat(item.tags)
        .filter((tag, index, list) => list.indexOf(tag) === index)
        .slice(0, 4)
        .map((tag) => `<span class="tag">${tag}</span>`)
        .join("");

      card.innerHTML = `
        <span>${item.kind} · ${Math.round(item.score * 100)}% match</span>
        <strong>${item.title}</strong>
        <p>${item.summary}</p>
        <ul>${highlights}</ul>
        <div class="tag-row">${tags}</div>
        <a class="text-link" href="${item.href}">View evidence</a>
      `;
      element.append(card);
    });
  };

  const portfolioById = new Map(portfolioIndex.map((item) => [item.id, item]));

  const renderAiEvidence = (element, matches) => {
    element.innerHTML = "";

    const evidenceMap = new Map();
    matches.forEach((match) => {
      const evidenceIds = Array.isArray(match.evidenceIds) ? match.evidenceIds : [];
      evidenceIds.forEach((id) => {
        const item = portfolioById.get(id);
        if (!item) return;
        const current = evidenceMap.get(id);
        const score = Math.max(current?.score || 0, Number(match.confidence) || 0);
        evidenceMap.set(id, {
          ...item,
          score,
          requirements: [...new Set([...(current?.requirements || []), match.requirement].filter(Boolean))],
        });
      });
    });

    const evidence = [...evidenceMap.values()].sort((a, b) => b.score - a.score).slice(0, 6);

    if (evidence.length === 0) {
      const empty = document.createElement("article");
      empty.className = "evidence-empty";
      empty.innerHTML = "<strong>No evidence selected yet.</strong><p>The AI response did not return portfolio evidence IDs for the matched requirements.</p>";
      element.append(empty);
      return;
    }

    evidence.forEach((item) => {
      const card = document.createElement("article");
      card.className = "match-evidence-card";

      const heading = document.createElement("span");
      heading.textContent = `${item.kind} · ${Math.round(item.score * 100)}% evidence confidence`;

      const title = document.createElement("strong");
      title.textContent = item.title;

      const summary = document.createElement("p");
      summary.textContent = item.summary;

      const highlights = document.createElement("ul");
      (item.highlights || []).slice(0, 2).forEach((highlight) => {
        const li = document.createElement("li");
        li.textContent = highlight;
        highlights.append(li);
      });

      const tags = document.createElement("div");
      tags.className = "tag-row";
      [...new Set([...(item.capabilities || []), ...(item.tags || []), ...(item.requirements || [])])]
        .slice(0, 4)
        .forEach((tag) => {
          const chip = document.createElement("span");
          chip.className = "tag";
          chip.textContent = tag;
          tags.append(chip);
        });

      const link = document.createElement("a");
      link.className = "text-link";
      link.href = item.href;
      link.textContent = "View evidence";

      card.append(heading, title, summary, highlights, tags, link);
      element.append(card);
    });
  };

  const classificationLabel = (value) => {
    const normalized = normalize(value);
    if (normalized === "direct") return "direct";
    if (normalized === "partial") return "partial";
    if (normalized === "adjacent") return "adjacent";
    return "gap";
  };

  const normalizeAiSkill = (item) => {
    const label = item?.label || item?.requirement || item?.skill || "";
    return {
      label: titleCase(label),
      normalized: normalize(label),
      source: "ai",
      score: item?.importance === "high" ? 0.9 : item?.importance === "low" ? 0.64 : 0.76,
      alias: item?.sourceText || item?.reason || "",
    };
  };

  const setupRecruiterMatcher = () => {
    document.querySelectorAll("[data-recruiter-matcher]").forEach((matcher) => {
      if (matcher.dataset.ready === "true") return;
      matcher.dataset.ready = "true";

      const input = matcher.querySelector("[data-match-input]");
      const aiButton = matcher.querySelector("[data-ai-run]");
      const extractButton = matcher.querySelector("[data-extract-run]");
      const clearButton = matcher.querySelector("[data-match-clear]");
      const statusElement = matcher.querySelector("[data-match-status]");
      const manualSkillInput = matcher.querySelector("[data-manual-skill]");
      const addManualSkillButton = matcher.querySelector("[data-add-manual-skill]");
      const detectedSkillsElement = matcher.querySelector("[data-detected-skills]");
      const detectedCountElement = matcher.querySelector("[data-detected-count]");
      const scoreElement = matcher.querySelector("[data-match-score]");
      const summaryElement = matcher.querySelector("[data-match-summary]");
      const roleProfileElement = matcher.querySelector("[data-role-profile]");
      const roleProfileSummaryElement = matcher.querySelector("[data-role-profile-summary]");
      const roleCategoriesElement = matcher.querySelector("[data-role-categories]");
      const matchList = matcher.querySelector("[data-match-list]");
      const gapList = matcher.querySelector("[data-gap-list]");
      const evidenceList = document.querySelector("[data-evidence-list]");
      let detectedSkills = [];

      const setStatus = (message, state = "") => {
        statusElement.textContent = message;
        if (state) {
          statusElement.dataset.state = state;
        } else {
          delete statusElement.dataset.state;
        }
      };

      const setDetectedSkills = (skills) => {
        const unique = new Map();
        skills.forEach((skill) => {
          const key = skill.normalized || normalize(skill.label);
          if (!key) return;
          const existing = unique.get(key);
          if (!existing || skill.score > existing.score) unique.set(key, { ...skill, normalized: key });
        });
        detectedSkills = [...unique.values()].sort((a, b) => b.score - a.score || a.label.localeCompare(b.label));
        renderDetectedSkills(detectedSkillsElement, detectedCountElement, detectedSkills, (normalized) => {
          setDetectedSkills(detectedSkills.filter((skill) => skill.normalized !== normalized));
          runMatch();
        });
        renderRoleInsights(roleProfileElement, roleProfileSummaryElement, roleCategoriesElement, detectedSkills);
      };

      const addManualSkills = (value) => {
        const skills = parseManualSkills(value).map((item) => {
          const label = titleCase(item);
          return {
            label,
            normalized: normalize(label),
            source: "typed",
            score: 0.66,
            alias: item,
          };
        }).filter((skill) => skill.label);

        if (skills.length === 0) return;
        setDetectedSkills([...detectedSkills, ...skills]);
        manualSkillInput.value = "";
        runMatch();
      };

      const runMatch = () => {
        const keywords = detectedSkills.length > 0 ? detectedSkills.map((skill) => skill.label) : extractRoleSkills(input.value).map((skill) => skill.label);
        if (keywords.length === 0) {
          scoreElement.textContent = "0%";
          summaryElement.textContent = "Extract or enter role skills to compare them against mapped portfolio evidence.";
          renderList(matchList, [], "Waiting for keywords.");
          renderList(gapList, [], "Nothing checked yet.");
          renderEvidence(evidenceList, []);
          return;
        }

        const keywordResults = keywords.map((keyword) => {
          const matches = matcherData
            .map((node) => ({ keyword, node, ...bestNodeMatch(keyword, node) }))
            .filter((match) => match.score >= 0.68)
            .sort((a, b) => b.score - a.score);

          return {
            keyword,
            best: matches[0],
            matches,
          };
        });

        const matched = keywordResults.filter((item) => item.best);
        const gaps = keywordResults.filter((item) => !item.best);
        const weightedScore = Math.round(
          (keywordResults.reduce((total, item) => total + Math.min(1, item.best?.score || 0), 0) / keywords.length) * 100,
        );

        const allMatches = matched.flatMap((item) => item.matches.slice(0, 2));

        scoreElement.textContent = `${weightedScore}%`;
        summaryElement.textContent = `${getGrade(weightedScore)} based on ${matched.length} of ${keywords.length} entered keyword${keywords.length === 1 ? "" : "s"} mapping to portfolio evidence.`;

        renderList(
          matchList,
          matched.map((item) => `${item.keyword} -> ${formatMatchLabel(item.best.label)} (${item.best.mapped ? "related evidence" : "direct match"}, ${Math.round(item.best.score * 100)}%)`),
          "No mapped matches.",
        );
        renderList(
          gapList,
          gaps.map((item) => item.keyword),
          "No obvious gaps from the entered list.",
        );
        renderEvidence(evidenceList, allMatches);
      };

      const renderAiMatch = (result) => {
        const extracted = Array.isArray(result.extractedRequirements) ? result.extractedRequirements : [];
        const matches = Array.isArray(result.matches) ? result.matches : [];
        const gaps = Array.isArray(result.gaps) ? result.gaps : [];
        const skills = extracted.map(normalizeAiSkill).filter((skill) => skill.normalized);
        const score = Math.max(0, Math.min(100, Math.round(Number(result.fitScore) || 0)));

        setDetectedSkills(skills);
        scoreElement.textContent = `${score}%`;
        summaryElement.textContent = result.fitSummary || `${getGrade(score)} based on AI-classified requirements and deterministic fit scoring.`;

        roleProfileElement.textContent = result.roleTitleGuess || result.roleCategory || "AI role read";
        roleProfileSummaryElement.textContent =
          result.roleCategory
            ? `Classified role family: ${result.roleCategory}.`
            : "The AI extracted role requirements and matched them against mapped portfolio evidence.";
        renderRoleInsights(roleProfileElement, roleProfileSummaryElement, roleCategoriesElement, detectedSkills);
        roleProfileElement.textContent = result.roleTitleGuess || result.roleCategory || roleProfileElement.textContent;
        if (result.roleCategory) {
          roleProfileSummaryElement.textContent = `Classified role family: ${result.roleCategory}.`;
        }

        renderList(
          matchList,
          matches.map((item) => {
            const classification = classificationLabel(item.classification);
            const confidence = Math.round(Math.max(0, Math.min(1, Number(item.confidence) || 0)) * 100);
            const portfolioSkill = item.matchedPortfolioSkill || item.matchedCapability || "portfolio evidence";
            return `${item.requirement} -> ${portfolioSkill} (${classification}, ${confidence}%)`;
          }),
          "No direct, partial, or adjacent matches returned.",
        );
        renderList(
          gapList,
          gaps.map((item) => item.reason ? `${item.requirement}: ${item.reason}` : item.requirement),
          "No clear gaps returned.",
        );
        renderAiEvidence(evidenceList, matches);
      };

      const runAiMatch = async () => {
        const jobText = input.value.trim();
        if (jobText.length < 20 && detectedSkills.length === 0) {
          setStatus("Paste a role description or add skills before running AI matching.", "error");
          input.focus();
          return;
        }

        if (!aiMatchEndpoint) {
          setStatus("No Cloudflare Worker URL is configured yet. Running the local fallback instead.", "error");
          extractAndMatch();
          return;
        }

        aiButton.disabled = true;
        extractButton.disabled = true;
        setStatus("Analyzing requirements with Cloudflare Workers AI...", "ready");

        try {
          const response = await fetch(aiMatchEndpoint, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              jobText,
              manualSkills: detectedSkills.map((skill) => skill.label),
              portfolioIndex,
              normalizerTags,
              roleProfiles,
            }),
          });

          const result = await response.json().catch(() => null);
          if (!response.ok) {
            throw new Error(result?.error || `Matcher request failed with ${response.status}`);
          }

          renderAiMatch(result);
          setStatus(`AI match complete. Score is calculated locally in the Worker, not guessed by the model.`, "ready");
        } catch (error) {
          setStatus(`${error.message || "AI matching failed"}. Local fallback is still available.`, "error");
        } finally {
          aiButton.disabled = false;
          extractButton.disabled = false;
        }
      };

      const extractAndMatch = () => {
        setStatus("Running local fallback matcher. AI matching will be more conservative once the Worker URL is configured.");
        setDetectedSkills(extractRoleSkills(input.value));
        runMatch();
      };

      aiButton.addEventListener("click", runAiMatch);
      extractButton.addEventListener("click", extractAndMatch);
      input.addEventListener("input", () => {
        if (input.value.trim().length > 0) {
          setStatus(aiMatchEndpoint ? "Ready to analyze with Cloudflare Workers AI." : "AI matching needs a Cloudflare Worker URL. Local fallback is available.");
        }
      });
      clearButton.addEventListener("click", () => {
        input.value = "";
        setDetectedSkills([]);
        setStatus(aiMatchEndpoint ? "Ready to analyze with Cloudflare Workers AI." : "AI matching needs a Cloudflare Worker URL. Local fallback is available.");
        runMatch();
        input.focus();
      });

      manualSkillInput.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          addManualSkills(manualSkillInput.value);
        }
      });

      addManualSkillButton.addEventListener("click", () => addManualSkills(manualSkillInput.value));

      setDetectedSkills([]);
      setStatus(aiMatchEndpoint ? "Ready to analyze with Cloudflare Workers AI." : "AI matching needs a Cloudflare Worker URL. Local fallback is available.");
    });
  };

  document.addEventListener("astro:page-load", setupRecruiterMatcher);
  setupRecruiterMatcher();
</script>
