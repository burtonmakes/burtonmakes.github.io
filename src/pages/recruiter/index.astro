---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { capabilityTaxonomy } from "../../data/capability-map";
import { projects, workHistory } from "../../data/site";
import "../../styles/global.css";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const sourceTagsByKey = new Map<string, string[]>();
const sourcePeriodByKey = new Map<string, string>();

workHistory.forEach((role) => {
  const key = `work:${slugify(role.title)}:${slugify(role.company)}`;
  sourceTagsByKey.set(key, [
    ...role.skills,
  ]);
  sourcePeriodByKey.set(key, role.dates);
});

projects.forEach((project) => {
  const key = `project:${project.slug}`;
  sourceTagsByKey.set(key, [
    ...project.skills,
    ...project.labels,
    ...project.stack,
    project.section,
    project.type,
  ]);
  sourcePeriodByKey.set(key, project.timeline);
});

const portfolioEvidence = new Map<
  string,
  {
    id: string;
    title: string;
    kind: string;
    href: string;
    summary: string;
    period: string;
    tags: string[];
    highlights: readonly string[];
    capabilities: string[];
  }
>();

capabilityTaxonomy.forEach((group) => {
  group.nodes.forEach((node) => {
    node.evidence.forEach((item) => {
      const current = portfolioEvidence.get(item.key);
      portfolioEvidence.set(item.key, {
        id: item.key,
        title: item.title,
        kind: item.kind,
        href: item.href,
        summary: item.summary,
        period: current?.period || sourcePeriodByKey.get(item.key) || "",
        tags: [
          ...new Set([
            ...(current?.tags ?? []),
            ...(sourceTagsByKey.get(item.key) ?? []),
            ...node.skillTags,
            node.label,
            group.label,
          ]),
        ].slice(0, 18),
        highlights: item.highlights.slice(0, 3),
        capabilities: [
          ...new Set([...(current?.capabilities ?? []), node.label]),
        ],
      });
    });
  });
});

const portfolioJson = JSON.stringify([...portfolioEvidence.values()]);
const recruiterAssistantApi =
  import.meta.env.PUBLIC_RECRUITER_MATCH_API ||
  "https://burton-recruiter-match.burtonmakes.workers.dev/match";
---

<BaseLayout
  title="Portfolio Chat"
  description="Ask the portfolio assistant about Alex Burton's work and project evidence."
>
  <section class="section recruiter-portal" data-recruiter-portal>
    <div class="portal-header">
      <div class="portal-header-copy">
        <p class="eyebrow">Portfolio chat</p>
        <h1>Ask the portfolio assistant</h1>
        <p class="portal-intro">
          Ask a follow-up about the role, experience, or evidence. Answers are grounded in the public portfolio.
        </p>
      </div>
    </div>

    <div class="portal-grid">
      <main class="portal-main">
        <section class="role-entry-panel" aria-labelledby="role-text-heading">
          <div class="panel-heading-row">
            <div>
              <span class="section-label">Role review</span>
              <h2 id="role-text-heading">What are you hiring for?</h2>
              <p>
                Paste the job description or the key requirements.
              </p>
            </div>
            <div class="usage-summary" aria-label="Daily usage limits">
              <span data-analysis-remaining>3 questions left today</span>
            </div>
          </div>

          <label class="role-text-label" for="recruiter-role-text">
            <span class="sr-only">Job description or role information</span>
            <textarea
              id="recruiter-role-text"
              data-role-text
              rows="9"
              maxlength="10000"
              placeholder="Paste the job description, requirements, or recruiter notes here."
            ></textarea>
          </label>

          <div class="role-entry-footer">
            <span class="character-count" data-character-count>
              0 / 10,000 characters
            </span>
            <div class="role-actions">
              <button
                class="button button-secondary compact-button"
                type="button"
                data-clear-role
              >
                Clear role
              </button>
              <button
                class="button button-primary"
                type="button"
                data-analyze-role
              >
                Analyze role
              </button>
            </div>
          </div>
          <p class="portal-status" data-portal-status role="status">
            Ready for a role description.
          </p>
        </section>

        <section class="analysis-shell" data-analysis-shell hidden>
          <section class="role-summary-panel">
            <div class="section-heading-inline">
              <div>
                <span class="section-label section-label-numbered">
                  <span aria-hidden="true">01</span>
                  Role summary
                </span>
                <h2>The role you’re trying to fill</h2>
              </div>
              <span class="analysis-stale" data-analysis-stale hidden>
                Role text changed. Analyze again before using chat.
              </span>
            </div>
            <p class="summary-role-title" data-role-summary-title>Role summary</p>
            <p data-role-summary-copy></p>
            <div class="theme-list" data-role-themes></div>
          </section>

          <section class="coverage-panel" aria-labelledby="coverage-heading">
            <div class="coverage-heading">
              <span class="section-label section-label-numbered">
                <span aria-hidden="true">02</span>
                Evidence coverage
              </span>
              <h2 id="coverage-heading">How the documented experience lines up</h2>
            </div>
            <div class="coverage-grid">
              <article>
                <span>Supported by work</span>
                <strong data-work-coverage>0</strong>
                <p>Requirements linked to professional work-history evidence.</p>
              </article>
              <article>
                <span>Supported by projects</span>
                <strong data-project-coverage>0</strong>
                <p>
                  Requirements linked to commercial, research, or technical
                  project evidence.
                </p>
              </article>
            </div>
          </section>

          <section class="evidence-panel" aria-labelledby="evidence-heading">
            <div class="section-heading-inline evidence-heading-row">
              <div>
                <span class="section-label section-label-numbered">
                  <span aria-hidden="true">03</span>
                  Relevant evidence
                </span>
                <h2 id="evidence-heading">Why this is a strong match</h2>
              </div>
              <div class="evidence-filters" role="group" aria-label="Evidence filters">
                <button type="button" data-evidence-filter="all" data-active="true">
                  All
                </button>
                <button type="button" data-evidence-filter="work">Work</button>
                <button type="button" data-evidence-filter="project">
                  Projects
                </button>
              </div>
            </div>
            <div class="reason-list" data-reason-list></div>
            <div class="evidence-list" data-evidence-list></div>
          </section>
        </section>
      </main>

      <aside class="portfolio-chat" aria-labelledby="chat-heading">
        <div class="chat-header">
          <div class="chat-brand">
            <img src="/logo.svg" alt="Coco the husky" class="chat-avatar" />
            <div>
              <span class="section-label">Portfolio assistant</span>
              <h2 id="chat-heading">Chat with Coco</h2>
            </div>
          </div>
          <div class="chat-header-actions">
            <button
              class="chat-minimize"
              type="button"
              data-chat-toggle
              aria-controls="portfolio-chat-body"
              aria-expanded="true"
              aria-label="Minimize Chat with Coco"
            >
              <span aria-hidden="true">−</span>
            </button>
          </div>
        </div>

        <div class="chat-body" id="portfolio-chat-body">
          <span class="chat-usage" data-chat-remaining>3 questions left today</span>
          <p class="chat-context">
            Ask a follow-up about the role, experience, or evidence. Answers are grounded in the public portfolio.
          </p>

          <div class="chat-messages" data-chat-messages aria-live="polite">
            <article class="chat-message assistant">
              <span class="chat-speaker">Portfolio assistant</span>
              <p>
                Analyze the role first. Then ask about hardware ownership, validation, manufacturing, sensing, research, or a specific requirement.
              </p>
            </article>
          </div>

          <div class="suggested-questions" data-suggested-questions hidden>
            <button type="button">What optical sensor experience is documented?</button>
            <button type="button">What manufacturing experience is documented?</button>
            <button type="button">Show the strongest sensor integration example.</button>
          </div>

          <form class="chat-form" data-chat-form>
            <label for="portfolio-chat-input" class="sr-only">
              Ask a portfolio question
            </label>
            <textarea
              id="portfolio-chat-input"
              data-chat-input
              rows="3"
              maxlength="1200"
              placeholder="Ask a portfolio question"
              disabled
            ></textarea>
            <div class="chat-form-footer">
              <span data-chat-count>0 / 1,200</span>
              <button
                class="button button-primary compact-button"
                type="submit"
                data-chat-submit
                disabled
              >
                Send
              </button>
            </div>
          </form>
          <p class="chat-status" data-chat-status role="status"></p>
        </div>
      </aside>
    </div>

    <dialog class="recruiter-dialog" data-context-dialog>
      <form method="dialog" class="dialog-panel" data-context-form>
        <div class="dialog-heading">
          <div>
            <span class="section-label">Recruiter information</span>
            <h2>Edit the role context.</h2>
            <p>
              These fields help the analysis understand who is reviewing the
              portfolio and which role is being filled.
            </p>
          </div>
          <button type="button" class="dialog-close" data-close-context aria-label="Close">
            ×
          </button>
        </div>

        <div class="dialog-fields">
          <label>
            <span>Your name</span>
            <input
              type="text"
              data-recruiter-name
              maxlength="120"
              autocomplete="name"
              placeholder="Jordan Lee"
            />
          </label>
          <label>
            <span>Company or team</span>
            <input
              type="text"
              data-recruiter-company
              maxlength="160"
              autocomplete="organization"
              placeholder="Company or team"
            />
          </label>
          <label>
            <span>Role being filled</span>
            <input
              type="text"
              data-recruiter-role
              maxlength="180"
              placeholder="Senior sensor hardware engineer"
            />
          </label>
        </div>

        <div class="dialog-actions">
          <button
            class="button button-secondary"
            type="button"
            data-skip-context
          >
            Continue with missing information
          </button>
          <button class="button button-primary" type="submit">
            Save recruiter information
          </button>
        </div>
      </form>
    </dialog>

    <dialog class="source-dialog" data-source-dialog>
      <article class="source-dialog-panel">
        <div class="dialog-heading">
          <div>
            <span class="section-label" data-source-type>Portfolio source</span>
            <h2 data-source-title>Evidence source</h2>
          </div>
          <button type="button" class="dialog-close" data-close-source aria-label="Close">
            ×
          </button>
        </div>
        <p class="source-excerpt" data-source-excerpt></p>
        <div class="source-dialog-actions">
          <a class="button button-primary" data-source-link href="/">
            Open full portfolio page
          </a>
        </div>
      </article>
    </dialog>
  </section>
</BaseLayout>

<style>
  .recruiter-portal {
    display: block;
    min-height: auto;
    padding-top: clamp(2rem, 4vh, 3rem);
    padding-bottom: clamp(3rem, 6vh, 5rem);
  }

  .portal-header {
    max-width: 1080px;
    margin-bottom: 22px;
  }

  .portal-header-copy {
    max-width: 780px;
    padding: clamp(18px, 2.5vw, 28px);
    border: 1px solid var(--line);
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(6, 16, 28, 0.88), rgba(6, 16, 28, 0.64));
    box-shadow: var(--shadow-soft);
  }

  .portal-header h1 {
    max-width: 24ch;
    margin-bottom: 14px;
    font-size: clamp(2.4rem, 4vw, 4.15rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .portal-intro {
    max-width: 60ch;
    margin: 0;
    color: var(--muted-2);
    font-size: 0.95rem;
  }

  .section-label {
    display: block;
    margin-bottom: 7px;
    color: var(--accent-2);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-label-numbered {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .section-label-numbered > span {
    display: inline-grid;
    width: 23px;
    height: 23px;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--cta-2), transparent 25%);
    border-radius: 7px;
    background: color-mix(in srgb, var(--cta-2), transparent 82%);
    color: var(--cta-1);
    font-size: 0.66rem;
    letter-spacing: 0;
  }

  .review-context,
  .role-entry-panel,
  .role-summary-panel,
  .coverage-panel,
  .evidence-panel,
  .portfolio-chat {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: color-mix(in srgb, var(--bg-2), transparent 18%);
    box-shadow: var(--shadow-soft);
  }

  .review-context {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: center;
    padding: 18px 20px;
    margin-bottom: 0;
  }

  .review-context h2,
  .role-entry-panel h2,
  .role-summary-panel h2,
  .coverage-panel h2,
  .evidence-panel h2,
  .portfolio-chat h2,
  .dialog-panel h2,
  .source-dialog-panel h2 {
    max-width: none;
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    line-height: 1.15;
  }

  .review-context p {
    margin: 5px 0 0;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .context-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 9px 14px;
    align-items: center;
  }

  .context-warning,
  .analysis-stale {
    color: var(--cta-1);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .portal-grid {
    display: block;
    padding-right: 430px;
  }

  .portal-grid:has(.portfolio-chat[data-minimized="true"]) {
    padding-right: 0;
  }

  .portal-main,
  .analysis-shell {
    display: grid;
    gap: 18px;
  }

  .analysis-shell {
    grid-template-columns: minmax(0, 1.25fr) minmax(230px, 0.75fr);
  }

  .analysis-shell > .evidence-panel {
    grid-column: 1 / -1;
  }

  .role-entry-panel,
  .role-summary-panel,
  .coverage-panel,
  .evidence-panel {
    padding: clamp(18px, 2vw, 24px);
  }

  .panel-heading-row,
  .section-heading-inline,
  .evidence-heading-row {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: flex-start;
  }

  .panel-heading-row p {
    max-width: 54ch;
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .usage-summary,
  .chat-usage {
    flex: 0 0 auto;
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 700;
  }

  .role-text-label {
    display: block;
    margin-top: 14px;
  }

  .role-text-label textarea,
  .chat-form textarea,
  .dialog-fields input {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 9px;
    outline: none;
    background: rgba(255, 255, 255, 0.018);
    color: var(--text);
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }

  .role-text-label textarea {
    height: 84px;
    min-height: 0;
    resize: vertical;
    padding: 13px 14px;
    font-size: 0.9rem;
    line-height: 1.42;
  }

  .role-text-label textarea:focus,
  .chat-form textarea:focus,
  .dialog-fields input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(76, 141, 255, 0.13);
  }

  .role-entry-footer,
  .chat-form-footer {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: center;
    margin-top: 7px;
  }

  .character-count,
  .chat-form-footer span {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .role-actions {
    display: flex;
    gap: 9px;
  }

  .compact-button {
    min-height: 40px;
    padding: 0 15px;
    border-radius: 8px;
  }

  .portal-status,
  .chat-status {
    min-height: 1.2em;
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .portal-status[data-state="error"],
  .chat-status[data-state="error"] {
    color: #ffab9c;
  }

  .portal-status[data-state="loading"],
  .chat-status[data-state="loading"] {
    color: var(--accent-2);
  }

  .role-summary-panel > p {
    max-width: 78ch;
    margin: 14px 0 0;
    color: var(--muted-2);
  }

  .role-summary-panel > .summary-role-title {
    margin-top: 18px;
    color: var(--text);
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    font-weight: 750;
    letter-spacing: -0.025em;
  }

  .role-summary-panel > .summary-role-title + p {
    margin-top: 6px;
  }

  .theme-list {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 16px;
  }

  .theme-list span,
  .source-chip {
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    color: var(--muted-2);
    font-size: 0.72rem;
  }

  .theme-list span {
    padding: 6px 9px;
  }

  .coverage-heading {
    margin-bottom: 16px;
  }

  .coverage-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .coverage-grid article {
    padding: 18px;
    border: 1px solid var(--line-soft);
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.018);
  }

  .coverage-grid span {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 750;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .coverage-grid strong {
    display: block;
    margin: 6px 0;
    color: var(--text);
    font-size: clamp(2.3rem, 4vw, 3.7rem);
    line-height: 1;
  }

  .coverage-grid p {
    margin: 0;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .reason-list,
  .evidence-list {
    display: grid;
    gap: 11px;
    margin-top: 16px;
  }

  .reason-list {
    grid-template-columns: 1fr;
  }

  .evidence-list-label {
    display: none;
  }

  .evidence-list {
    grid-template-columns: minmax(0, 1fr);
  }

  .evidence-card {
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(7, 18, 31, 0.86);
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.03);
  }

  .reason-card {
    position: relative;
    padding: 0 0 0 20px;
    border: 0;
    background: transparent;
  }

  .reason-card::before {
    position: absolute;
    top: 0.55em;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent-2);
    content: "";
  }

  .reason-card .card-kicker {
    display: block;
  }

  .reason-card h3,
  .evidence-card h3 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .card-kicker,
  .card-support-label {
    display: block;
    margin-bottom: 7px;
    color: var(--accent-2);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-support-label {
    margin-top: 13px;
    margin-bottom: 0;
    color: var(--muted);
  }

  .reason-card p,
  .evidence-card p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.52;
  }

  .source-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 12px;
  }

  .source-chip {
    padding: 5px 8px;
    cursor: pointer;
  }

  .evidence-label {
    cursor: default;
  }

  .source-chip:hover,
  .source-chip:focus-visible {
    border-color: var(--accent);
    color: var(--text);
  }

  .evidence-label:hover,
  .evidence-label:focus-visible {
    border-color: var(--line);
    color: var(--muted-2);
  }

  .evidence-match-label {
    white-space: nowrap;
  }

  .evidence-period {
    flex: 0 0 auto;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .evidence-filters {
    display: flex;
    gap: 5px;
    padding: 3px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
  }

  .evidence-filters button {
    padding: 6px 9px;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--muted);
    font-size: 0.72rem;
    cursor: pointer;
  }

  .evidence-filters button[data-active="true"] {
    background: rgba(76, 141, 255, 0.16);
    color: var(--text);
  }

  .evidence-card-header {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
  }

  .evidence-type {
    color: var(--accent-2);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .evidence-summary {
    margin: 6px 0 0;
    color: var(--muted-2);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .evidence-card small {
    color: var(--muted);
    font-size: 0.7rem;
  }

  .portfolio-chat {
    position: fixed;
    z-index: 20;
    right: 24px;
    bottom: 24px;
    display: flex;
    flex-direction: column;
    width: min(410px, calc(100vw - 32px));
    height: min(560px, calc(100vh - 32px));
    min-height: 0;
    max-height: none;
    overflow: hidden;
    padding: 18px;
    border: 1px solid rgba(145, 200, 229, 0.18);
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(10, 21, 40, 0.97), rgba(8, 18, 33, 0.94));
    box-shadow: 0 22px 70px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(145, 200, 229, 0.08);
    backdrop-filter: blur(18px);
  }

  .portfolio-chat[data-minimized="true"] {
    width: max-content;
    max-width: calc(100vw - 48px);
    height: auto;
    padding: 10px 12px;
    border-radius: 999px;
  }

  .portfolio-chat[data-minimized="true"] .chat-body {
    display: none;
  }

  .portfolio-chat[data-minimized="true"] .chat-header {
    align-items: center;
  }

  .portfolio-chat[data-minimized="true"] .chat-brand .section-label,
  .portfolio-chat[data-minimized="true"] .chat-usage {
    display: none;
  }

  .portfolio-chat[data-minimized="true"] .chat-avatar {
    width: 32px;
    height: 32px;
    border-radius: 999px;
  }

  .portfolio-chat[data-minimized="true"] .chat-brand h2 {
    font-size: 0.92rem;
    white-space: nowrap;
  }

  .chat-brand,
  .chat-header-actions {
    display: flex;
    align-items: center;
  }

  .chat-brand {
    flex: 1 1 auto;
