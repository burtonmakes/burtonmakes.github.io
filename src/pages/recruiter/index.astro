      padding: 14px;
      border-radius: 20px;
    }

    .portfolio-chat[data-minimized="true"] {
      width: 100%;
      max-width: none;
      height: auto;
    }

    .chat-brand {
      padding-right: 36px;
    }

    .chat-brand h2 {
      white-space: normal;
      font-size: 1.05rem;
    }

    .chat-avatar {
