  }

  .panel-heading h2,
  .match-list-card h2 {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.25rem, 1.8vw, 1.7rem);
    line-height: 1.1;
  }

  .panel-heading p {
    margin: 0;
    color: var(--muted-2);
    font-size: 0.84rem;
    line-height: 1.42;
  }

  .context-fields,
  .role-text-field,
  .manual-skill-row label {
    display: grid;
    gap: 8px;
  }

  .context-fields {
    gap: 10px;
  }

  .context-fields label {
    display: grid;
    gap: 7px;
  }

  .context-fields label span {
    color: var(--accent-2);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .context-fields input,
  .manual-skill-row input,
  .matcher-panel textarea {
