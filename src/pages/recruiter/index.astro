---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
---

<BaseLayout
  title="Recruiter Context"
  description="Optional recruiter context before using Alex Burton's candidate matching tool."
>
  <section class="section recruiter-gateway">
    <div class="gateway-card reveal">
      <p class="eyebrow">Recruiter fast path</p>
      <h1>Optional context improves candidate matching.</h1>
      <p class="gateway-copy">
        Add your name, company, and the role you are looking to fill so the matcher can compare the
        job text with better context. You can skip this step, but the analysis may be less accurate.
      </p>
      <div class="gateway-visual" aria-hidden="true">
        <div class="gateway-node">
          <span>Recruiter</span>
          <small>role needs</small>
        </div>
        <div class="gateway-match">
          <span>Common match</span>
          <i></i>
          <small>role needs + portfolio evidence</small>
        </div>
        <div class="gateway-node">
          <span>Alex Burton</span>
          <small>project evidence</small>
        </div>
      </div>

      <form class="gateway-form" data-recruiter-gateway>
        <label for="gateway-name">
          <span>Your name</span>
          <input id="gateway-name" data-gateway-name type="text" autocomplete="name" placeholder="Optional" />
        </label>

        <label for="gateway-company">
          <span>Company</span>
          <input id="gateway-company" data-gateway-company type="text" autocomplete="organization" placeholder="Optional" />
        </label>

        <label for="gateway-role">
          <span>Role you are filling</span>
          <input id="gateway-role" data-gateway-role type="text" placeholder="Sensor hardware engineer" />
        </label>

        <p class="gateway-note">
          Context is saved in your browser for this visit. Pasted role text is used only to compare the role
          against Alex's portfolio. Treat the match score as a quick screening aid, not a final hiring decision.
        </p>

        <div class="gateway-actions">
          <button class="button button-primary" type="submit">Continue to matcher</button>
          <button class="button button-secondary" type="button" data-gateway-skip>Skip context</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .recruiter-gateway {
    display: grid;
    min-height: calc(100vh - 96px);
    place-items: center;
    padding-top: clamp(4.5rem, 7vh, 5.8rem);
    padding-bottom: clamp(1.8rem, 4vh, 3rem);
  }

  .gateway-card {
    width: min(860px, 100%);
    padding: clamp(20px, 3vw, 34px);
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(1, 5, 10, 0.98);
    box-shadow: var(--shadow-soft);
  }

  .gateway-card h1 {
    max-width: 15ch;
    margin-bottom: 12px;
    font-size: clamp(2rem, 3.8vw, 3.55rem);
    line-height: 1;
  }

  .gateway-copy {
    max-width: 68ch;
    margin-bottom: 0;
    color: var(--muted-2);
    font-size: 0.92rem;
    line-height: 1.4;
  }

  .gateway-visual {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(210px, 1fr) minmax(0, 0.8fr);
    align-items: stretch;
    gap: 10px;
    margin: 16px 0 18px;
  }

  .gateway-node,
  .gateway-match {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.018);
  }

  .gateway-node {
    display: grid;
    min-height: 72px;
    place-items: center;
    padding: 12px;
    text-align: center;
  }

  .gateway-node span {
    color: var(--text);
    font-weight: 850;
  }

  .gateway-node small,
  .gateway-match small {
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .gateway-match {
    display: grid;
    min-height: 82px;
    align-content: center;
    gap: 7px;
    padding: 12px;
    text-align: center;
  }

  .gateway-match span {
    color: var(--accent-2);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .gateway-match i {
    display: block;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--graph-amber), var(--graph-coral));
  }

  .gateway-form {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .gateway-form label {
    display: grid;
    gap: 7px;
  }

  .gateway-form label span {
    color: var(--accent-2);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .gateway-form input {
    min-height: 42px;
    width: 100%;
    padding: 0 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.018);
    color: var(--text);
    outline: none;
  }

  .gateway-form input:focus {
    border-color: color-mix(in srgb, var(--accent-2), white 8%);
    box-shadow: 0 0 0 4px rgba(111, 211, 255, 0.08);
  }

  .gateway-note {
    grid-column: 1 / -1;
    margin: 4px 0 0;
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.36;
  }

  .gateway-actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .gateway-actions .button {
    min-height: 42px;
    border-radius: 8px;
  }

  @media (max-width: 720px) {
    .recruiter-gateway {
      place-items: start center;
    }

    .gateway-card h1 {
      max-width: none;
    }

    .gateway-visual,
    .gateway-form {
      grid-template-columns: 1fr;
    }

    .gateway-visual {
      margin: 14px 0;
    }

    .gateway-actions {
      flex-direction: column;
    }
  }
</style>

<script>
  const sessionStorageKey = "burton-recruiter-match-session-v1";

  const getStoredSession = () => {
    try {
      return JSON.parse(window.localStorage.getItem(sessionStorageKey) || "{}");
    } catch {
      return {};
    }
  };

  const saveContext = (context) => {
    const existing = getStoredSession();
    window.localStorage.setItem(sessionStorageKey, JSON.stringify({
      ...existing,
      recruiterContext: context,
    }));
  };

  const goToMatcher = () => {
    window.location.href = "/recruiter/match/";
  };

  const setupGateway = () => {
    const form = document.querySelector("[data-recruiter-gateway]");
    if (!form || form.dataset.ready === "true") return;
    form.dataset.ready = "true";

    const nameInput = form.querySelector("[data-gateway-name]");
    const companyInput = form.querySelector("[data-gateway-company]");
    const roleInput = form.querySelector("[data-gateway-role]");
    const skipButton = form.querySelector("[data-gateway-skip]");
    const saved = getStoredSession().recruiterContext || {};

    nameInput.value = saved.name || "";
    companyInput.value = saved.company || "";
    roleInput.value = saved.hiringFor || "";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      saveContext({
        name: nameInput.value.trim(),
        company: companyInput.value.trim(),
        hiringFor: roleInput.value.trim(),
        skipped: false,
      });
      goToMatcher();
    });

    skipButton.addEventListener("click", () => {
      saveContext({
        name: "",
        company: "",
        hiringFor: "",
        skipped: true,
      });
      goToMatcher();
    });
  };

  document.addEventListener("astro:page-load", setupGateway);
  setupGateway();
</script>
