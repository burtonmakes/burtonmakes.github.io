  }

  .manual-skill-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    align-items: end;
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .action-row .button,
  .manual-skill-row .button {
    min-height: 40px;
    border-radius: 9px;
  }

  .button.subtle {
    opacity: 0.82;
  }

  .match-status {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 40px;
    margin: 0;
    padding: 0 11px;
    border: 1px solid var(--line);
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.014);
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.2;
  }

  .match-status::before {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: currentColor;
    content: "";
  }

  .match-status[data-state="ready"] {
    color: var(--accent-2);
  }

  .match-status[data-state="loading"] {
    color: var(--cta-1);
  }

  .match-status[data-state="error"] {
    color: #ffc4b4;
  }

  .detected-strip {
    display: grid;
    gap: 10px;
  }

  .detected-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  .detected-heading strong {
    color: var(--muted);
    font-size: 0.8rem;
  }

  .detected-heading-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .clear-tags-button {
    min-height: 28px;
    padding: 0 10px;
    border: 1px solid var(--line);
    border-radius: 7px;
    background: transparent;
    color: var(--muted-2);
