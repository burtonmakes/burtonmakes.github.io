  }

  .context-skip[data-skipped="true"] {
    background: rgba(232, 111, 78, 0.12);
  }

  .context-quality,
  .data-path-card,
  .detected-strip {
    padding: 13px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.014);
  }

  .context-quality[data-state="complete"] {
    border-color: rgba(111, 211, 255, 0.28);
