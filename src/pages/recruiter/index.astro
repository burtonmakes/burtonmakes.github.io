    grid-template-columns: minmax(0, 0.92fr) minmax(360px, 0.8fr);
    gap: clamp(18px, 3vw, 30px);
    align-items: end;
  }

  .recruiter-hero-copy h1 {
    max-width: 15ch;
    margin-bottom: 12px;
    font-size: clamp(2.35rem, 4.8vw, 5.1rem);
