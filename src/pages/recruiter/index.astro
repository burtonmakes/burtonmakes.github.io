---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { capabilityTaxonomy } from "../../data/capability-map";
import { projects, skillsDemonstrated, workHistory } from "../../data/site";
import "../../styles/global.css";

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const sourceTagsByKey = new Map<string, string[]>();

workHistory.forEach((role) => {
  sourceTagsByKey.set(`work:${slugify(role.title)}:${slugify(role.company)}`, [...role.skills]);
});

projects.forEach((project) => {
  sourceTagsByKey.set(`project:${project.slug}`, [
    ...project.skills,
    ...project.labels,
    ...project.stack,
    project.section,
    project.type,
  ]);
});

const matcherData = capabilityTaxonomy.flatMap((group) =>
  group.nodes.map((node) => ({
    group: group.label,
    id: node.id,
    label: node.label,
    summary: node.summary,
    yearsActive: node.yearsActive,
    yearsScore: node.yearsScore,
    skillTags: node.skillTags,
    evidence: node.evidence.map((item) => ({
      key: item.key,
      kind: item.kind,
      title: item.title,
      href: item.href,
      period: item.period,
      summary: item.summary,
      note: item.note,
      highlights: item.highlights.slice(0, 2),
      tags: sourceTagsByKey.get(item.key) ?? [],
    })),
  }))
);

const suggestedSkills = [...skillsDemonstrated].slice(0, 12);
const matcherJson = JSON.stringify(matcherData);
---

<BaseLayout
  title="Recruiter Match"
  description="Quick recruiter skill matcher for Alex Burton's biomedical systems engineering portfolio."
>
  <section class="section recruiter-match-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Recruiter fast path</p>
      <h1>Paste the role keywords. See where the portfolio matches.</h1>
      <p class="hero-text">
        This is a quick first-pass screen for comparing a job description, skill list, or role keywords
        against the skills and labels already mapped through the portfolio.
      </p>
    </div>

    <div class="recruiter-match-shell reveal" data-recruiter-matcher>
      <div class="match-input-panel">
        <label for="recruiter-keywords">
          <span>Keywords or phrases</span>
          <textarea
            id="recruiter-keywords"
            data-match-input
            rows="8"
            placeholder="Example: wearable sensing, medical devices, validation, BLE, clinical workflow, Python"
          ></textarea>
        </label>

        <div class="match-actions">
          <button class="button button-primary" type="button" data-match-run>Match skills</button>
          <button class="button button-tertiary" type="button" data-match-clear>Clear</button>
        </div>

        <div class="suggested-skill-row" aria-label="Suggested skills">
          {suggestedSkills.map((skill) => (
            <button type="button" data-suggested-skill={skill}>{skill}</button>
          ))}
        </div>
      </div>

      <div class="match-results-panel" aria-live="polite">
        <div class="match-score-card">
          <span>Candidate match</span>
          <strong data-match-score>0%</strong>
          <p data-match-summary>Enter role keywords to compare them against mapped portfolio evidence.</p>
        </div>

        <div class="match-breakdown-grid">
          <section class="match-list-card">
            <h2>Matched</h2>
            <ul data-match-list>
              <li>Waiting for keywords.</li>
            </ul>
          </section>

          <section class="match-list-card">
            <h2>Not found yet</h2>
            <ul data-gap-list>
              <li>Nothing checked yet.</li>
            </ul>
          </section>
        </div>
      </div>
    </div>
  </section>

  <section class="section match-evidence-section">
    <div class="section-heading reveal">
      <p class="eyebrow">Evidence</p>
      <h2>Relevant work and projects appear here after matching.</h2>
    </div>

    <div class="match-evidence-grid reveal" data-evidence-list>
      <article class="evidence-empty">
        <strong>No keywords matched yet.</strong>
        <p>Paste requirements above to pull forward the closest capabilities, projects, and work history.</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .recruiter-match-hero {
    display: grid;
    gap: clamp(32px, 5vw, 56px);
    align-content: center;
  }

  .recruiter-match-hero .hero-copy {
    max-width: 1040px;
  }

  .recruiter-match-shell {
    display: grid;
    grid-template-columns: minmax(320px, 0.82fr) minmax(0, 1fr);
    gap: 18px;
  }

  .match-input-panel,
  .match-results-panel,
  .match-list-card,
  .match-score-card,
  .evidence-empty,
  .match-evidence-card {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--panel);
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.05), var(--shadow-soft);
  }

  .match-input-panel {
    display: grid;
    gap: 18px;
    padding: clamp(20px, 2.4vw, 28px);
  }

  .match-input-panel label {
    display: grid;
    gap: 10px;
  }

  .match-input-panel label span,
  .match-score-card span,
  .match-evidence-card span {
    color: var(--accent-2);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .match-input-panel textarea {
    width: 100%;
    min-height: 210px;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.018);
    color: var(--text);
    resize: vertical;
    outline: none;
  }

  .match-input-panel textarea:focus {
    border-color: color-mix(in srgb, var(--accent-2), white 8%);
    box-shadow: 0 0 0 4px rgba(111, 211, 255, 0.08);
  }

  .match-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .match-actions .button {
    border: 1px solid var(--line);
    cursor: pointer;
  }

  .suggested-skill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .suggested-skill-row button {
    min-height: 34px;
    padding: 0 11px;
    border: 1px solid rgba(232, 111, 78, 0.32);
    border-radius: 999px;
    background: rgba(232, 111, 78, 0.06);
    color: #f4ded8;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
  }

  .match-results-panel {
    display: grid;
    gap: 14px;
    padding: clamp(18px, 2vw, 22px);
  }

  .match-score-card {
    padding: clamp(20px, 2.4vw, 30px);
  }

  .match-score-card strong {
    display: block;
    margin: 12px 0 10px;
    color: var(--text);
    font-size: clamp(4rem, 9vw, 8rem);
    line-height: 0.88;
    letter-spacing: 0;
  }

  .match-score-card p {
    max-width: 58ch;
    margin: 0;
  }

  .match-breakdown-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .match-list-card {
    padding: 20px;
  }

  .match-list-card h2 {
    margin-bottom: 14px;
    font-size: clamp(1.18rem, 1.5vw, 1.45rem);
  }

  .match-list-card ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .match-list-card li {
    color: var(--muted-2);
    font-size: 0.94rem;
    line-height: 1.42;
  }

  .match-list-card li + li {
    margin-top: 10px;
  }

  .match-evidence-section {
    align-content: start !important;
  }

  .match-evidence-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .evidence-empty,
  .match-evidence-card {
    padding: 22px;
  }

  .evidence-empty {
    grid-column: 1 / -1;
  }

  .evidence-empty strong,
  .match-evidence-card strong {
    display: block;
    color: var(--text);
    font-size: 1.08rem;
    line-height: 1.25;
  }

  .match-evidence-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 280px;
  }

  .match-evidence-card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.48;
  }

  .match-evidence-card ul {
    margin: 0;
    padding-left: 18px;
    color: var(--muted-2);
    font-size: 0.9rem;
  }

  .match-evidence-card .tag-row {
    margin-top: auto;
    padding-top: 4px;
  }

  @media (max-width: 1100px) {
    .recruiter-match-shell,
    .match-evidence-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .match-breakdown-grid {
      grid-template-columns: 1fr;
    }

    .match-actions {
      flex-direction: column;
    }
  }
</style>

<script define:vars={{ matcherJson }}>
  const matcherData = JSON.parse(matcherJson);

  const normalize = (value) =>
    String(value)
      .toLowerCase()
      .replace(/&/g, " and ")
      .replace(/[^a-z0-9+#.]+/g, " ")
      .replace(/\s+/g, " ")
      .trim();

  const tokenize = (value) => normalize(value).split(" ").filter((token) => token.length > 1);

  const parseKeywords = (value) => {
    const direct = String(value)
      .split(/[,;\n|]+/)
      .map((item) => item.trim())
      .filter(Boolean);

    if (direct.length > 1) return [...new Set(direct)];

    return [...new Set(String(value).split(/\s{2,}|[,;\n|]+/).map((item) => item.trim()).filter(Boolean))];
  };

  const diceCoefficient = (left, right) => {
    const a = normalize(left);
    const b = normalize(right);
    if (!a || !b) return 0;
    if (a === b) return 1;
    if (a.length < 2 || b.length < 2) return a === b ? 1 : 0;

    const pairs = (value) => {
      const output = [];
      for (let index = 0; index < value.length - 1; index += 1) {
        output.push(value.slice(index, index + 2));
      }
      return output;
    };

    const leftPairs = pairs(a);
    const rightPairs = pairs(b);
    const used = new Array(rightPairs.length).fill(false);
    let matches = 0;

    leftPairs.forEach((pair) => {
      const matchIndex = rightPairs.findIndex((candidate, index) => !used[index] && candidate === pair);
      if (matchIndex >= 0) {
        used[matchIndex] = true;
        matches += 1;
      }
    });

    return (2 * matches) / (leftPairs.length + rightPairs.length);
  };

  const scorePhrase = (keyword, candidate) => {
    const key = normalize(keyword);
    const target = normalize(candidate);
    if (!key || !target) return 0;
    if (key === target) return 1;
    if (target.includes(key) || key.includes(target)) return 0.9;

    const keyTokens = tokenize(key);
    const targetTokens = new Set(tokenize(target));
    const tokenOverlap = keyTokens.length
      ? keyTokens.filter((token) => targetTokens.has(token)).length / keyTokens.length
      : 0;

    return Math.max(diceCoefficient(key, target), tokenOverlap * 0.86);
  };

  const bestNodeMatch = (keyword, node) => {
    const candidates = [
      node.label,
      node.group,
      node.summary,
      ...node.skillTags,
      ...node.evidence.flatMap((item) => [item.title, item.summary, item.note, ...item.highlights, ...item.tags]),
    ];

    const best = candidates.reduce(
      (current, candidate) => {
        const score = scorePhrase(keyword, candidate);
        return score > current.score ? { score, label: candidate } : current;
      },
      { score: 0, label: "" },
    );

    return best;
  };

  const getGrade = (score) => {
    if (score >= 82) return "Strong initial fit";
    if (score >= 62) return "Good partial fit";
    if (score >= 38) return "Some overlap";
    return "Limited mapped overlap";
  };

  const renderList = (element, items, emptyText) => {
    element.innerHTML = "";
    const content = items.length ? items : [emptyText];
    content.forEach((item) => {
      const li = document.createElement("li");
      li.textContent = item;
      element.append(li);
    });
  };

  const renderEvidence = (element, matches) => {
    element.innerHTML = "";

    const evidenceMap = new Map();
    matches.forEach((match) => {
      match.node.evidence.forEach((item) => {
        const current = evidenceMap.get(item.key);
        const nextScore = Math.max(match.score, current?.score || 0);
        evidenceMap.set(item.key, {
          ...item,
          score: nextScore,
          capabilities: [...new Set([...(current?.capabilities || []), match.node.label])],
          keywords: [...new Set([...(current?.keywords || []), match.keyword])],
          tags: [...new Set([...(current?.tags || []), ...item.tags])],
        });
      });
    });

    const evidence = [...evidenceMap.values()].sort((a, b) => b.score - a.score).slice(0, 6);

    if (evidence.length === 0) {
      const empty = document.createElement("article");
      empty.className = "evidence-empty";
      empty.innerHTML = "<strong>No strong matches yet.</strong><p>Try a job-description skill list, separated by commas or new lines.</p>";
      element.append(empty);
      return;
    }

    evidence.forEach((item) => {
      const card = document.createElement("article");
      card.className = "match-evidence-card";

      const highlights = item.highlights.map((highlight) => `<li>${highlight}</li>`).join("");
      const tags = item.capabilities
        .concat(item.tags)
        .filter((tag, index, list) => list.indexOf(tag) === index)
        .slice(0, 4)
        .map((tag) => `<span class="tag">${tag}</span>`)
        .join("");

      card.innerHTML = `
        <span>${item.kind} · ${Math.round(item.score * 100)}% match</span>
        <strong>${item.title}</strong>
        <p>${item.summary}</p>
        <ul>${highlights}</ul>
        <div class="tag-row">${tags}</div>
        <a class="text-link" href="${item.href}">View evidence</a>
      `;
      element.append(card);
    });
  };

  const setupRecruiterMatcher = () => {
    document.querySelectorAll("[data-recruiter-matcher]").forEach((matcher) => {
      if (matcher.dataset.ready === "true") return;
      matcher.dataset.ready = "true";

      const input = matcher.querySelector("[data-match-input]");
      const runButton = matcher.querySelector("[data-match-run]");
      const clearButton = matcher.querySelector("[data-match-clear]");
      const scoreElement = matcher.querySelector("[data-match-score]");
      const summaryElement = matcher.querySelector("[data-match-summary]");
      const matchList = matcher.querySelector("[data-match-list]");
      const gapList = matcher.querySelector("[data-gap-list]");
      const evidenceList = document.querySelector("[data-evidence-list]");

      const runMatch = () => {
        const keywords = parseKeywords(input.value);
        if (keywords.length === 0) {
          scoreElement.textContent = "0%";
          summaryElement.textContent = "Enter role keywords to compare them against mapped portfolio evidence.";
          renderList(matchList, [], "Waiting for keywords.");
          renderList(gapList, [], "Nothing checked yet.");
          renderEvidence(evidenceList, []);
          return;
        }

        const keywordResults = keywords.map((keyword) => {
          const matches = matcherData
            .map((node) => ({ keyword, node, ...bestNodeMatch(keyword, node) }))
            .filter((match) => match.score >= 0.46)
            .sort((a, b) => b.score - a.score);

          return {
            keyword,
            best: matches[0],
            matches,
          };
        });

        const matched = keywordResults.filter((item) => item.best);
        const gaps = keywordResults.filter((item) => !item.best);
        const weightedScore = Math.round(
          (keywordResults.reduce((total, item) => total + Math.min(1, item.best?.score || 0), 0) / keywords.length) * 100,
        );

        const allMatches = matched.flatMap((item) => item.matches.slice(0, 2));

        scoreElement.textContent = `${weightedScore}%`;
        summaryElement.textContent = `${getGrade(weightedScore)} based on ${matched.length} of ${keywords.length} entered keyword${keywords.length === 1 ? "" : "s"} mapping to portfolio evidence.`;

        renderList(
          matchList,
          matched.map((item) => `${item.keyword} -> ${item.best.node.label} (${Math.round(item.best.score * 100)}%)`),
          "No mapped matches.",
        );
        renderList(
          gapList,
          gaps.map((item) => item.keyword),
          "No obvious gaps from the entered list.",
        );
        renderEvidence(evidenceList, allMatches);
      };

      runButton.addEventListener("click", runMatch);
      input.addEventListener("input", () => {
        if (input.value.trim().length > 2) runMatch();
      });
      clearButton.addEventListener("click", () => {
        input.value = "";
        runMatch();
        input.focus();
      });

      matcher.querySelectorAll("[data-suggested-skill]").forEach((button) => {
        button.addEventListener("click", () => {
          const current = input.value.trim();
          input.value = current ? `${current}, ${button.dataset.suggestedSkill}` : button.dataset.suggestedSkill;
          runMatch();
        });
      });
    });
  };

  document.addEventListener("astro:page-load", setupRecruiterMatcher);
  setupRecruiterMatcher();
</script>
