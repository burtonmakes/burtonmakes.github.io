  }

  .context-skip {
    justify-self: start;
    min-height: 34px;
    padding: 0 11px;
    border: 1px solid rgba(232, 111, 78, 0.34);
    border-radius: 9px;
    background: rgba(232, 111, 78, 0.05);
    color: #ffb39f;
