    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 7px;
    min-height: 54px;
    max-height: 156px;
    overflow-y: auto;
  }

  .detected-list p {
    margin: 0;
    color: var(--muted);
    font-size: 0.84rem;
  }

  :global(.skill-chip) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    max-width: 100%;
    min-height: 25px;
    padding: 3px 7px 3px 10px;
    border: 1px solid rgba(111, 211, 255, 0.26);
    border-radius: 999px;
    background: rgba(111, 211, 255, 0.06);
    color: #e9f7ff;
