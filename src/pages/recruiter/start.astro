---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
---

<BaseLayout
  title="Recruiter Review Setup"
  description="Add recruiter and role context before reviewing Alex Burton's portfolio."
>
  <section class="section recruiter-entry">
    <div class="entry-shell">
      <div class="entry-intro">
        <p class="eyebrow">Recruiter portfolio review</p>
        <h1>Start with the role you are hiring for.</h1>
        <p>
          Add your recruiter context first. On the next page, paste the full
          job description, review the strongest documented evidence, and ask
          follow-up questions through the portfolio assistant.
        </p>
      </div>

      <form
        class="entry-form"
        data-recruiter-entry-form
      >
        <div class="entry-fields">
          <label>
            <span>Your name</span>
            <input
              name="recruiter-name"
              data-entry-name
              type="text"
              maxlength="120"
              autocomplete="name"
              placeholder="Jordan Lee"
            />
          </label>

          <label>
            <span>Company or team</span>
            <input
              name="company"
              data-entry-company
              type="text"
              maxlength="160"
              autocomplete="organization"
              placeholder="Company or team"
            />
          </label>

          <label>
            <span>Role being filled</span>
            <input
              name="role"
              data-entry-role
              type="text"
              maxlength="180"
              autocomplete="off"
              placeholder="Senior sensor hardware engineer"
            />
          </label>
        </div>

        <div class="entry-note">
          <strong>How the review works</strong>
          <p>
            The role text is sent to the configured Cloudflare recruiter
            assistant only when you choose Analyze role. Public portfolio
            evidence is retrieved and cited in the result. Daily usage is
            limited to protect the site's free AI allowance.
          </p>
        </div>

        <div class="entry-actions">
          <a class="button button-secondary" href="/" data-entry-back>
            Go back
          </a>
          <button class="button button-primary" type="submit">
            Continue to role review
          </button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const storageKey = "burton-recruiter-onepage-session-v3";
    const legacyStorageKey = "burton-recruiter-onepage-session-v2";
    const form = document.querySelector("[data-recruiter-entry-form]");
    if (!form) return;

    const readState = () => {
      try {
        const current = localStorage.getItem(storageKey);
        if (current) return JSON.parse(current);

        const legacy = localStorage.getItem(legacyStorageKey);
        if (legacy) {
          const parsed = JSON.parse(legacy);
          return {
            recruiterContext: parsed.recruiterContext || {},
            jobText: parsed.jobText || "",
          };
        }
      } catch {}
      return {};
    };

    const state = readState();
    const context = state.recruiterContext || {};
    const nameInput = form.querySelector("[data-entry-name]");
    const companyInput = form.querySelector("[data-entry-company]");
    const roleInput = form.querySelector("[data-entry-role]");

    nameInput.value = context.name || "";
    companyInput.value = context.company || "";
    roleInput.value = context.hiringFor || "";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      try {
        localStorage.setItem(
          storageKey,
          JSON.stringify({
            ...state,
            recruiterContext: {
              name: nameInput.value.trim(),
              company: companyInput.value.trim(),
              hiringFor: roleInput.value.trim(),
              skipped: false,
            },
          }),
        );
      } catch {}
      window.location.assign("/recruiter/");
    });
  })();
</script>

<style>
  :global(.recruiter-entry) {
    min-height: calc(100svh - 80px);
    align-content: center;
    padding-top: clamp(7rem, 12vh, 10rem);
    padding-bottom: clamp(4rem, 8vh, 7rem);
  }

  .entry-shell {
    width: min(1120px, 100%);
    margin: 0 auto;
    padding: clamp(22px, 3vw, 38px);
    border: 1px solid var(--line);
    border-radius: 14px;
    background: color-mix(in srgb, var(--bg-2), transparent 18%);
    box-shadow: var(--shadow-soft);
  }

  .entry-intro {
    max-width: 820px;
    margin-bottom: 28px;
  }

  .entry-intro h1 {
    max-width: 16ch;
    margin: 8px 0 14px;
    font-size: clamp(2.5rem, 4.8vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .entry-intro p {
    max-width: 70ch;
    margin: 0;
    color: var(--muted-2);
  }

  .entry-form {
    display: grid;
    gap: 18px;
  }

  .entry-fields {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .entry-fields label {
    display: grid;
    gap: 7px;
  }

  .entry-fields span {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .entry-fields input {
    width: 100%;
    min-height: 48px;
    padding: 0 13px;
    border: 1px solid var(--line);
    border-radius: 9px;
    outline: none;
    background: rgba(255, 255, 255, 0.018);
    color: var(--text);
  }

  .entry-fields input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(76, 141, 255, 0.13);
  }

  .entry-note {
    padding: 14px 15px;
    border: 1px solid var(--line-soft);
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.015);
  }

  .entry-note strong {
    display: block;
    margin-bottom: 4px;
  }

  .entry-note p {
    margin: 0;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .entry-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  .entry-actions .button {
    min-height: 46px;
    justify-content: center;
  }

  @media (max-width: 820px) {
    .entry-fields {
      grid-template-columns: 1fr;
    }

    .entry-intro h1 {
      font-size: clamp(2rem, 9vw, 3rem);
    }

    .entry-note {
      padding: 12px 13px;
    }

    .entry-note p {
      font-size: 0.76rem;
      line-height: 1.45;
    }

    .entry-actions {
      flex-direction: column-reverse;
    }

    .entry-actions .button {
      width: 100%;
    }
  }
</style>
