---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
---

<BaseLayout
  title="Recruiter Match Setup"
  description="Add optional recruiter context before opening the role comparison tool."
>
  <section class="section recruiter-entry">
    <div class="recruiter-entry-card">
      <p class="eyebrow">Recruiter match</p>
      <h1>Compare a role with Alex Burton’s experience.</h1>
      <p class="entry-copy">Add the recruiter and role context first, then continue to the separate comparison page.</p>

      <form class="recruiter-entry-form" action="/recruiter/" method="get" data-recruiter-entry-form>
        <input type="hidden" name="match" value="1" />

        <label>
          <span>Your name</span>
          <input name="recruiter-name" data-entry-name type="text" autocomplete="name" placeholder="Jordan Lee" required />
        </label>

        <label>
          <span>Company</span>
          <input name="company" data-entry-company type="text" autocomplete="organization" placeholder="Company or team" required />
        </label>

        <label>
          <span>Role being filled</span>
          <input name="role" data-entry-role type="text" autocomplete="off" placeholder="Senior sensor hardware engineer" required />
        </label>

        <div class="recruiter-entry-note">
          <strong>Your information is not used to train AI models.</strong>
          <p>Fuzzy Compare stays in your browser. AI Compare sends the entered text to Cloudflare Workers AI only for this comparison.</p>
        </div>

        <div class="recruiter-entry-actions">
          <button class="button button-primary" type="submit">Continue</button>
          <a class="button button-secondary" href="/recruiter/?match=1" data-entry-skip>Skip</a>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const key = "burton-recruiter-onepage-session-v2";
    const form = document.querySelector("[data-recruiter-entry-form]");
    const skip = document.querySelector("[data-entry-skip]");
    if (!form) return;

    const save = (context) => {
      try {
        const current = JSON.parse(localStorage.getItem(key) || "{}");
        localStorage.setItem(key, JSON.stringify({ ...current, recruiterContext: context }));
      } catch {}
    };

    form.addEventListener("submit", () => {
      save({
        name: form.querySelector("[data-entry-name]")?.value.trim() || "",
        company: form.querySelector("[data-entry-company]")?.value.trim() || "",
        hiringFor: form.querySelector("[data-entry-role]")?.value.trim() || "",
        skipped: false,
      });
    });

    skip?.addEventListener("click", () => {
      save({ name: "", company: "", hiringFor: "", skipped: true });
    });
  })();
</script>

<style>
  :global(.recruiter-entry) {
    min-height: calc(100svh - 110px);
    align-content: center;
    padding-top: clamp(7rem, 12vh, 10rem);
    padding-bottom: clamp(3rem, 8vh, 6rem);
  }

  .recruiter-entry-card {
    width: min(1100px, 100%);
    margin: 0 auto;
    padding: clamp(24px, 3vw, 38px);
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    box-shadow: var(--shadow-soft);
  }

  .recruiter-entry-card h1 {
    max-width: 18ch;
    margin: 8px 0 10px;
    font-size: clamp(2.2rem, 4.3vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .entry-copy {
    max-width: 70ch;
    margin: 0 0 26px;
    color: var(--muted-2);
  }

  .recruiter-entry-form {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .recruiter-entry-form label {
    display: grid;
    gap: 7px;
  }

  .recruiter-entry-form label span {
    color: var(--accent-2);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .recruiter-entry-form input {
    min-height: 48px;
    padding: 0 14px;
    border: 1px solid var(--line);
    border-radius: 9px;
    background: rgba(255,255,255,.02);
    color: var(--text);
    font: inherit;
  }

  .recruiter-entry-note {
    grid-column: 1 / -1;
    padding: 12px 14px;
    border: 1px solid var(--line-soft);
    border-radius: 9px;
    background: rgba(255,255,255,.018);
  }

  .recruiter-entry-note strong { display: block; margin-bottom: 3px; }
  .recruiter-entry-note p { margin: 0; color: var(--muted); font-size: .8rem; }

  .recruiter-entry-actions {
    grid-column: 1 / -1;
    display: flex;
    gap: 10px;
  }

  .recruiter-entry-actions .button {
    min-width: 140px;
    justify-content: center;
  }

  @media (max-width: 820px) {
    .recruiter-entry-form { grid-template-columns: 1fr; }
    .recruiter-entry-actions { flex-direction: column; }
    .recruiter-entry-actions .button { width: 100%; }
  }
</style>
