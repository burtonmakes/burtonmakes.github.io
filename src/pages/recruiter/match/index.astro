---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/global.css";
---

<BaseLayout
  title="Recruiter Role Review"
  description="Continue to the current recruiter role-review workspace."
>
  <section class="section recruiter-redirect">
    <article class="redirect-card reveal">
      <p class="eyebrow">Recruiter portal</p>
      <h1>Continue to the role review.</h1>
      <p>This legacy address now redirects to the current recruiter workspace.</p>
      <a class="button button-primary" href="/recruiter/">Open role review</a>
    </article>
  </section>
</BaseLayout>

<style>
  .recruiter-redirect {
    display: grid;
    min-height: calc(100vh - 96px);
    place-items: center;
    padding-block: clamp(4.5rem, 7vh, 5.8rem) clamp(1.8rem, 4vh, 3rem);
  }

  .redirect-card {
    display: grid;
    gap: 14px;
    width: min(620px, 100%);
    padding: clamp(22px, 4vw, 34px);
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    box-shadow: var(--shadow-soft);
  }

  .redirect-card h1,
  .redirect-card p {
    margin: 0;
  }

  .redirect-card h1 {
    max-width: 14ch;
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 0.98;
  }

  .redirect-card p:not(.eyebrow) {
    color: var(--muted-2);
    font-size: 0.95rem;
    line-height: 1.48;
  }

  .redirect-card .button {
    justify-self: start;
    min-height: 42px;
    border-radius: 9px;
  }
</style>

<script is:inline>
  window.location.replace("/recruiter/");
</script>
