---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/global.css";
---

<BaseLayout
  title="Recruiter Match"
  description="The recruiter matcher now lives on one page."
>
  <section class="section recruiter-match-redirect">
    <article class="redirect-card reveal">
      <p class="eyebrow">Recruiter fast path</p>
      <h1>Recruiter Match moved to one page.</h1>
      <p>
        The context form and comparison tool now live together on the recruiter page so hiring context,
        role text, match score, and evidence are reviewed in one flow.
      </p>
      <a class="button button-primary" href="/recruiter/">Open recruiter matcher</a>
    </article>
  </section>
</BaseLayout>

<style>
  .recruiter-match-redirect {
    display: grid;
    min-height: calc(100vh - 96px);
    place-items: center;
    padding-top: clamp(4.5rem, 7vh, 5.8rem);
    padding-bottom: clamp(1.8rem, 4vh, 3rem);
  }

  .redirect-card {
    display: grid;
    gap: 14px;
    width: min(620px, 100%);
    padding: clamp(22px, 4vw, 34px);
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--panel);
    box-shadow: var(--shadow-soft);
  }

  .redirect-card h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 0.98;
  }

  .redirect-card p:not(.eyebrow) {
    max-width: 58ch;
    margin: 0;
    color: var(--muted-2);
    font-size: 0.95rem;
    line-height: 1.48;
  }

  .redirect-card .button {
    justify-self: start;
    min-height: 42px;
    border-radius: 9px;
  }
</style>

<script is:inline>
  window.location.replace("/recruiter/");
</script>
