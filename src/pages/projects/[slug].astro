---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/site";
import "../../styles/global.css";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect("/projects/");
}
const relatedProjects = projects.filter((item) => item.slug !== project.slug).slice(0, 3);
---

<BaseLayout title={project.title} description={project.summary}>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">{project.section}</p>
      <h1>{project.title}</h1>
      <p class="hero-subtitle">{project.summary}</p>

      <div class="tag-row">
        <span class="tag tag-strong">{project.status}</span>
        <span class="tag">{project.timeline}</span>
        {project.labels.slice(0, 4).map((label) => <span class="tag">{label}</span>)}
      </div>
    </div>

    <div class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="profile-list">
        <div>
          <span>Type</span>
          <strong>{project.type}</strong>
        </div>
        <div>
          <span>Skills</span>
          <strong>{project.skills.join(", ")}</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section split-band">
    <div class="section-heading reveal">
      <p class="eyebrow">Project summary</p>
      <h2>Why it exists, what I built, and what I learned.</h2>
    </div>

    <div class="summary-blocks">
      <article class="feature-card reveal">
        <h3>Why I built it</h3>
        <p>{project.why}</p>
      </article>

      <article class="feature-card reveal">
        <h3>What I built</h3>
        <p>{project.built}</p>
      </article>

      <article class="feature-card reveal">
        <h3>What worked</h3>
        <p>{project.worked}</p>
      </article>

      <article class="feature-card reveal">
        <h3>What failed</h3>
        <p>{project.failed}</p>
      </article>

      <article class="feature-card reveal">
        <h3>What I learned</h3>
        <p>{project.learned}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Stack</p>
      <h2>Tools, systems, and technical areas involved.</h2>
    </div>

    <div class="tag-panel reveal">
      {project.stack.map((item) => <span class="tag tag-large">{item}</span>)}
    </div>
  </section>

  {(project.links.length > 0 || project.nextSteps) && (
    <section class="section split-band">
      <div class="section-heading reveal">
        <p class="eyebrow">Links and direction</p>
        <h2>Public links and next steps.</h2>
      </div>

      <div class="compact-stack">
        {project.links.map((item) => (
          <a class="publication-card reveal" href={item.href}>
            <span>Link</span>
            <strong>{item.label}</strong>
            <p>{item.href}</p>
          </a>
        ))}

        {project.nextSteps && (
          <article class="publication-card reveal">
            <span>Next</span>
            <strong>Future direction</strong>
            <p>{project.nextSteps}</p>
          </article>
        )}
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Related projects</p>
      <h2>Other projects in the same neighborhood.</h2>
    </div>

    <div class="card-grid">
      {relatedProjects.map((item) => (
        <a
          class="story-card reveal"
          href={`/projects/${item.slug}/`}
          data-project-slug={item.slug}
          data-project-type={item.type}
        >
          <span class="feature-kicker">{item.section}</span>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
