---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/site";
import "../../styles/global.css";

const featuredProjects = projects.slice(0, 6);
---

<BaseLayout
  title="Projects"
  description="Selected engineering projects by Alex Burton across AI systems, infrastructure, hardware, CAD, sensing, and automation."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Projects</p>
      <h1>Selected builds across AI tools, infrastructure, hardware, and sensing.</h1>
      <p class="hero-text">
        A focused set of projects showing how I build systems: define the problem,
        prototype quickly, document the tradeoffs, and turn rough ideas into working tools.
      </p>
    </div>

    <div class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="hero-panel-grid">
        <article class="hero-stat-card">
          <span class="label">Flagship product work</span>
          <strong>FlowSense Clinical + Home</strong>
        </article>
        <article class="hero-stat-card">
          <span class="label">Research foundation</span>
          <strong>Wireless battery-free bioelectronics</strong>
        </article>
        <article class="hero-stat-card hero-stat-accent">
          <span class="label">Platform extension</span>
          <strong>Wound-monitoring sensing patch</strong>
        </article>
        <article class="hero-stat-card">
          <span class="label">Current systems work</span>
          <strong>AI agents + self-hosted infrastructure</strong>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="featured-projects">
    <div class="section-heading reveal">
      <p class="eyebrow">Selected projects</p>
      <h2>A small set of projects worth opening first.</h2>
    </div>

    <div class="card-grid">
      {featuredProjects.map((project) => (
        <a
          class="story-card tilt-card reveal"
          href={`/projects/${project.slug}/`}
          data-project-slug={project.slug}
          data-project-type={project.type}
          data-analytics-impression="project-card"
          data-analytics-id={project.slug}
          data-analytics-label={project.title}
        >
          <span class="feature-kicker">{project.section}</span>
          <h3>{project.title}</h3>
          <p>{project.summary}</p>
          <div class="tag-row">
            {project.labels.slice(0, 3).map((label) => <span class="tag">{label}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
