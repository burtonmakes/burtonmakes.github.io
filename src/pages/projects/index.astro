---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/site";
import "../../styles/global.css";

const featuredProjects = projects;
const projectDomains = [...new Set(featuredProjects.map((project) => project.section))];
const getProjectProof = (project: (typeof projects)[number]) => project.facts.slice(0, 2);
---

<BaseLayout
  title="Projects"
  description="Selected engineering projects by Alex Burton across medical devices, implantables, physiological data, AI systems, infrastructure, and sensing."
>
  <section class="section projects-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Projects</p>
      <h1>Selected medical-device, implantable, sensing, data, and AI systems.</h1>
      <p class="hero-text">
        Concise project evidence from commercial medical-device work, Ph.D. implantable
        bioelectronics, early biomedical sensing, physiological data workflows, and
        selected AI/infrastructure builds.
      </p>
    </div>

    <div class="project-explorer reveal" data-project-explorer>
      <div class="project-domain-list" aria-label="Filter projects by domain">
        <button class="domain-node is-active" type="button" data-project-domain="all" aria-pressed="true">
          All systems
        </button>
        {projectDomains.map((domain) => (
          <button class="domain-node" type="button" data-project-domain={domain} aria-pressed="false">
            {domain}
          </button>
        ))}
      </div>

      <div class="project-node-field" aria-live="polite">
        {featuredProjects.map((project) => (
          <a
            class="project-node"
            href={`/projects/${project.slug}/`}
            data-project-node
            data-project-domain={project.section}
          >
            <span>{project.section}</span>
            <strong>{project.title}</strong>
            <small>{project.timeline}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="featured-projects">
    <div class="section-heading reveal">
      <p class="eyebrow">Selected projects</p>
      <h2>Project evidence with the numbers pulled forward.</h2>
    </div>

    <div class="card-grid project-evidence-grid">
      {featuredProjects.map((project) => {
        const proof = getProjectProof(project);
        return (
          <a
            class="story-card tilt-card reveal project-evidence-card"
            href={`/projects/${project.slug}/`}
            data-project-slug={project.slug}
            data-project-type={project.type}
            data-analytics-impression="project-card"
            data-analytics-id={project.slug}
            data-analytics-label={project.title}
          >
            <span class="feature-kicker">{project.section}</span>
            <h3>{project.title}</h3>
            <p>{project.summary}</p>
            {proof.length > 0 && (
              <ul class="project-proof-list" aria-label={`Evidence for ${project.title}`}>
                {proof.map((item) => <li>{item}</li>)}
              </ul>
            )}
            <div class="tag-row">
              {project.labels.slice(0, 3).map((label) => <span class="tag">{label}</span>)}
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .project-evidence-grid {
    align-items: stretch;
  }

  .project-evidence-card {
    display: flex;
    flex-direction: column;
  }

  .project-proof-list {
    display: grid;
    gap: 8px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .project-proof-list li {
    position: relative;
    margin: 0;
    padding-left: 16px;
    color: var(--muted-2);
    font-size: 0.92rem;
    line-height: 1.42;
    font-weight: 620;
  }

  .project-proof-list li::before {
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--accent-2);
    content: "";
  }

  .project-evidence-card .tag-row {
    margin-top: auto;
    padding-top: 18px;
  }
</style>

<script>
  const setupProjectExplorer = () => {
    document.querySelectorAll<HTMLElement>("[data-project-explorer]").forEach((explorer) => {
      if (explorer.dataset.ready === "true") return;
      explorer.dataset.ready = "true";

      const filters = [...explorer.querySelectorAll<HTMLButtonElement>("[data-project-domain]")].filter(
        (element) => element.matches("button"),
      );
      const nodes = [...explorer.querySelectorAll<HTMLElement>("[data-project-node]")];

      const selectDomain = (domain: string) => {
        filters.forEach((filter) => {
          const active = filter.dataset.projectDomain === domain;
          filter.classList.toggle("is-active", active);
          filter.setAttribute("aria-pressed", String(active));
        });
        nodes.forEach((node) => {
          const active = domain === "all" || node.dataset.projectDomain === domain;
          node.classList.toggle("is-muted", !active);
        });
      };

      filters.forEach((filter) => {
        filter.addEventListener("click", () => selectDomain(filter.dataset.projectDomain || "all"));
        filter.addEventListener("mouseenter", () => selectDomain(filter.dataset.projectDomain || "all"));
        filter.addEventListener("focus", () => selectDomain(filter.dataset.projectDomain || "all"));
      });
    });
  };

  document.addEventListener("astro:page-load", setupProjectExplorer);
  setupProjectExplorer();
</script>
