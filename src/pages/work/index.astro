---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  skillsDemonstrated,
  workHistory,
  workMetrics,
} from "../../data/site";
import "../../styles/global.css";

const careerTimeline = [...workHistory].reverse();
const roleId = (title: string) => title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
const getYearRange = (dates: string) => {
  const years = dates.match(/\d{4}/g) ?? [];
  if (years.length === 0) return dates;
  const first = years[0];
  const last = years[years.length - 1];
  return first === last ? first : `${first}–${last}`;
};
---

<BaseLayout
  title="Work"
  description="Professional engineering work by Alex Burton across medical devices, wearable sensing, hardware, validation, data workflows, and AI tools."
>
  <section class="section work-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Work history</p>
      <h1>From physiological data to implantables to medical-device systems.</h1>
      <p class="hero-text">
        A chronological view of the technical work: sensor data, low-noise
        electronics, wireless implantables, wearable medical devices, validation,
        documentation, and systems that have to work outside the lab.
      </p>
    </div>

    <div class="career-explorer reveal" data-career-explorer>
      <div class="career-track" role="tablist" aria-label="Career timeline">
        {careerTimeline.map((role, index) => (
          <button
            class="career-stop"
            type="button"
            role="tab"
            id={`career-tab-${roleId(role.title)}`}
            aria-controls={`career-panel-${roleId(role.title)}`}
            aria-selected={index === careerTimeline.length - 1 ? "true" : "false"}
            tabindex={index === careerTimeline.length - 1 ? "0" : "-1"}
            data-career-tab={roleId(role.title)}
          >
            <span>{getYearRange(role.dates)}</span>
            <strong>{role.title}</strong>
            <em>{role.company}</em>
          </button>
        ))}
      </div>

      <div class="career-panels">
        {careerTimeline.map((role, index) => (
          <article
            class="career-panel"
            id={`career-panel-${roleId(role.title)}`}
            role="tabpanel"
            aria-labelledby={`career-tab-${roleId(role.title)}`}
            hidden={index !== careerTimeline.length - 1}
            data-career-panel={roleId(role.title)}
          >
            <p class="career-period">{role.company} · {role.dates}</p>
            <h2>{role.title}</h2>
            <p>{role.summary}</p>

            <div class="career-scan-grid">
              <div>
                <span>Role focus</span>
                <strong>{role.context}</strong>
              </div>
              <div>
                <span>Achievement</span>
                <strong>{role.accomplishments[0]}</strong>
              </div>
              <div>
                <span>Technical range</span>
                <strong>{role.skills.slice(0, 4).join(" · ")}</strong>
              </div>
            </div>

            <details class="career-detail-tree" data-career-tree>
              <summary
                class="career-detail-toggle"
                aria-label={`Toggle detailed information for ${role.title}`}
              >
                <span class="detail-label-open">Details</span>
                <span class="detail-label-close">Close</span>
              </summary>

              <div class="career-detail-tree-body">
                <div class="work-tree-root">
                  <span>Selected role</span>
                  <strong>{role.title}</strong>
                  <p>{role.company} · {role.dates}</p>
                </div>

                <div class="work-tree-branches">
                  <section class="work-tree-node">
                    <span>Scope</span>
                    <ul>
                      {role.responsibilities.map((item) => <li>{item}</li>)}
                    </ul>
                  </section>

                  <section class="work-tree-node">
                    <span>Achievements</span>
                    <ul>
                      {role.accomplishments.map((item) => <li>{item}</li>)}
                    </ul>
                  </section>

                  <section class="work-tree-node">
                    <span>Technical range</span>
                    <div class="tag-row tree-tag-row">
                      {role.skills.map((skill) => <span class="tag">{skill}</span>)}
                    </div>
                  </section>
                </div>
              </div>
            </details>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section split-band">
    <div class="section-heading reveal">
      <p class="eyebrow">Metrics</p>
      <h2>Public achievements from engineering work.</h2>
    </div>

    <div class="card-grid metrics-card-grid">
      {workMetrics.map(([label, value]) => (
        <article
          class="metric-card reveal"
          data-analytics-impression="work-metric"
          data-analytics-id={label}
          data-analytics-label={value}
        >
          <strong>{label}</strong>
          <p>{value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Skills demonstrated through the work.</h2>
    </div>

    <div class="tag-panel reveal">
      {skillsDemonstrated.map((item) => (
        <span
          class="tag tag-large"
          data-analytics-impression="work-skill"
          data-analytics-id={item}
          data-analytics-label={item}
        >
          {item}
        </span>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .career-detail-tree {
    margin-top: 18px;
  }

  .career-detail-toggle {
    display: flex;
    justify-content: flex-end;
    cursor: pointer;
    list-style: none;
  }

  .career-detail-toggle::-webkit-details-marker {
    display: none;
  }

  .career-detail-toggle span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 17px;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--cta-1), var(--cta-2));
    color: #081014;
    box-shadow: 0 10px 28px rgba(232, 111, 78, 0.2);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .career-detail-toggle:hover span,
  .career-detail-toggle:focus-visible span {
    filter: brightness(1.06);
  }

  .career-detail-toggle .detail-label-close,
  .career-detail-tree[open] .career-detail-toggle .detail-label-open {
    display: none;
  }

  .career-detail-tree[open] .career-detail-toggle .detail-label-close {
    display: inline-flex;
  }

  .career-detail-tree-body {
    position: relative;
    margin-top: 18px;
    padding: 22px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.014)),
      rgba(3, 8, 15, 0.36);
  }

  .work-tree-root {
    position: relative;
    display: grid;
    gap: 5px;
    padding: 18px 20px;
    border: 1px solid color-mix(in srgb, var(--accent-2), transparent 65%);
    border-radius: 10px;
    background: rgba(76, 141, 255, 0.08);
  }

  .work-tree-root::after {
    position: absolute;
    left: 28px;
    top: 100%;
    width: 1px;
    height: 18px;
    background: color-mix(in srgb, var(--accent-2), transparent 54%);
    content: "";
  }

  .work-tree-root span,
  .work-tree-node span {
    display: block;
    color: #9fe7ff;
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .work-tree-root strong {
    color: var(--text);
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .work-tree-root p {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .work-tree-branches {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 18px;
    padding-top: 18px;
  }

  .work-tree-branches::before {
    position: absolute;
    left: 28px;
    right: 28px;
    top: 0;
    height: 1px;
    background: color-mix(in srgb, var(--accent-2), transparent 72%);
    content: "";
  }

  .work-tree-node {
    position: relative;
    min-height: 100%;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.095);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.025);
  }

  .work-tree-node::before {
    position: absolute;
    left: 28px;
    bottom: 100%;
    width: 1px;
    height: 18px;
    background: color-mix(in srgb, var(--accent-2), transparent 65%);
    content: "";
  }

  .work-tree-node ul {
    margin-top: 12px;
  }

  .work-tree-node li {
    color: #d6e4f3;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .tree-tag-row {
    margin-top: 14px;
  }

  @media (max-width: 980px) {
    .work-tree-branches {
      grid-template-columns: 1fr;
    }

    .work-tree-branches::before,
    .work-tree-node::before,
    .work-tree-root::after {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .career-detail-toggle {
      justify-content: stretch;
    }

    .career-detail-toggle span {
      width: 100%;
    }

    .career-detail-tree-body {
      padding: 16px;
    }
  }
</style>

<script>
  const setupCareerExplorer = () => {
    document.querySelectorAll<HTMLElement>("[data-career-explorer]").forEach((explorer) => {
      if (explorer.dataset.ready === "true") return;
      explorer.dataset.ready = "true";

      const tabs = [...explorer.querySelectorAll<HTMLButtonElement>("[data-career-tab]")];
      const panels = [...explorer.querySelectorAll<HTMLElement>("[data-career-panel]")];
      const detailTrees = [...explorer.querySelectorAll<HTMLDetailsElement>("[data-career-tree]")];

      const closeHiddenTrees = (activePanel: HTMLElement) => {
        detailTrees.forEach((tree) => {
          if (!activePanel.contains(tree)) tree.open = false;
        });
      };

      const activate = (tab: HTMLButtonElement) => {
        const target = tab.dataset.careerTab;
        tabs.forEach((item) => {
          const selected = item === tab;
          item.setAttribute("aria-selected", String(selected));
          item.tabIndex = selected ? 0 : -1;
        });
        panels.forEach((panel) => {
          const selected = panel.dataset.careerPanel === target;
          panel.hidden = !selected;
          if (selected) closeHiddenTrees(panel);
        });
      };

      detailTrees.forEach((tree) => {
        tree.addEventListener("toggle", () => {
          if (!tree.open) return;
          detailTrees.forEach((item) => {
            if (item !== tree) item.open = false;
          });
        });
      });

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(tab));
        tab.addEventListener("keydown", (event) => {
          if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
          event.preventDefault();
          const offset = event.key === "ArrowRight" ? 1 : -1;
          const next = tabs[(index + offset + tabs.length) % tabs.length];
          activate(next);
          next.focus();
        });
      });
    });
  };

  document.addEventListener("astro:page-load", setupCareerExplorer);
  setupCareerExplorer();
</script>
