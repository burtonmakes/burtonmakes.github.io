---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  skillsDemonstrated,
  workHistory,
  workMetrics,
} from "../../data/site";
import "../../styles/global.css";

const careerTimeline = [...workHistory].reverse();
const roleId = (title: string) => title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
const getYearRange = (dates: string) => {
  const years = dates.match(/\d{4}/g) ?? [];
  if (years.length === 0) return dates;
  const first = years[0];
  const last = years[years.length - 1];
  return first === last ? first : `${first}–${last}`;
};
---

<BaseLayout
  title="Work"
  description="Professional engineering work by Alex Burton across medical devices, wearable sensing, hardware, validation, data workflows, and AI tools."
>
  <section class="section work-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Work history</p>
      <h1>From physiological data to implantables to medical-device systems.</h1>
      <p class="hero-text">
        A chronological view of the technical work: sensor data, low-noise
        electronics, wireless implantables, wearable medical devices, validation,
        documentation, and systems that have to work outside the lab.
      </p>
    </div>

    <div class="career-explorer reveal" data-career-explorer>
      <div class="career-track" role="tablist" aria-label="Career timeline">
        {careerTimeline.map((role, index) => (
          <button
            class="career-stop"
            type="button"
            role="tab"
            id={`career-tab-${roleId(role.title)}`}
            aria-controls={`career-panel-${roleId(role.title)}`}
            aria-selected={index === careerTimeline.length - 1 ? "true" : "false"}
            tabindex={index === careerTimeline.length - 1 ? "0" : "-1"}
            data-career-tab={roleId(role.title)}
          >
            <span>{getYearRange(role.dates)}</span>
            <strong>{role.title}</strong>
            <em>{role.company}</em>
          </button>
        ))}
      </div>

      <div class="career-panels">
        {careerTimeline.map((role, index) => (
          <article
            class="career-panel"
            id={`career-panel-${roleId(role.title)}`}
            role="tabpanel"
            aria-labelledby={`career-tab-${roleId(role.title)}`}
            hidden={index !== careerTimeline.length - 1}
            data-career-panel={roleId(role.title)}
          >
            <p class="career-period">{role.company} · {role.dates}</p>
            <h2>{role.title}</h2>
            <p>{role.summary}</p>

            <div class="career-scan-grid branch-card-grid">
              <button
                class="career-scan-item"
                type="button"
                data-branch-toggle="role-focus"
                aria-expanded="false"
                aria-controls={`branch-${roleId(role.title)}-role-focus`}
              >
                <span>Role focus</span>
                <strong>{role.context}</strong>
              </button>

              <button
                class="career-scan-item"
                type="button"
                data-branch-toggle="achievements"
                aria-expanded="false"
                aria-controls={`branch-${roleId(role.title)}-achievements`}
              >
                <span>Achievement</span>
                <strong>{role.accomplishments[0]}</strong>
              </button>

              <button
                class="career-scan-item"
                type="button"
                data-branch-toggle="technical-range"
                aria-expanded="false"
                aria-controls={`branch-${roleId(role.title)}-technical-range`}
              >
                <span>Technical range</span>
                <strong>{role.skills.slice(0, 4).join(" · ")}</strong>
              </button>
            </div>

            <div class="branch-expansion" data-branch-expansion hidden>
              <section
                class="branch-panel"
                id={`branch-${roleId(role.title)}-role-focus`}
                data-branch-panel="role-focus"
                hidden
              >
                <div class="branch-panel-heading">
                  <span>Role focus</span>
                  <h3>Scope of role</h3>
                </div>
                <ul class="branch-list">
                  {role.responsibilities.map((item) => <li>{item}</li>)}
                </ul>
              </section>

              <section
                class="branch-panel"
                id={`branch-${roleId(role.title)}-achievements`}
                data-branch-panel="achievements"
                hidden
              >
                <div class="branch-panel-heading">
                  <span>Achievements</span>
                  <h3>Evidence from the work</h3>
                </div>
                <ul class="branch-list">
                  {role.accomplishments.map((item) => <li>{item}</li>)}
                </ul>
              </section>

              <section
                class="branch-panel"
                id={`branch-${roleId(role.title)}-technical-range`}
                data-branch-panel="technical-range"
                hidden
              >
                <div class="branch-panel-heading">
                  <span>Technical range</span>
                  <h3>Tools, systems, and technical areas</h3>
                </div>
                <div class="tag-row branch-tag-row">
                  {role.skills.map((skill) => <span class="tag">{skill}</span>)}
                </div>
              </section>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section split-band">
    <div class="section-heading reveal">
      <p class="eyebrow">Metrics</p>
      <h2>Public achievements from engineering work.</h2>
    </div>

    <div class="card-grid metrics-card-grid">
      {workMetrics.map(([label, value]) => (
        <article
          class="metric-card reveal"
          data-analytics-impression="work-metric"
          data-analytics-id={label}
          data-analytics-label={value}
        >
          <strong>{label}</strong>
          <p>{value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Skills demonstrated through the work.</h2>
    </div>

    <div class="tag-panel reveal">
      {skillsDemonstrated.map((item) => (
        <span
          class="tag tag-large"
          data-analytics-impression="work-skill"
          data-analytics-id={item}
          data-analytics-label={item}
        >
          {item}
        </span>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .career-explorer {
    --branch-line: #9fe7ff;
    --branch-line-soft: rgba(159, 231, 255, 0.42);
    --branch-orange: var(--cta-2);
    overflow: hidden;
  }

  .branch-card-grid {
    align-items: stretch;
  }

  .career-scan-item {
    position: relative;
    display: block;
    min-height: 100%;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.035);
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .career-scan-item::after {
    position: absolute;
    left: 50%;
    bottom: -30px;
    display: none;
    width: 2px;
    height: 30px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--branch-line), var(--branch-line-soft));
    box-shadow: 0 0 16px rgba(159, 231, 255, 0.34);
    content: "";
    transform: translateX(-50%);
  }

  .career-scan-item:hover,
  .career-scan-item:focus-visible {
    border-color: color-mix(in srgb, var(--branch-orange), white 10%);
    background:
      linear-gradient(145deg, rgba(232, 111, 78, 0.08), rgba(226, 184, 105, 0.03)),
      rgba(255, 255, 255, 0.042);
    box-shadow: 0 0 0 1px rgba(232, 111, 78, 0.18);
    transform: translateY(-2px);
    outline: none;
  }

  .career-scan-item.is-active {
    border-color: color-mix(in srgb, var(--branch-orange), white 8%);
    background:
      linear-gradient(145deg, rgba(232, 111, 78, 0.14), rgba(226, 184, 105, 0.04)),
      rgba(255, 255, 255, 0.05);
    box-shadow:
      0 0 0 1px rgba(232, 111, 78, 0.26),
      0 16px 36px rgba(0, 0, 0, 0.2);
  }

  .career-scan-item.is-active::after {
    display: block;
  }

  .career-scan-item span {
    display: block;
    margin-bottom: 10px;
    color: #9fb0c4;
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    transition: color 180ms ease;
  }

  .career-scan-item:hover span,
  .career-scan-item:focus-visible span,
  .career-scan-item.is-active span {
    color: #f2b277;
  }

  .career-scan-item strong {
    display: block;
    color: #edf5ff;
    font-size: 0.95rem;
    font-weight: 650;
    line-height: 1.45;
  }

  .branch-expansion {
    position: relative;
    margin-top: 30px;
    padding: 22px;
    border: 1px solid rgba(159, 231, 255, 0.22);
    border-radius: 12px;
    background:
      radial-gradient(circle at var(--branch-x, 50%) 0%, rgba(159, 231, 255, 0.14), transparent 28%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.048), rgba(255, 255, 255, 0.014)),
      rgba(3, 8, 15, 0.38);
    box-shadow:
      inset 0 1px rgba(255, 255, 255, 0.05),
      0 18px 44px rgba(0, 0, 0, 0.18);
  }

  .branch-expansion::before {
    position: absolute;
    left: var(--branch-x, 50%);
    top: -1px;
    width: min(140px, 24%);
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--branch-line), transparent);
    box-shadow: 0 0 18px rgba(159, 231, 255, 0.32);
    content: "";
    transform: translateX(-50%);
  }

  .branch-panel {
    animation: branch-panel-in 180ms ease both;
  }

  .branch-panel-heading {
    display: grid;
    gap: 4px;
    margin-bottom: 16px;
  }

  .branch-panel-heading span {
    display: block;
    color: var(--branch-line);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .branch-panel-heading h3 {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.12rem, 1.6vw, 1.45rem);
    line-height: 1.14;
  }

  .branch-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px 22px;
    margin: 0;
    padding-left: 20px;
  }

  .branch-list li {
    color: #d6e4f3;
    font-size: 0.96rem;
    line-height: 1.52;
  }

  .branch-list li + li {
    margin-top: 0;
  }

  .branch-tag-row {
    margin-top: 4px;
  }

  @keyframes branch-panel-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .career-scan-item.is-active::after,
    .branch-expansion::before {
      display: none;
    }

    .branch-list {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const setupCareerExplorer = () => {
    document.querySelectorAll<HTMLElement>("[data-career-explorer]").forEach((explorer) => {
      if (explorer.dataset.ready === "true") return;
      explorer.dataset.ready = "true";

      const tabs = [...explorer.querySelectorAll<HTMLButtonElement>("[data-career-tab]")];
      const panels = [...explorer.querySelectorAll<HTMLElement>("[data-career-panel]")];
      const branchToggles = [...explorer.querySelectorAll<HTMLButtonElement>("[data-branch-toggle]")];

      const closeBranches = (scope: HTMLElement = explorer) => {
        scope.querySelectorAll<HTMLElement>("[data-branch-expansion]").forEach((expansion) => {
          expansion.hidden = true;
          expansion.style.removeProperty("--branch-x");
        });
        scope.querySelectorAll<HTMLElement>("[data-branch-panel]").forEach((panel) => {
          panel.hidden = true;
        });
        scope.querySelectorAll<HTMLButtonElement>("[data-branch-toggle]").forEach((toggle) => {
          toggle.classList.remove("is-active");
          toggle.setAttribute("aria-expanded", "false");
        });
      };

      const syncBranchLine = (toggle: HTMLButtonElement, expansion: HTMLElement) => {
        const toggleRect = toggle.getBoundingClientRect();
        const expansionRect = expansion.getBoundingClientRect();
        const x = toggleRect.left + toggleRect.width / 2 - expansionRect.left;
        expansion.style.setProperty("--branch-x", `${x}px`);
      };

      const activateBranch = (toggle: HTMLButtonElement) => {
        const branch = toggle.dataset.branchToggle;
        const panel = toggle.closest<HTMLElement>("[data-career-panel]");
        if (!branch || !panel) return;

        const expansion = panel.querySelector<HTMLElement>("[data-branch-expansion]");
        const targetPanel = panel.querySelector<HTMLElement>(`[data-branch-panel="${branch}"]`);
        const wasActive = toggle.classList.contains("is-active");

        closeBranches(panel);

        if (wasActive || !expansion || !targetPanel) return;

        toggle.classList.add("is-active");
        toggle.setAttribute("aria-expanded", "true");
        targetPanel.hidden = false;
        expansion.hidden = false;
        syncBranchLine(toggle, expansion);
      };

      const activate = (tab: HTMLButtonElement) => {
        const target = tab.dataset.careerTab;
        tabs.forEach((item) => {
          const selected = item === tab;
          item.setAttribute("aria-selected", String(selected));
          item.tabIndex = selected ? 0 : -1;
        });
        panels.forEach((panel) => {
          const selected = panel.dataset.careerPanel === target;
          panel.hidden = !selected;
          if (!selected) closeBranches(panel);
        });
      };

      branchToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => activateBranch(toggle));
      });

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(tab));
        tab.addEventListener("keydown", (event) => {
          if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
          event.preventDefault();
          const offset = event.key === "ArrowRight" ? 1 : -1;
          const next = tabs[(index + offset + tabs.length) % tabs.length];
          activate(next);
          next.focus();
        });
      });

      window.addEventListener(
        "resize",
        () => {
          const activeToggle = explorer.querySelector<HTMLButtonElement>("[data-branch-toggle].is-active");
          const activePanel = activeToggle?.closest<HTMLElement>("[data-career-panel]");
          const expansion = activePanel?.querySelector<HTMLElement>("[data-branch-expansion]");
          if (activeToggle && expansion && !expansion.hidden) syncBranchLine(activeToggle, expansion);
        },
        { passive: true },
      );
    });
  };

  document.addEventListener("astro:page-load", setupCareerExplorer);
  setupCareerExplorer();
</script>
