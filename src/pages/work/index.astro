---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  skillsDemonstrated,
  siteMeta,
  workHistory,
  workMetrics,
} from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Work"
  description="Professional engineering work by Alex Burton across medical devices, wearable sensing, hardware, validation, data workflows, and AI tools."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Professional work</p>
      <h1>Medical-device engineering with range across hardware, sensing, data, and validation.</h1>
      <p class="hero-text">
        My professional work centers on wearable and implantable sensing systems,
        device reliability, clinical and home monitoring workflows, sensor integration,
        testing, documentation, and cross-functional execution.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={siteMeta.links.linkedin} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a class="button button-secondary" href={siteMeta.links.github} target="_blank" rel="noreferrer noopener">GitHub</a>
        <a class="button button-tertiary" href="/contact/">Contact</a>
      </div>
    </div>

    <div class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="profile-list">
        <div>
          <span>Progression · 2014–2025</span>
          <strong>Physiological data → low-noise sensing → implantable bioelectronics → senior product R&amp;D</strong>
        </div>
        <div>
          <span>How I connect the system</span>
          <strong>Sensor physics, electronics, packaging, algorithms, validation, manufacturing, and clinical use</strong>
        </div>
        <div>
          <span>Product translation</span>
          <strong>Prototype development, verification, manufacturing support, and clinical or home-use workflows</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Work history</p>
      <h2>Roles, responsibilities, and outcomes.</h2>
    </div>

    <div class="timeline-stack">
      {workHistory.map((role) => (
        <article
          class="timeline-card reveal"
          data-analytics-impression="work-role"
          data-analytics-id={`${role.company} | ${role.title}`}
          data-analytics-label={role.dates}
        >
          <div class="timeline-top">
            <div>
              <h3>{role.title}</h3>
              <p class="muted">{role.company} · {role.dates}</p>
            </div>
          </div>

          <p>{role.context}</p>
          <p>{role.summary}</p>

          <div class="dual-list">
            <div>
              <strong>Responsibilities</strong>
              <ul>
                {role.responsibilities.map((item) => <li>{item}</li>)}
              </ul>
            </div>

            <div>
              <strong>Accomplishments</strong>
              <ul>
                {role.accomplishments.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>

          <div class="tag-row">
            {role.skills.map((skill) => <span class="tag">{skill}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-band">
    <div class="section-heading reveal">
      <p class="eyebrow">Metrics</p>
      <h2>Public proof points from engineering work.</h2>
    </div>

    <div class="card-grid metrics-card-grid">
      {workMetrics.map(([label, value]) => (
        <article
          class="metric-card reveal"
          data-analytics-impression="work-metric"
          data-analytics-id={label}
          data-analytics-label={value}
        >
          <strong>{label}</strong>
          <p>{value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Skills demonstrated through the work.</h2>
    </div>

    <div class="tag-panel reveal">
      {skillsDemonstrated.map((item) => (
        <span
          class="tag tag-large"
          data-analytics-impression="work-skill"
          data-analytics-id={item}
          data-analytics-label={item}
        >
          {item}
        </span>
      ))}
    </div>
  </section>
</BaseLayout>
