---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  skillsDemonstrated,
  workHistory,
  workMetrics,
} from "../../data/site";
import "../../styles/global.css";

const careerTimeline = [...workHistory].reverse();
const roleId = (title: string) => title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
const getYearRange = (dates: string) => {
  const years = dates.match(/\d{4}/g) ?? [];
  if (years.length === 0) return dates;
  const first = years[0];
  const last = years[years.length - 1];
  return first === last ? first : `${first}–${last}`;
};
---

<BaseLayout
  title="Work"
  description="Professional engineering work by Alex Burton across medical devices, wearable sensing, hardware, validation, data workflows, and AI tools."
>
  <section class="section work-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Work history</p>
      <h1>From physiological data to implantables to medical-device systems.</h1>
      <p class="hero-text">
        A chronological view of the technical work: sensor data, low-noise
        electronics, wireless implantables, wearable medical devices, validation,
        documentation, and systems that have to work outside the lab.
      </p>
    </div>

    <div class="career-explorer reveal" data-career-explorer>
      <div class="career-track" role="tablist" aria-label="Career timeline">
        {careerTimeline.map((role, index) => (
          <button
            class="career-stop"
            type="button"
            role="tab"
            id={`career-tab-${roleId(role.title)}`}
            aria-controls={`career-panel-${roleId(role.title)}`}
            aria-selected={index === careerTimeline.length - 1 ? "true" : "false"}
            tabindex={index === careerTimeline.length - 1 ? "0" : "-1"}
            data-career-tab={roleId(role.title)}
          >
            <span>{getYearRange(role.dates)}</span>
            <strong>{role.title}</strong>
            <em>{role.company}</em>
          </button>
        ))}
      </div>

      <div class="career-panels">
        {careerTimeline.map((role, index) => (
          <article
            class="career-panel"
            id={`career-panel-${roleId(role.title)}`}
            role="tabpanel"
            aria-labelledby={`career-tab-${roleId(role.title)}`}
            hidden={index !== careerTimeline.length - 1}
            data-career-panel={roleId(role.title)}
          >
            <div class="career-panel-card">
              <p class="career-period">{role.company} · {role.dates}</p>
              <h2>{role.title}</h2>
              <p>{role.summary}</p>

              <div class="career-scan-grid">
                <div>
                  <span>Role focus</span>
                  <strong>{role.context}</strong>
                </div>
                <div>
                  <span>Achievement</span>
                  <strong>{role.accomplishments[0]}</strong>
                </div>
                <div>
                  <span>Technical range</span>
                  <strong>{role.skills.slice(0, 4).join(" · ")}</strong>
                </div>
              </div>
            </div>

            <details class="career-detail-tree" data-career-tree>
              <summary
                class="career-detail-toggle"
                aria-label={`Toggle detailed information for ${role.title}`}
              >
                <span class="detail-label-open">Details</span>
                <span class="detail-label-close">Close</span>
              </summary>

              <div class="career-detail-tree-body">
                <div class="resume-detail-card">
                  <header class="resume-detail-header">
                    <span>Role details</span>
                    <h3>{role.title}</h3>
                    <p>{role.company} · {role.dates}</p>
                  </header>

                  <div class="resume-detail-grid">
                    <section class="resume-block resume-summary-block">
                      <span>Summary</span>
                      <p>{role.context}</p>
                    </section>

                    <section class="resume-block">
                      <span>Scope</span>
                      <ul>
                        {role.responsibilities.map((item) => <li>{item}</li>)}
                      </ul>
                    </section>

                    <section class="resume-block">
                      <span>Achievements</span>
                      <ul>
                        {role.accomplishments.map((item) => <li>{item}</li>)}
                      </ul>
                    </section>

                    <section class="resume-block">
                      <span>Technical range</span>
                      <div class="tag-row tree-tag-row">
                        {role.skills.map((skill) => <span class="tag">{skill}</span>)}
                      </div>
                    </section>
                  </div>
                </div>
              </div>
            </details>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section split-band">
    <div class="section-heading reveal">
      <p class="eyebrow">Metrics</p>
      <h2>Public achievements from engineering work.</h2>
    </div>

    <div class="card-grid metrics-card-grid">
      {workMetrics.map(([label, value]) => (
        <article
          class="metric-card reveal"
          data-analytics-impression="work-metric"
          data-analytics-id={label}
          data-analytics-label={value}
        >
          <strong>{label}</strong>
          <p>{value}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Skills demonstrated through the work.</h2>
    </div>

    <div class="tag-panel reveal">
      {skillsDemonstrated.map((item) => (
        <span
          class="tag tag-large"
          data-analytics-impression="work-skill"
          data-analytics-id={item}
          data-analytics-label={item}
        >
          {item}
        </span>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .career-explorer {
    --tree-line: #9fe7ff;
    --tree-line-soft: rgba(159, 231, 255, 0.38);
    --tree-line-faint: rgba(159, 231, 255, 0.16);
    position: relative;
    overflow: visible;
  }

  .career-explorer::before {
    position: absolute;
    left: var(--career-line-x, 50%);
    top: var(--career-track-bottom, 112px);
    z-index: 2;
    width: 2px;
    height: 34px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--tree-line), var(--tree-line-soft));
    box-shadow: 0 0 18px rgba(159, 231, 255, 0.38);
    content: "";
    transform: translateX(-50%);
    pointer-events: none;
  }

  .career-explorer::after {
    position: absolute;
    left: var(--career-line-x, 50%);
    top: calc(var(--career-track-bottom, 112px) + 26px);
    z-index: 1;
    width: 8px;
    height: 8px;
    border: 1px solid var(--tree-line);
    border-radius: 999px;
    background: #06101c;
    box-shadow: 0 0 20px rgba(159, 231, 255, 0.42);
    content: "";
    transform: translateX(-50%);
    pointer-events: none;
  }

  .career-panel {
    position: relative;
  }

  .career-panel-card {
    position: relative;
    padding: 0;
  }

  .career-panel-card::before {
    position: absolute;
    left: var(--career-line-x, 50%);
    top: -44px;
    width: 1px;
    height: 44px;
    background: linear-gradient(180deg, transparent, var(--tree-line-soft));
    content: "";
    transform: translateX(-50%);
    pointer-events: none;
  }

  .career-detail-tree {
    position: relative;
    margin-top: 28px;
    padding-top: 28px;
  }

  .career-detail-tree::before {
    position: absolute;
    left: 50%;
    top: 0;
    display: none;
    width: 2px;
    height: 34px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--tree-line-soft), var(--tree-line));
    box-shadow: 0 0 18px rgba(159, 231, 255, 0.28);
    content: "";
    transform: translateX(-50%);
  }

  .career-detail-tree[open]::before {
    display: block;
  }

  .career-detail-toggle {
    display: flex;
    justify-content: flex-end;
    cursor: pointer;
    list-style: none;
  }

  .career-detail-toggle::-webkit-details-marker {
    display: none;
  }

  .career-detail-toggle span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 17px;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--cta-1), var(--cta-2));
    color: #081014;
    box-shadow: 0 10px 28px rgba(232, 111, 78, 0.2);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .career-detail-toggle:hover span,
  .career-detail-toggle:focus-visible span {
    filter: brightness(1.06);
  }

  .career-detail-toggle .detail-label-close,
  .career-detail-tree[open] .career-detail-toggle .detail-label-open {
    display: none;
  }

  .career-detail-tree[open] .career-detail-toggle .detail-label-close {
    display: inline-flex;
  }

  .career-detail-tree-body {
    position: relative;
    margin-top: 24px;
  }

  .career-detail-tree-body::before {
    position: absolute;
    left: 50%;
    top: -24px;
    width: 1px;
    height: 24px;
    background: var(--tree-line-soft);
    content: "";
    transform: translateX(-50%);
  }

  .resume-detail-card {
    position: relative;
    padding: 22px;
    border: 1px solid rgba(159, 231, 255, 0.2);
    border-radius: 13px;
    background:
      radial-gradient(circle at 18% 0%, rgba(159, 231, 255, 0.1), transparent 28%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.048), rgba(255, 255, 255, 0.014)),
      rgba(3, 8, 15, 0.38);
    box-shadow:
      inset 0 1px rgba(255, 255, 255, 0.05),
      0 18px 44px rgba(0, 0, 0, 0.18);
  }

  .resume-detail-card::before {
    position: absolute;
    left: 28px;
    right: 28px;
    top: 112px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--tree-line-soft), transparent);
    content: "";
    pointer-events: none;
  }

  .resume-detail-header {
    position: relative;
    display: grid;
    gap: 4px;
    padding: 18px 18px 22px;
    border: 1px solid color-mix(in srgb, var(--tree-line), transparent 68%);
    border-radius: 10px;
    background: rgba(76, 141, 255, 0.08);
  }

  .resume-detail-header::after {
    position: absolute;
    left: 28px;
    top: 100%;
    width: 1px;
    height: 24px;
    background: var(--tree-line-soft);
    content: "";
  }

  .resume-detail-header span,
  .resume-block span {
    display: block;
    color: var(--tree-line);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .resume-detail-header h3 {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.12rem, 1.6vw, 1.55rem);
    line-height: 1.14;
  }

  .resume-detail-header p {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .resume-detail-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.2fr) minmax(0, 1.1fr);
    gap: 14px;
    margin-top: 24px;
    padding-top: 18px;
  }

  .resume-detail-grid::before {
    position: absolute;
    left: 28px;
    right: 28px;
    top: 0;
    height: 1px;
    background: var(--tree-line-soft);
    content: "";
  }

  .resume-block {
    position: relative;
    min-height: 100%;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.095);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.024);
  }

  .resume-block::before {
    position: absolute;
    left: 28px;
    bottom: 100%;
    width: 1px;
    height: 18px;
    background: var(--tree-line-soft);
    content: "";
  }

  .resume-summary-block {
    grid-column: span 3;
  }

  .resume-block p {
    margin: 12px 0 0;
    color: #d6e4f3;
    line-height: 1.55;
  }

  .resume-block ul {
    margin-top: 12px;
  }

  .resume-block li {
    color: #d6e4f3;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .tree-tag-row {
    margin-top: 14px;
  }

  @media (max-width: 1100px) {
    .resume-detail-grid {
      grid-template-columns: 1fr;
    }

    .resume-summary-block {
      grid-column: auto;
    }

    .resume-detail-card::before,
    .resume-detail-header::after,
    .resume-detail-grid::before,
    .resume-block::before {
      display: none;
    }
  }

  @media (max-width: 980px) {
    .career-explorer::before,
    .career-explorer::after,
    .career-panel-card::before,
    .career-detail-tree::before,
    .career-detail-tree-body::before {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .career-detail-toggle {
      justify-content: stretch;
    }

    .career-detail-toggle span {
      width: 100%;
    }

    .resume-detail-card {
      padding: 16px;
    }
  }
</style>

<script>
  const setupCareerExplorer = () => {
    document.querySelectorAll<HTMLElement>("[data-career-explorer]").forEach((explorer) => {
      if (explorer.dataset.ready === "true") return;
      explorer.dataset.ready = "true";

      const tabs = [...explorer.querySelectorAll<HTMLButtonElement>("[data-career-tab]")];
      const panels = [...explorer.querySelectorAll<HTMLElement>("[data-career-panel]")];
      const detailTrees = [...explorer.querySelectorAll<HTMLDetailsElement>("[data-career-tree]")];
      const track = explorer.querySelector<HTMLElement>(".career-track");

      const syncConnector = (tab: HTMLButtonElement) => {
        const explorerRect = explorer.getBoundingClientRect();
        const tabRect = tab.getBoundingClientRect();
        const trackRect = track?.getBoundingClientRect();
        explorer.style.setProperty("--career-line-x", `${tabRect.left + tabRect.width / 2 - explorerRect.left}px`);
        if (trackRect) {
          explorer.style.setProperty("--career-track-bottom", `${trackRect.bottom - explorerRect.top}px`);
        }
      };

      const getActiveTab = () => tabs.find((item) => item.getAttribute("aria-selected") === "true") ?? tabs[0];

      const closeHiddenTrees = (activePanel: HTMLElement) => {
        detailTrees.forEach((tree) => {
          if (!activePanel.contains(tree)) tree.open = false;
        });
      };

      const activate = (tab: HTMLButtonElement) => {
        const target = tab.dataset.careerTab;
        tabs.forEach((item) => {
          const selected = item === tab;
          item.setAttribute("aria-selected", String(selected));
          item.tabIndex = selected ? 0 : -1;
        });
        panels.forEach((panel) => {
          const selected = panel.dataset.careerPanel === target;
          panel.hidden = !selected;
          if (selected) closeHiddenTrees(panel);
        });
        syncConnector(tab);
      };

      detailTrees.forEach((tree) => {
        tree.addEventListener("toggle", () => {
          if (!tree.open) return;
          detailTrees.forEach((item) => {
            if (item !== tree) item.open = false;
          });
        });
      });

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(tab));
        tab.addEventListener("keydown", (event) => {
          if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
          event.preventDefault();
          const offset = event.key === "ArrowRight" ? 1 : -1;
          const next = tabs[(index + offset + tabs.length) % tabs.length];
          activate(next);
          next.focus();
        });
      });

      track?.addEventListener("scroll", () => syncConnector(getActiveTab()), { passive: true });
      window.addEventListener("resize", () => syncConnector(getActiveTab()), { passive: true });
      requestAnimationFrame(() => syncConnector(getActiveTab()));
    });
  };

  document.addEventListener("astro:page-load", setupCareerExplorer);
  setupCareerExplorer();
</script>
