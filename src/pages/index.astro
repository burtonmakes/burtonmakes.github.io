---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Alex Burton | Biomedical Systems Engineer";
const pageDescription =
  "Biomedical systems engineer building wearable and implantable medical-device sensing systems across hardware, validation, manufacturing, physiological data workflows, and ML/AI-enabled tools.";
const originStory = [
  {
    kicker: "Early engineering",
    title: "Learning by building physical systems.",
    body:
      "I started building hardware around 2010 through hands-on projects that mixed electronics, mechanics, soldering, and control systems. The work ranged from 3D LED displays and wireless motion-control systems to an electromagnetic launcher, building a 3D printer out of balsa wood, and a plastic-recycling setup for 3D-printing material. It gave me a practical foundation in electronics, digital control, transistors, mechanical design, troubleshooting, and the patience required to make physical systems work.",
  },
  {
    kicker: "Interest in medicine",
    title: "Seeing healthcare up close.",
    body:
      "Around 2014, I became more interested in medicine through hospital volunteering, where I helped staff and nurses with day-to-day patient-care activities. That experience gave me a closer look at hospital environments, medical devices, physiology, and the human side of healthcare. It made medicine feel practical, real, and connected to the people using the technology.",
  },
  {
    kicker: "Biomedical systems",
    title: "Where engineering became healthcare technology.",
    body:
      "Biomedical engineering became the place where those interests fit together: using hardware, electronics, sensing, and systems engineering to build technology that can help people. That path grew into medical devices, wearable and implantable sensing systems, preclinical and clinical validation, patient interaction, and the workflow required to move a device from an idea into real use.",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section studio-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Biomedical Systems Engineer · Medical Devices</p>

      <h1>Biomedical sensing systems from prototype to clinical use.</h1>

      <p class="hero-subtitle">
        Biomedical systems engineer building wearable and implantable medical-device
        sensing systems across hardware, validation, manufacturing, physiological
        data workflows, and ML/AI-enabled tools.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/projects/">Projects</a>
        <a class="button button-tertiary" href="/work/">Work history</a>
      </div>
    </div>
  </section>

  <section class="section origin-section">
    <div class="section-heading reveal">
      <p class="eyebrow">Through line</p>
      <h2>From early hardware curiosity to biomedical systems.</h2>
    </div>

    <div class="capability-grid">
      {originStory.map((item, index) => (
        <article class="capability-card reveal">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p class="feature-kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section capabilities-section" id="capabilities">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Where I create the most value.</h2>
    </div>

    <div class="capability-grid">
      <article class="capability-card reveal">
        <span>01</span>
        <h3>Wearable and implantable sensing systems</h3>
        <p>
          Miniaturized medical-device platforms using flexible electronics, adhesives,
          encapsulation, thermal sensing, BLE/NFC, wireless power, and sensor integration.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>02</span>
        <h3>Validation, reliability, and regulated development</h3>
        <p>
          Requirements, test procedures, FMEA, V&V workflows, inspection records,
          travelers, reliability debugging, and FDA-ready technical documentation.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>03</span>
        <h3>Physiological data and ML/AI workflows</h3>
        <p>
          Signal processing, feature engineering, model evaluation, bias and overfitting
          checks, visualization, automation, and tools that turn sensor data into decisions.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  :global(.studio-hero) {
    grid-template-columns: minmax(0, 1fr);
    min-height: auto;
    padding-top: clamp(6rem, 9vh, 7.5rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
  }

  :global(.studio-hero .hero-copy) {
    max-width: 980px;
  }

  @media (max-width: 760px) {
    :global(.studio-hero) {
      padding-top: 5.5rem;
    }
  }
</style>
