---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteMeta } from "../data/site";
import "../styles/global.css";
---

<BaseLayout title={siteMeta.siteTitle} description={siteMeta.siteDescription}>
  <section class="section studio-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Implantable & wearable medical sensors</p>

      <h1>Medical sensor systems for real-world use.</h1>

      <p class="hero-subtitle">
        Engineering across sensing hardware, flexible electronics, sensor-skin interfaces,
        validation, reliability, manufacturing support, data workflows, and ML/AI-enabled tools.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/work/">View work</a>
        <a class="button button-secondary" href="/projects/">View projects</a>
      </div>
    </div>

    <div class="hero-dashboard reveal" aria-label="Engineering summary panel">
      <div class="dashboard-window">
        <div class="window-dots">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="dashboard-grid">
          <article class="prototype-card">
            <span class="card-label">Focus</span>
            <strong>Medical sensing</strong>
            <p>Hardware · data · validation</p>
          </article>

          <article class="bar-card">
            <span></span>
            <span></span>
            <span></span>
          </article>

          <article class="radar-card">
            <div class="radar-ring"></div>
          </article>

          <article class="active-card">
            <span class="card-label">Systems range</span>
            <strong>R&D</strong>
            <p>Prototype → validate → improve</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section metrics-section">
    <div class="section-heading reveal">
      <p class="eyebrow">Metrics</p>
      <h2>Selected outcomes from medical-device engineering work.</h2>
    </div>

    <div class="metrics-grid">
      <article class="metric-tile reveal">
        <strong>70% → 96%</strong>
        <span>field reliability improvement</span>
      </article>

      <article class="metric-tile reveal">
        <strong>4 weeks → ~1 week</strong>
        <span>100-device build cycle improvement</span>
      </article>

      <article class="metric-tile reveal">
        <strong>3,000+</strong>
        <span>hours of device/data collection</span>
      </article>

      <article class="metric-tile reveal">
        <strong>200+</strong>
        <span>sensing datasets reviewed</span>
      </article>
    </div>
  </section>

  <section class="section capabilities-section" id="capabilities">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Where the work fits.</h2>
    </div>

    <div class="capability-grid">
      <article class="capability-card reveal">
        <span>01</span>
        <h3>Medical sensor systems</h3>
        <p>
          Implantable and wearable sensing platforms, flexible electronics, adhesives,
          encapsulation, BLE/NFC, wireless power, and sensor integration.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>02</span>
        <h3>Validation and reliability</h3>
        <p>
          Requirements, test procedures, inspection records, travelers, reliability debugging,
          V&V workflows, and device-performance reviews.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>03</span>
        <h3>Data and ML/AI workflows</h3>
        <p>
          Sensing datasets, algorithm evaluation, data analysis, automation, local AI tools,
          and engineering systems that make execution easier.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>