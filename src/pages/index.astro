---
import BaseLayout from "../layouts/BaseLayout.astro";
import { quickAccessSkills, siteMeta, workMetrics } from "../data/site";
import "../styles/global.css";
---

<BaseLayout title={siteMeta.siteTitle} description={siteMeta.siteDescription}>
  <section class="section studio-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">{siteMeta.personName}</p>
      <h1>{siteMeta.brandName}</h1>
      <p class="hero-brand-subtitle">{siteMeta.brandSubtitle}</p>
      <p class="hero-text">
        Engineering across sensing hardware, flexible electronics, sensor-skin interfaces,
        validation, reliability, manufacturing support, data workflows, and ML/AI-enabled tools.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/work/">Start with work</a>
        <a class="button button-secondary" href="/projects/">View projects</a>
        <a class="button button-tertiary" href={siteMeta.links.linkedin} target="_blank" rel="noreferrer noopener">
          LinkedIn
        </a>
        <a class="button button-tertiary" href={siteMeta.links.github} target="_blank" rel="noreferrer noopener">
          GitHub
        </a>
      </div>
    </div>

    <div class="hero-dashboard reveal" aria-label="Quick access block">
      <div class="dashboard-window quick-access-window">
        <div class="window-chrome">
          <div class="window-topline">
            <span class="chrome-label">Quick access.</span>
            <h2 class="chrome-title">Where to look first.</h2>
          </div>

          <span class="chrome-badge">Recruiter path</span>
        </div>

        <div class="window-dots window-dots-inline" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="quick-access-grid">
          <a class="focus-card" href="/work/" aria-label="Open professional work details">
            <span class="feature-kicker">Featured focus</span>
            <h2>Miniature sensing systems from hardware to clinical data.</h2>
            <p>
              End-to-end development of miniaturized sensing products across hardware,
              electronics, firmware/software, signal processing, data pipelines,
              validation, and clinical or preclinical study readiness.
            </p>
            <div class="tag-row tag-row-compact">
              <span class="tag tag-compact tag-strong">Miniature hardware</span>
              <span class="tag tag-compact">Flexible materials</span>
              <span class="tag tag-compact">Biocompatible packaging</span>
              <span class="tag tag-compact">Low-power electronics</span>
              <span class="tag tag-compact">Sensing integration</span>
              <span class="tag tag-compact">Firmware workflows</span>
              <span class="tag tag-compact">Signal processing</span>
              <span class="tag tag-compact tag-data">Data pipelines</span>
              <span class="tag tag-compact tag-warm">Validation studies</span>
            </div>
          </a>

          <a class="skill-card" href="/work/#skills" aria-label="Open skill details">
            <span class="feature-kicker">Skill depth</span>
            <h3>Skill depth</h3>

            <div class="skill-list skill-list-home">
              {quickAccessSkills.map((item) => (
                <div class="skill-row-home">
                  <div class="skill-top-home">
                    <span>{item.label}</span>
                    <span class="skill-score">{item.score}</span>
                  </div>
                  <div class={`skill-bar ${item.tone}`}>
                    <i style={`width:${item.value}%`}></i>
                  </div>
                  <p class="skill-detail-home">{item.detail}</p>
                </div>
              ))}
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section metrics-section" id="metrics">
    <div class="section-heading reveal">
      <p class="eyebrow">Metrics</p>
      <h2>Selected outcomes from medical-device engineering work.</h2>
    </div>

    <div class="metrics-grid">
      {workMetrics.map(([label, value], index) => (
        <a
          class="metric-tile reveal"
          href={index < 2 ? "/work/#metrics" : "/work/#work-history"}
          aria-label={`Open related work details for ${label}`}
        >
          <strong>{value}</strong>
          <span>{label}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section capabilities-section" id="capabilities">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Where the work fits.</h2>
    </div>

    <div class="capability-grid">
      <a class="capability-card reveal" href="/projects/flowsense-clinical-ace/" aria-label="Open FlowSense Clinical project">
        <span>01</span>
        <h3>Medical sensor systems</h3>
        <p>
          Implantable and wearable sensing platforms, flexible electronics, adhesives,
          encapsulation, BLE/NFC, wireless power, and sensor integration.
        </p>
      </a>

      <a class="capability-card reveal" href="/work/#work-history" aria-label="Open the work history section">
        <span>02</span>
        <h3>Validation and reliability</h3>
        <p>
          Requirements, test procedures, inspection records, travelers, reliability debugging,
          V&V workflows, and device-performance reviews.
        </p>
      </a>

      <a class="capability-card reveal" href="/projects/openclaw-ai-agent-system/" aria-label="Open the OpenClaw project">
        <span>03</span>
        <h3>Data and ML/AI workflows</h3>
        <p>
          Sensing datasets, algorithm evaluation, data analysis, automation, local AI tools,
          and engineering systems that make execution easier.
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
