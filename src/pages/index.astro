---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Alex Burton | Biomedical Systems Engineer";
const pageDescription =
  "Biomedical systems engineer building wearable and implantable medical-device sensing systems across hardware, validation, manufacturing, physiological data workflows, and ML/AI-enabled tools.";
const originStory = [
  {
    kicker: "Early engineering",
    title: "Learning by building.",
    body:
      "I started building hardware around 2010 through hands-on projects that mixed electronics, mechanics, soldering, and control systems: 3D LED displays, wireless motion control, an electromagnetic launcher, a balsa-wood 3D printer, and a plastic-recycling setup. Those projects taught me digital control, transistors, mechanical design, and troubleshooting.",
  },
  {
    kicker: "Interest in medicine",
    title: "Seeing healthcare up close.",
    body:
      "Around 2014, hospital volunteering pulled me toward medicine. Helping staff and nurses with day-to-day patient-care tasks gave me a closer look at clinical environments, medical devices, physiology, and the human side of care. It was the first time I saw technical details affect someone’s day.",
  },
  {
    kicker: "Biomedical systems",
    title: "Biomedical Engineering.",
    body:
      "Biomedical engineering became the place those interests fit together: hardware, electronics, sensing, and systems engineering applied to healthcare. That path grew into medical devices, wearable and implantable sensing systems, preclinical and clinical validation, patient interaction, and the work needed to move a device into real use.",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section studio-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Biomedical Systems Engineer · Medical Devices</p>

      <h1 class="hero-title-three-lines">
        <span>Biomedical sensing</span>
        <span>systems from prototype</span>
        <span>to clinical use.</span>
      </h1>

      <p class="hero-subtitle">
        Biomedical systems engineer building wearable and implantable medical-device
        sensing systems across hardware, validation, manufacturing, physiological
        data workflows, and ML/AI-enabled tools.
      </p>

      <div class="hero-actions audience-actions" aria-label="Choose a path through the site">
        <a class="button button-primary audience-recruiter" href="/recruiter/start/">Recruiter Match</a>
        <a class="button audience-cocometric" href="/cocometric/">Services and Quote</a>
      </div>
    </div>
  </section>

  <section class="section capabilities-section" id="capabilities">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Where I create the most value.</h2>
    </div>

    <div class="capabilities-flow">
      <article class="capability-flow-item reveal">
        <span>01</span>
        <h3>Wearable and implantable sensing systems</h3>
        <p>
          Miniaturized medical-device platforms using flexible electronics, adhesives,
          encapsulation, thermal sensing, BLE/NFC, wireless power, and sensor integration.
        </p>
      </article>

      <article class="capability-flow-item reveal">
        <span>02</span>
        <h3>Validation, reliability, and regulated development</h3>
        <p>
          Requirements, test procedures, FMEA, V&V workflows, inspection records,
          travelers, reliability debugging, and FDA-ready technical documentation.
        </p>
      </article>

      <article class="capability-flow-item reveal">
        <span>03</span>
        <h3>Physiological data and ML/AI workflows</h3>
        <p>
          Signal processing, feature engineering, model evaluation, bias and overfitting
          checks, visualization, automation, and tools that turn sensor data into decisions.
        </p>
      </article>
    </div>
  </section>

  <section class="section origin-section">
    <div class="section-heading reveal">
      <p class="eyebrow">Through line</p>
      <h2>From early hardware curiosity to biomedical systems.</h2>
    </div>

    <div class="origin-timeline">
      {originStory.map((item, index) => (
        <article class="origin-step reveal">
          <span class="origin-step-number">{String(index + 1).padStart(2, "0")}</span>
          <div class="origin-step-heading">
            <p>{item.kicker}</p>
            <h3>{item.title}</h3>
          </div>
          <p class="origin-step-body">{item.body}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  :global(html) {
    scroll-snap-type: none !important;
  }

  :global(main > .section) {
    min-height: auto;
    align-content: start;
    scroll-snap-align: none;
    scroll-snap-stop: normal;
  }

  :global(.studio-hero) {
    grid-template-columns: minmax(0, 1fr);
    min-height: calc(100svh - 76px) !important;
    padding-top: clamp(4rem, 8vh, 6rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
    align-items: center;
    align-content: center !important;
  }

  :global(.studio-hero .hero-copy) {
    max-width: 980px;
  }

  :global(.studio-hero .eyebrow) {
    margin-bottom: 20px;
    letter-spacing: 0.16em;
  }

  :global(.hero-title-three-lines) {
    max-width: 960px;
    margin-bottom: 28px;
    font-size: clamp(3.2rem, 6.2vw, 5.9rem);
    line-height: 0.99;
  }

  :global(.hero-title-three-lines span) {
    display: block;
    white-space: normal;
  }

  :global(.studio-hero .hero-subtitle) {
    max-width: 760px;
    margin-bottom: 30px;
  }

  :global(.audience-actions) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 220px));
    align-items: stretch;
    gap: 12px;
  }

  :global(.audience-actions .button) {
    width: 100%;
    min-height: 52px;
    padding: 0 20px;
    justify-content: center;
    text-align: center;
    white-space: nowrap;
    line-height: 1;
    font-size: 0.96rem;
  }

  :global(.audience-recruiter) {
    border-color: color-mix(in srgb, var(--cta-2), white 12%);
    background: linear-gradient(135deg, var(--cta-1), var(--cta-2));
    box-shadow: 0 14px 36px rgba(232, 111, 78, 0.18);
  }

  :global(.audience-cocometric) {
    border-color: color-mix(in srgb, var(--cta-2), transparent 18%);
    background: transparent;
    color: #fff4ee;
    box-shadow: inset 0 0 0 1px rgba(232, 111, 78, 0.06);
  }

  :global(.audience-cocometric:hover) {
    border-color: var(--cta-2);
    background: rgba(232, 111, 78, 0.06);
  }

  :global(.capabilities-section),
  :global(.origin-section) {
    padding-top: clamp(72px, 8vw, 112px);
    padding-bottom: clamp(72px, 8vw, 112px);
  }

  :global(.capabilities-section .section-heading),
  :global(.origin-section .section-heading) {
    margin-bottom: clamp(32px, 4vw, 52px);
  }

  :global(.capabilities-section .eyebrow),
  :global(.origin-section .eyebrow) {
    margin-bottom: 16px;
  }

  :global(.capabilities-section h2),
  :global(.origin-section h2) {
    max-width: 17ch;
    font-size: clamp(2.25rem, 3.05vw, 3.55rem);
    line-height: 1.04;
  }

  :global(.capabilities-flow) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  :global(.capability-flow-item) {
    min-width: 0;
    padding: clamp(28px, 3vw, 44px);
  }

  :global(.capability-flow-item + .capability-flow-item) {
    border-left: 1px solid var(--line);
  }

  :global(.capability-flow-item > span) {
    display: block;
    margin-bottom: clamp(34px, 4vw, 58px);
    color: var(--accent-2);
    font-size: 0.9rem;
    line-height: 1;
  }

  :global(.capability-flow-item h3) {
    max-width: 24ch;
    margin: 0 0 16px;
    font-size: clamp(1.32rem, 1.6vw, 1.72rem);
    line-height: 1.12;
  }

  :global(.capability-flow-item p) {
    max-width: 42ch;
    margin: 0;
    color: #d6e3f2;
    font-size: clamp(0.96rem, 1.05vw, 1.05rem);
    line-height: 1.55;
  }

  :global(.origin-timeline) {
    border-top: 1px solid var(--line);
  }

  :global(.origin-step) {
    display: grid;
    grid-template-columns: 72px minmax(220px, 0.58fr) minmax(0, 1fr);
    gap: clamp(24px, 4vw, 64px);
    align-items: start;
    padding: clamp(28px, 3.5vw, 46px) 0;
    border-bottom: 1px solid var(--line);
  }

  :global(.origin-step-number) {
    color: var(--accent-2);
    font-size: 0.9rem;
    line-height: 1;
  }

  :global(.origin-step-heading p) {
    margin: 0 0 12px;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 750;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  :global(.origin-step-heading h3) {
    max-width: 18ch;
    margin: 0;
    font-size: clamp(1.35rem, 1.75vw, 1.85rem);
    line-height: 1.12;
  }

  :global(.origin-step-body) {
    max-width: 66ch;
    margin: 0;
    color: #d6e3f2;
    font-size: clamp(0.98rem, 1.08vw, 1.08rem);
    line-height: 1.62;
  }

  @media (max-width: 1050px) {
    :global(.capabilities-flow) {
      grid-template-columns: 1fr;
    }

    :global(.capability-flow-item + .capability-flow-item) {
      border-top: 1px solid var(--line);
      border-left: 0;
    }
  }

  @media (max-width: 820px) {
    :global(.origin-step) {
      grid-template-columns: 52px minmax(0, 1fr);
      gap: 20px;
    }

    :global(.origin-step-body) {
      grid-column: 2;
    }
  }

  @media (max-width: 760px) {
    :global(.studio-hero) {
      min-height: auto !important;
      padding-top: 4.25rem;
      padding-bottom: 4.25rem;
    }

    :global(.hero-title-three-lines) {
      font-size: clamp(2.8rem, 13vw, 4.3rem);
    }

    :global(.audience-actions) {
      grid-template-columns: 1fr;
      width: min(100%, 320px);
    }

    :global(.capabilities-section h2),
    :global(.origin-section h2) {
      max-width: none;
    }

    :global(.capability-flow-item) {
      padding-right: 0;
      padding-left: 0;
    }
  }

  @media (max-width: 540px) {
    :global(.origin-step) {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    :global(.origin-step-body) {
      grid-column: 1;
    }
  }
</style>