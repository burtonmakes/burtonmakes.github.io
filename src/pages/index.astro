---
import { rhaeosAccomplishments, workProofPoints } from "../data/publicFacts";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Alex Burton | Biomedical Systems Engineer";
const pageDescription =
  "Biomedical systems engineer building wearable and implantable medical-device sensing systems across hardware, validation, manufacturing, physiological data workflows, and ML/AI-enabled tools.";
const workProofPointMap = new Map(workProofPoints);
const homepageMetrics = [
  {
    value: workProofPointMap.get("FlowSense Home reliability"),
    label: rhaeosAccomplishments[0],
  },
  {
    value: workProofPointMap.get("Clinical-study build cycle"),
    label: rhaeosAccomplishments[1],
  },
  {
    value: workProofPointMap.get("Physiological/device data")?.replace(" hours", "+"),
    label: rhaeosAccomplishments[2],
  },
  {
    value: workProofPointMap.get("HA Connect datasets")?.replace(" datasets", "+"),
    label: rhaeosAccomplishments[3],
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section studio-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Biomedical Systems Engineer · Medical Devices</p>

      <h1>Biomedical sensing systems from prototype to clinical use.</h1>

      <p class="hero-subtitle">
        Biomedical engineer leading the translation of novel sensing technologies into
        wearable and implantable medical products through miniaturized hardware,
        AI/ML analytics, and cross-functional leadership.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/work/">View work</a>
        <a class="button button-secondary" href="/projects/">View projects</a>
      </div>
    </div>

    <div class="hero-dashboard reveal" aria-label="Engineering summary panel">
      <div class="dashboard-window">
        <div class="window-dots" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="dashboard-grid">
          <article class="prototype-card">
            <span class="card-label">Focus</span>
            <strong>Medical devices</strong>
            <p>Hardware · validation · data</p>
          </article>

          <article class="bar-card" aria-label="Core engineering areas">
            <span></span>
            <span></span>
            <span></span>
          </article>

          <article class="radar-card" aria-label="Prototype validation loop">
            <div class="radar-ring"></div>
          </article>

          <article class="active-card">
            <span class="card-label">Systems range</span>
            <strong>R&D</strong>
            <p>Prototype → validate → transfer</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section metrics-section">
    <div class="metrics-grid">
      {homepageMetrics.map((metric) => (
        <article class="metric-tile reveal">
          <h2>{metric.value}</h2>
          <span>{metric.label}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section capabilities-section" id="capabilities">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Where I create the most value.</h2>
    </div>

    <div class="capability-grid">
      <article class="capability-card reveal">
        <span>01</span>
        <h3>Wearable and implantable sensing systems</h3>
        <p>
          Miniaturized medical-device platforms using flexible electronics, adhesives,
          encapsulation, thermal sensing, BLE/NFC, wireless power, and sensor integration.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>02</span>
        <h3>Validation, reliability, and regulated development</h3>
        <p>
          Requirements, test procedures, FMEA, V&V workflows, inspection records,
          travelers, reliability debugging, and FDA-ready technical documentation.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>03</span>
        <h3>Physiological data and ML/AI workflows</h3>
        <p>
          Signal processing, feature engineering, model evaluation, bias and overfitting
          checks, visualization, automation, and tools that turn sensor data into decisions.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  :global(.studio-hero) {
    min-height: auto;
    padding-top: clamp(6rem, 9vh, 7.5rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
  }

  @media (max-width: 760px) {
    :global(.studio-hero) {
      padding-top: 5.5rem;
    }
  }
</style>
