---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Alex Burton | Biomedical Systems Engineer";
const pageDescription =
  "Biomedical systems engineer building wearable and implantable medical-device sensing systems across hardware, validation, manufacturing, physiological data workflows, and ML/AI-enabled tools.";
const originStory = [
  {
    year: "2013 – present",
    title: "3D printing business",
    bullets: [
      "Started and maintained an online page to sell 3D printed objects.",
      "Kept learning through practical part design, customer requests, print failures, and material constraints.",
    ],
  },
  {
    year: "2014 – 2015",
    title: "Built a 3D printer",
    bullets: [
      "Built and tuned the printer hardware.",
      "Optimized the system to reduce vibration and improve print resolution.",
    ],
  },
  {
    year: "2015",
    title: "3D LED matrix",
    bullets: [
      "Designed, built, and programmed a 5×5×5 LED cube display.",
      "Used multiplexers and control logic to drive the display.",
    ],
  },
  {
    year: "2016",
    title: "Bio-amplifier",
    bullets: [
      "Built and designed a bio-amplifier to measure surface ECG signals.",
      "This was the bridge from electronics projects into biomedical sensing.",
    ],
  },
  {
    year: "College onward",
    title: "Biomedical systems",
    bullets: [
      "Chose biomedical engineering because medicine and technology both mattered to me.",
      "Medicine was the initial pull, but sensors, hardware, mechanics, and useful systems are where I do my best work.",
    ],
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section studio-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Burton Makes · biomedical systems engineer</p>

      <h1>A technical life built around sensors, hardware, medicine, and useful systems.</h1>

      <p class="hero-subtitle">
        This is both a portfolio and a personal record: early mechanical builds,
        biomedical research, medical-device work, infrastructure projects, and the
        thread that connects them.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/projects/">Projects</a>
        <a class="button button-tertiary" href="/work/">Work history</a>
      </div>
    </div>
  </section>

  <section class="section origin-section">
    <div class="section-heading reveal">
      <p class="eyebrow">Through line</p>
      <h2>Projects became electronics, electronics became biomedical systems.</h2>
      <p>
        The through line is not a single job title. It is a habit of building,
        testing, fixing, and connecting mechanical, electrical, software, and
        biological systems.
      </p>
    </div>

    <div class="origin-grid">
      {originStory.map((item) => (
        <article class="origin-card reveal">
          <span>{item.year}</span>
          <h3>{item.title}</h3>
          <ul>
            {item.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section capabilities-section" id="capabilities">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Where I create the most value.</h2>
    </div>

    <div class="capability-grid">
      <article class="capability-card reveal">
        <span>01</span>
        <h3>Wearable and implantable sensing systems</h3>
        <p>
          Miniaturized medical-device platforms using flexible electronics, adhesives,
          encapsulation, thermal sensing, BLE/NFC, wireless power, and sensor integration.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>02</span>
        <h3>Validation, reliability, and regulated development</h3>
        <p>
          Requirements, test procedures, FMEA, V&V workflows, inspection records,
          travelers, reliability debugging, and FDA-ready technical documentation.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>03</span>
        <h3>Physiological data and ML/AI workflows</h3>
        <p>
          Signal processing, feature engineering, model evaluation, bias and overfitting
          checks, visualization, automation, and tools that turn sensor data into decisions.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  :global(.studio-hero) {
    grid-template-columns: minmax(0, 1fr);
    min-height: auto;
    padding-top: clamp(6rem, 9vh, 7.5rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
  }

  :global(.studio-hero .hero-copy) {
    max-width: 980px;
  }

  @media (max-width: 760px) {
    :global(.studio-hero) {
      padding-top: 5.5rem;
    }
  }
</style>
