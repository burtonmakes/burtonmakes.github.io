---
import { rhaeosAccomplishments, workProofPoints } from "../data/publicFacts";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Alex Burton | Biomedical Systems Engineer";
const pageDescription =
  "Biomedical systems engineer building wearable and implantable medical-device sensing systems across hardware, validation, manufacturing, physiological data workflows, and ML/AI-enabled tools.";
const workProofPointMap = new Map(workProofPoints);
const getFirstToken = (value: string | undefined) => value?.split(" ")[0];
const homepageMetrics = [
  {
    value: workProofPointMap.get("FlowSense Home reliability"),
    label: rhaeosAccomplishments[0],
  },
  {
    value: workProofPointMap.get("Clinical-study build cycle"),
    label: rhaeosAccomplishments[1],
  },
  {
    value: getFirstToken(workProofPointMap.get("Physiological/device data")),
    label: rhaeosAccomplishments[2],
  },
  {
    value: getFirstToken(workProofPointMap.get("HA Connect datasets")),
    label: rhaeosAccomplishments[3],
  },
];
const originStory = [
  {
    kicker: "Early builds",
    title: "Electronics, mechanics, and making things move.",
    body:
      "Long before medical devices, I was building physical systems: 3D printing, recycled-filament extrusion, magnetic projectile / rail-gun experiments, and motion-control ideas like the LEX 3D matrix.",
  },
  {
    kicker: "Biomedical pull",
    title: "Medicine mattered, but technology kept pulling me back.",
    body:
      "I studied biomedical engineering because I wanted the medical side and the technical side in the same room. I considered medicine, but the work I kept coming back to was sensors, hardware, mechanics, and systems.",
  },
  {
    kicker: "Current thread",
    title: "Now I build sensing systems that have to survive real use.",
    body:
      "My work connects wearable and implantable hardware, physiological data, validation, documentation, clinical/home workflows, and AI-enabled tools into systems people can actually use.",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="section studio-hero">
    <div class="hero-copy reveal">
      <p class="eyebrow">Burton Makes · biomedical systems engineer</p>

      <h1>A technical life built around sensors, hardware, medicine, and useful systems.</h1>

      <p class="hero-subtitle">
        This is both a portfolio and a personal record: early mechanical builds,
        biomedical research, medical-device work, infrastructure projects, and the
        thread that connects them.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/projects/">Projects</a>
        <a class="button button-tertiary" href="/work/">Work history</a>
      </div>
    </div>
  </section>

  <section class="section origin-section">
    <div class="section-heading reveal">
      <p class="eyebrow">Through line</p>
      <h2>From building odd machines to biomedical systems.</h2>
    </div>

    <div class="capability-grid">
      {originStory.map((item, index) => (
        <article class="capability-card reveal">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <p class="feature-kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section metrics-section">
    <div class="metrics-grid">
      {homepageMetrics.map((metric) => (
        <article class="metric-tile reveal">
          <h2>{metric.value}</h2>
          <span>{metric.label}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section capabilities-section" id="capabilities">
    <div class="section-heading reveal">
      <p class="eyebrow">Capabilities</p>
      <h2>Where I create the most value.</h2>
    </div>

    <div class="capability-grid">
      <article class="capability-card reveal">
        <span>01</span>
        <h3>Wearable and implantable sensing systems</h3>
        <p>
          Miniaturized medical-device platforms using flexible electronics, adhesives,
          encapsulation, thermal sensing, BLE/NFC, wireless power, and sensor integration.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>02</span>
        <h3>Validation, reliability, and regulated development</h3>
        <p>
          Requirements, test procedures, FMEA, V&V workflows, inspection records,
          travelers, reliability debugging, and FDA-ready technical documentation.
        </p>
      </article>

      <article class="capability-card reveal">
        <span>03</span>
        <h3>Physiological data and ML/AI workflows</h3>
        <p>
          Signal processing, feature engineering, model evaluation, bias and overfitting
          checks, visualization, automation, and tools that turn sensor data into decisions.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  :global(.studio-hero) {
    grid-template-columns: minmax(0, 1fr);
    min-height: auto;
    padding-top: clamp(6rem, 9vh, 7.5rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
  }

  :global(.studio-hero .hero-copy) {
    max-width: 980px;
  }

  @media (max-width: 760px) {
    :global(.studio-hero) {
      padding-top: 5.5rem;
    }
  }
</style>
