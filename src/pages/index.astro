---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const pageTitle = "Coco Metric | Engineering systems and portfolio";
const pageDescription =
  "Choose a direct path through Alex Burton's engineering work, projects, recruiter evidence, local AI services, or contact information.";
const routerApi =
  import.meta.env.PUBLIC_RECRUITER_MATCH_API ||
  "https://burton-recruiter-match.burtonmakes.workers.dev/match";

const routes = [
  {
    key: "recruiter",
    index: "01",
    title: "Recruiter Match",
    summary: "Compare a role with documented work, projects, and measurable evidence.",
    href: "/recruiter/start/",
  },
  {
    key: "services",
    index: "02",
    title: "Services & Quote",
    summary: "Plan private AI, storage, networking, deployment, and ongoing support.",
    href: "/cocometric/",
  },
  {
    key: "work",
    index: "03",
    title: "Selected Work",
    summary: "Review biomedical systems, wearable sensing, validation, and product development.",
    href: "/work/",
  },
  {
    key: "projects",
    index: "04",
    title: "Project Library",
    summary: "Explore open builds across hardware, software, infrastructure, and fabrication.",
    href: "/projects/",
  },
  {
    key: "contact",
    index: "05",
    title: "Contact",
    summary: "Start a conversation about a role, system, collaboration, or technical question.",
    href: "/contact/",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="router-home" data-router-home data-router-api={routerApi}>
    <section class="router-boot" data-router-boot aria-label="Coco Metric startup" role="status">
      <div class="boot-shell">
        <div class="boot-heading">
          <span>Coco Metric / startup</span>
          <strong data-boot-status>Waking router</strong>
        </div>
        <div class="boot-log" data-boot-log aria-live="polite"></div>
        <div class="boot-track" aria-hidden="true"><i data-boot-progress></i></div>
        <div class="boot-footer">
          <span data-boot-copy>0% / looking for Coco</span>
          <button type="button" data-boot-skip>Enter to skip</button>
        </div>
      </div>
    </section>

    <div class="router-interface" data-router-interface aria-hidden="true">
      <header class="router-bar">
        <a class="router-brand" href="/" aria-label="Coco Metric home">
          <img src="/logo.svg" alt="" width="38" height="38" />
          <span data-location-trail>— Chicago — <strong>Router online</strong></span>
        </a>

        <div class="direct-shell" data-direct-shell>
          <button
            class="direct-trigger"
            type="button"
            aria-expanded="false"
            aria-controls="direct-panel"
            data-direct-trigger
          >
            <span>Direct path</span><i aria-hidden="true">+</i>
          </button>

          <div class="direct-panel" id="direct-panel" data-direct-panel>
            <nav class="direct-routes" aria-label="Direct site paths">
              {routes.map((route, index) => (
                <a
                  class:list={["direct-route", { "is-active": index === 0 }]}
                  href={route.href}
                  data-direct-route={route.key}
                  data-direct-title={route.title}
                  data-direct-summary={route.summary}
                >
                  <span>{route.index}</span>
                  <strong>{route.title}</strong>
                </a>
              ))}
            </nav>

            <section class="direct-preview" aria-live="polite">
              <p>Closest destination</p>
              <h2 data-direct-preview-title>{routes[0].title}</h2>
              <p data-direct-preview-summary>{routes[0].summary}</p>
              <a href={routes[0].href} data-direct-preview-link>Open route ↗</a>
            </section>
          </div>
        </div>
      </header>

      <main class="router-stage">
        <header class="router-heading">
          <h1>Choose your <em>path.</em></h1>
          <p>Type a command or describe what brought you here.</p>
        </header>

        <section class="router-terminal" aria-label="Interactive site router">
          <div class="terminal-bar">
            <span class="terminal-dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span>CLI</span>
            <strong>Active</strong>
          </div>

          <div class="terminal-history" data-terminal-history aria-live="polite">
            <p class="terminal-line is-prompt">$ ./route --interactive</p>
            <p class="terminal-line is-response">Type --help, a route name, or a short description.</p>
          </div>

          <form class="terminal-composer" data-router-form autocomplete="off">
            <span class="typing-cue" data-typing-cue>Click to start typing</span>
            <label for="router-command">
              <span>Command input</span>
              <small><b data-character-count>0</b> / 320</small>
            </label>
            <div class="composer-row">
              <span aria-hidden="true">$</span>
              <textarea
                id="router-command"
                data-router-command
                maxlength="320"
                rows="2"
                spellcheck="false"
                placeholder="e.g. I’m hiring for a wearable sensing role"
              ></textarea>
              <button type="submit">Route ↵</button>
            </div>
          </form>
        </section>

        <footer class="router-footer">
          <span>/ focuses the CLI · Esc closes Direct path</span>
          <button type="button" data-replay-boot>Replay / reboot</button>
        </footer>
      </main>
    </div>
  </section>
</BaseLayout>

<script>
  const home = document.querySelector("[data-router-home]");

  if (home instanceof HTMLElement) {
    const boot = home.querySelector("[data-router-boot]");
    const bootLog = home.querySelector("[data-boot-log]");
    const bootProgress = home.querySelector("[data-boot-progress]");
    const bootCopy = home.querySelector("[data-boot-copy]");
    const bootStatus = home.querySelector("[data-boot-status]");
    const skipBoot = home.querySelector("[data-boot-skip]");
    const replayBoot = home.querySelector("[data-replay-boot]");
    const routerInterface = home.querySelector("[data-router-interface]");
    const form = home.querySelector("[data-router-form]");
    const command = home.querySelector("[data-router-command]");
    const history = home.querySelector("[data-terminal-history]");
    const characterCount = home.querySelector("[data-character-count]");
    const typingCue = home.querySelector("[data-typing-cue]");
    const locationTrail = home.querySelector("[data-location-trail]");
    const directShell = home.querySelector("[data-direct-shell]");
    const directTrigger = home.querySelector("[data-direct-trigger]");
    const directRoutes = [...home.querySelectorAll("[data-direct-route]")];
    const previewTitle = home.querySelector("[data-direct-preview-title]");
    const previewSummary = home.querySelector("[data-direct-preview-summary]");
    const previewLink = home.querySelector("[data-direct-preview-link]");
    const routerApi = home.dataset.routerApi || "";

    const routes = {
      recruiter: {
        title: "Recruiter Match",
        path: "/recruiter/start/",
        location: "Recruiter",
        reply: "Recruiter Match is the closest path for role fit and documented evidence.",
      },
      services: {
        title: "Services & Quote",
        path: "/cocometric/",
        location: "Services",
        reply: "Services & Quote is the closest path for private infrastructure and support.",
      },
      work: {
        title: "Selected Work",
        path: "/work/",
        location: "Work",
        reply: "Selected Work is the closest path for professional engineering experience.",
      },
      projects: {
        title: "Project Library",
        path: "/projects/",
        location: "Projects",
        reply: "Project Library is the closest path for technical builds and open work.",
      },
      contact: {
        title: "Contact",
        path: "/contact/",
        location: "Contact",
        reply: "Contact is the closest path to start a conversation.",
      },
    };

    const bootLines = [
      ["00:00", "finished walking Coco", "OK"],
      ["00:01", "brushed all of the dog hair", "OK"],
      ["00:02", "vacuumed dog hair from the floor", "TEMPORARY"],
      ["00:03", "detected new dog hair on the floor", "EXPECTED"],
      ["00:04", "vibe coded the vibe code", "UNSUPERVISED"],
      ["00:05", "waiting for the hot end to reach 220°C", "HEATING"],
      ["00:06", "checked Tesla range and chose optimism", "OK"],
      ["00:07", "swiped card for additional tokens", "PAID"],
      ["00:08", "router ready", "ONLINE"],
    ];

    let timers = [];
    let bootFinished = false;

    const clearTimers = () => {
      timers.forEach((timer) => window.clearTimeout(timer));
      timers = [];
    };

    const finishBoot = () => {
      if (bootFinished) return;
      bootFinished = true;
      clearTimers();
      if (bootProgress instanceof HTMLElement) bootProgress.style.width = "100%";
      if (bootStatus) bootStatus.textContent = "Router online";
      if (bootCopy) bootCopy.textContent = "100% / interface ready";
      timers.push(
        window.setTimeout(() => {
          boot?.classList.add("is-complete");
          routerInterface?.classList.add("is-ready");
          routerInterface?.setAttribute("aria-hidden", "false");
          timers.push(window.setTimeout(() => command?.focus({ preventScroll: true }), 420));
        }, 560),
      );
    };

    const runBoot = () => {
      clearTimers();
      bootFinished = false;
      if (bootLog) bootLog.replaceChildren();
      if (bootProgress instanceof HTMLElement) bootProgress.style.width = "0";
      if (bootCopy) bootCopy.textContent = "0% / looking for Coco";
      if (bootStatus) bootStatus.textContent = "Waking router";
      boot?.classList.remove("is-complete");
      routerInterface?.classList.remove("is-ready");
      routerInterface?.setAttribute("aria-hidden", "true");

      bootLines.forEach((line, index) => {
        timers.push(
          window.setTimeout(() => {
            const row = document.createElement("p");
            row.className = "boot-row";
            const time = document.createElement("span");
            const text = document.createElement("span");
            const state = document.createElement("strong");
            time.textContent = line[0];
            text.textContent = line[1];
            state.textContent = `[${line[2]}]`;
            if (["TEMPORARY", "EXPECTED", "UNSUPERVISED", "HEATING"].includes(line[2])) {
              state.classList.add("is-warning");
            }
            if (line[2] === "PAID") state.classList.add("is-paid");
            row.append(time, text, state);
            bootLog?.append(row);
            if (bootLog instanceof HTMLElement) bootLog.scrollTop = bootLog.scrollHeight;
            const percent = Math.round(((index + 1) / bootLines.length) * 100);
            if (bootProgress instanceof HTMLElement) bootProgress.style.width = `${percent}%`;
            if (bootCopy) bootCopy.textContent = `${percent}% / ${line[1]}`;
            if (index === bootLines.length - 1) {
              timers.push(window.setTimeout(finishBoot, 520));
            }
          }, 500 + index * 720),
        );
      });
    };

    const setDirectOpen = (open) => {
      directShell?.classList.toggle("is-open", open);
      directTrigger?.setAttribute("aria-expanded", String(open));
    };

    const setPreview = (link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      directRoutes.forEach((item) => item.classList.toggle("is-active", item === link));
      if (previewTitle) previewTitle.textContent = link.dataset.directTitle || "Direct path";
      if (previewSummary) previewSummary.textContent = link.dataset.directSummary || "";
      if (previewLink instanceof HTMLAnchorElement) previewLink.href = link.href;
    };

    const appendLine = (kind, text, routeKey) => {
      if (!history) return null;
      const line = document.createElement("p");
      line.className = `terminal-line ${kind}`;
      line.textContent = text;
      if (routeKey && routes[routeKey]) {
        const link = document.createElement("a");
        link.href = routes[routeKey].path;
        link.textContent = ` Open ${routes[routeKey].path} ↗`;
        line.append(link);
      }
      history.append(line);
      if (history instanceof HTMLElement) history.scrollTop = history.scrollHeight;
      return line;
    };

    const setLocation = (routeKey) => {
      if (!locationTrail) return;
      if (!routeKey || !routes[routeKey]) {
        locationTrail.innerHTML = "— Chicago — <strong>Router online</strong>";
        return;
      }
      locationTrail.innerHTML = `— Chicago — ${routes[routeKey].location} — <strong>Route ready</strong>`;
    };

    const identifyRoute = (raw) => {
      const text = raw.toLowerCase().trim().replace(/^--?/, "");
      if (!text) return null;
      if (/^(help|options|routes|commands)$/.test(text)) return "help";
      if (/^(clear|reset)$/.test(text)) return "clear";
      if (/^(reboot|restart|replay)$/.test(text)) return "reboot";
      if (/recruit|hiring|hire|job|role|candidate|resume|cv|fit/.test(text)) return "recruiter";
      if (/service|quote|private ai|local ai|server|infrastructure|deploy|consult|client|storage/.test(text)) return "services";
      if (/work|experience|career|rhaeos|biomedical|medical device|algorithm|wearable|sensor/.test(text)) return "work";
      if (/project|github|open source|build|portfolio|homelab|tesla|3d print|fabricat/.test(text)) return "projects";
      if (/contact|email|meeting|talk|connect|collaborat/.test(text)) return "contact";
      return null;
    };

    const showRoute = (routeKey, answer) => {
      if (!routes[routeKey]) return;
      setLocation(routeKey);
      const directRoute = directRoutes.find((item) => item.dataset.directRoute === routeKey);
      setPreview(directRoute);
      appendLine("is-response", answer || routes[routeKey].reply, routeKey);
    };

    const askRouter = async (text) => {
      const pending = appendLine("is-pending", "Matching intent…");
      const controller = new AbortController();
      const timeout = window.setTimeout(() => controller.abort(), 6000);

      try {
        const response = await fetch(routerApi, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ action: "route", text }),
          signal: controller.signal,
        });
        const payload = await response.json();
        pending?.remove();
        const routeKey = typeof payload.route === "string" ? payload.route : "";
        if (response.ok && routes[routeKey]) {
          showRoute(routeKey, typeof payload.answer === "string" ? payload.answer : "");
          return;
        }
        appendLine("is-error", "No confident path yet. Add context or open Direct path.");
      } catch {
        pending?.remove();
        appendLine("is-error", "The smart router is unavailable. Direct path still works.");
      } finally {
        window.clearTimeout(timeout);
      }
    };

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      if (!(command instanceof HTMLTextAreaElement)) return;
      const raw = command.value.trim();
      if (!raw) return;
      appendLine("is-prompt", `$ ${raw}`);
      command.value = "";
      command.style.height = "";
      if (characterCount) characterCount.textContent = "0";

      const result = identifyRoute(raw);
      if (result === "help") {
        appendLine("is-response", "Commands: recruiter, services, work, projects, contact, clear, reboot.");
        return;
      }
      if (result === "clear") {
        history?.replaceChildren();
        appendLine("is-prompt", "$ ./route --interactive");
        appendLine("is-response", "Type --help, a route name, or a short description.");
        setLocation(null);
        return;
      }
      if (result === "reboot") {
        runBoot();
        return;
      }
      if (result && routes[result]) {
        showRoute(result, routes[result].reply);
        return;
      }
      if (raw.length < 8) {
        appendLine("is-error", "Add a little more context or open Direct path.");
        return;
      }
      void askRouter(raw);
    });

    command?.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        form?.requestSubmit();
      }
    });

    command?.addEventListener("input", () => {
      if (!(command instanceof HTMLTextAreaElement)) return;
      typingCue?.classList.add("is-hidden");
      if (characterCount) characterCount.textContent = String(command.value.length);
      command.style.height = "auto";
      command.style.height = `${Math.min(command.scrollHeight, 150)}px`;
    });

    command?.addEventListener("focus", () => typingCue?.classList.add("is-hidden"));
    directTrigger?.addEventListener("click", () => setDirectOpen(!directShell?.classList.contains("is-open")));
    directRoutes.forEach((link) => {
      link.addEventListener("mouseenter", () => setPreview(link));
      link.addEventListener("focus", () => setPreview(link));
      link.addEventListener("click", () => setLocation(link.dataset.directRoute));
    });

    document.addEventListener("click", (event) => {
      if (directShell && !directShell.contains(event.target)) setDirectOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (!boot?.classList.contains("is-complete") && event.key === "Enter") {
        finishBoot();
        return;
      }
      if (event.key === "Escape") setDirectOpen(false);
      if (event.key === "/" && document.activeElement !== command) {
        event.preventDefault();
        command?.focus();
      }
    });

    skipBoot?.addEventListener("click", finishBoot);
    replayBoot?.addEventListener("click", runBoot);
    runBoot();
  }
</script>

<style>
  :global(.site-header),
  :global(.site-footer) {
    display: none;
  }

  :global(body) {
    --accent: #54d3bd;
    --accent-2: #85ead8;
    --cta-1: #f0b35b;
    --cta-2: #f06b43;
    --router-bg: #03070c;
    --router-panel: rgba(5, 12, 19, 0.94);
    --router-panel-strong: rgba(8, 18, 27, 0.98);
    overflow: hidden;
  }

  :global(main#main) {
    min-height: 100svh;
  }

  .router-home {
    position: relative;
    min-height: 100svh;
    color: var(--text);
  }

  .router-home::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    content: "";
    pointer-events: none;
    background:
      radial-gradient(circle at 84% 14%, rgba(84, 211, 189, 0.08), transparent 25%),
      radial-gradient(circle at 18% 88%, rgba(240, 107, 67, 0.06), transparent 28%);
  }

  .router-boot {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: 28px;
    background: var(--router-bg);
    transition: opacity 480ms ease, visibility 0s 480ms;
  }

  .router-boot.is-complete {
    visibility: hidden;
    opacity: 0;
  }

  .boot-shell {
    width: min(820px, 100%);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .boot-heading,
  .boot-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    color: #5d6978;
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .boot-heading {
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }

  .boot-heading strong,
  .boot-row strong {
    color: var(--accent-2);
    font-weight: 600;
  }

  .boot-log {
    height: 310px;
    padding: 24px 0 18px;
    overflow: hidden;
  }

  :global(.boot-row) {
    display: grid;
    grid-template-columns: 66px minmax(0, 1fr) auto;
    gap: 16px;
    margin: 0;
    color: #b5c0ce;
    font-size: 0.75rem;
    line-height: 1.9;
    animation: boot-row-in 260ms ease both;
  }

  :global(.boot-row span:first-child) {
    color: #4d5968;
  }

  :global(.boot-row strong.is-warning) {
    color: #dca45b;
  }

  :global(.boot-row strong.is-paid) {
    color: var(--cta-2);
  }

  .boot-track {
    height: 2px;
    overflow: hidden;
    background: #151d27;
  }

  .boot-track i {
    display: block;
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--cta-2));
    box-shadow: 0 0 20px rgba(84, 211, 189, 0.3);
    transition: width 420ms ease;
  }

  .boot-footer {
    padding-top: 12px;
  }

  .boot-footer button,
  .router-footer button {
    border: 0;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
  }

  .router-interface {
    min-height: 100svh;
    opacity: 0;
    transform: scale(0.996);
    transition: opacity 560ms ease, transform 560ms ease;
  }

  .router-interface.is-ready {
    opacity: 1;
    transform: none;
  }

  .router-bar {
    position: relative;
    z-index: 30;
    display: flex;
    height: 68px;
    align-items: center;
    gap: 20px;
    padding: 0 32px;
    border-bottom: 1px solid var(--line-soft);
    background: rgba(0, 4, 8, 0.78);
    backdrop-filter: blur(18px) saturate(120%);
  }

  .router-brand {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 13px;
  }

  .router-brand img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
  }

  .router-brand span {
    overflow: hidden;
    color: #97a6b8;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.075em;
    text-overflow: ellipsis;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .router-brand strong {
    color: var(--accent-2);
    font-weight: 600;
  }

  .direct-shell {
    position: relative;
    margin-left: auto;
    height: 100%;
  }

  .direct-trigger {
    display: flex;
    height: 100%;
    align-items: center;
    gap: 10px;
    border: 0;
    background: transparent;
    color: #b7c1cd;
    cursor: pointer;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .direct-trigger i {
    display: grid;
    width: 22px;
    height: 22px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 50%;
    color: var(--accent-2);
    font-style: normal;
    transition: transform 220ms ease, border-color 220ms ease;
  }

  .direct-shell:hover .direct-trigger i,
  .direct-shell:focus-within .direct-trigger i,
  .direct-shell.is-open .direct-trigger i {
    border-color: color-mix(in srgb, var(--accent), transparent 35%);
    transform: rotate(45deg);
  }

  .direct-panel {
    position: absolute;
    top: 67px;
    right: -12px;
    display: grid;
    width: min(600px, calc(100vw - 24px));
    grid-template-columns: minmax(220px, 0.85fr) minmax(260px, 1.15fr);
    border: 1px solid var(--line);
    background: var(--router-panel-strong);
    box-shadow: 0 32px 100px rgba(0, 0, 0, 0.52);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: opacity 200ms ease, transform 200ms ease, visibility 0s 200ms;
  }

  .direct-shell:hover .direct-panel,
  .direct-shell:focus-within .direct-panel,
  .direct-shell.is-open .direct-panel {
    visibility: visible;
    opacity: 1;
    transform: none;
    transition-delay: 0s;
  }

  .direct-routes {
    display: grid;
    align-content: start;
    border-right: 1px solid var(--line);
  }

  .direct-route {
    position: relative;
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    gap: 10px;
    align-items: center;
    min-height: 58px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line-soft);
    color: #c6d0dc;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    transition: color 160ms ease, background 160ms ease;
  }

  .direct-route:last-child {
    border-bottom: 0;
  }

  .direct-route span {
    color: #596777;
    font-size: 0.62rem;
  }

  .direct-route strong {
    font-size: 0.76rem;
    font-weight: 600;
  }

  .direct-route:hover,
  .direct-route:focus-visible,
  .direct-route.is-active {
    outline: 0;
    background: linear-gradient(110deg, var(--cta-2), #d95436);
    color: #fffaf6;
  }

  .direct-route:hover span,
