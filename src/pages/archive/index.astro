---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { archiveItems, archiveSections } from "../../data/site";
import "../../styles/global.css";
---

<BaseLayout
  title="Archive"
  description="Archived projects, paused ideas, replaced experiments, and older work kept for historical context."
>
  <section class="section hero-grid">
    <div class="hero-copy reveal">
      <p class="eyebrow">Archive</p>
      <h1>Older work still worth keeping, but not on the main path.</h1>
      <p class="hero-text">
        Archive items preserve evolution, false starts, and replaced approaches without forcing them into the recruiter-first narrative.
      </p>
    </div>
    <div class="interface-shell tilt-card reveal">
      <div class="interface-topbar"><span></span><span></span><span></span></div>
      <div class="hero-panel-grid">
        {archiveSections.map((item) => (
          <article class="hero-stat-card"><span class="label">Archive lane</span><strong>{item}</strong></article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading reveal">
      <p class="eyebrow">Archive items</p>
      <h2>Structured placeholders with tags and notes.</h2>
    </div>
    <div class="timeline-stack">
      {archiveItems.map((item) => (
        <article class="timeline-card reveal">
          <div class="timeline-top">
            <h3>{item.title}</h3>
            <span class="status-pill">{item.status}</span>
          </div>
          <p>{item.note}</p>
          <div class="tag-row">
            {item.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
