---
import "../../styles/global.css";
import "../../styles/cocometric.css";
import "../../styles/cocometric-production.css";
import "../../styles/cocometric-mobile.css";
import "../../styles/cocometric-desktop.css";

const stages = [
  ["01", "Complete system", "Show the complete Cocometric system"],
  ["02", "Rack + chassis", "Show the rack and serviceable chassis"],
  ["03", "Storage", "Show the removable storage drives"],
  ["04", "Compute", "Show the motherboard, processors, and memory"],
  ["05", "AI accelerators", "Show the GPU accelerator assemblies"],
  ["06", "Cooling", "Show the fan wall and cooling assemblies"],
  ["07", "Power + network", "Show redundant power and networking"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#01050a" />
    <meta
      name="description"
      content="Cocometric designs, builds, deploys, and supports private local infrastructure for storage, AI, networking, video, and internal tools."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Cocometric — Private local infrastructure" />
    <meta
      property="og:description"
      content="Purpose-built local infrastructure for storage, private AI, networking, video, and internal tools."
    />
    <meta property="og:url" content="https://cocometric.com/cocometric/" />
    <link rel="canonical" href="https://cocometric.com/cocometric/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline src="/archive-mode.js"></script>
    <title>Cocometric — Private local infrastructure</title>
  </head>

  <body class="cocometric-page" data-model-status="loading">
    <a class="skip-link" href="#contact">Skip to services and contact</a>

    <div class="loading" id="loading" role="status" aria-live="polite">
      <div class="loading-inner">
        <p class="loading-copy" id="loading-copy">Loading Cocometric hardware</p>
        <div
          class="loading-track"
          id="loading-track"
          role="progressbar"
          aria-label="Loading 3D server model"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-valuenow="8"
        >
          <div class="loading-bar" id="loading-bar" aria-hidden="true"></div>
        </div>
      </div>
    </div>

    <header class="header">
      <div class="header-left">
        <a class="back-link" href="/" aria-label="Back to Burton Makes">Back</a>
        <a class="brand" href="/cocometric/" aria-label="Cocometric home">Cocometric</a>
      </div>
      <a class="header-cta" href="/contact/?topic=cocometric-services">Contact</a>
    </header>

    <div class="scene" id="scene" aria-hidden="true">
      <canvas id="server-canvas"></canvas>
      <div class="vignette"></div>
    </div>

    <section class="copy" id="copy" aria-labelledby="stage-title">
      <p class="step" id="stage-step">Cocometric system · 01</p>
      <h1 id="stage-title">One system. Every layer visible.</h1>
      <p class="copy-note" id="stage-note">
        A complete private infrastructure stack designed to support storage, local AI, networking,
        and internal tools.
      </p>
      <div class="component-tags" id="stage-tags" aria-hidden="true">
        <span>System design</span><span>Private infrastructure</span><span>Deployment planning</span>
      </div>
    </section>

    <nav class="stage-nav" aria-label="Inspect server components">
      {stages.map(([number, label, ariaLabel], index) => (
        <button
          type="button"
          class={index === 0 ? "is-active" : undefined}
          data-stage-button={index}
          aria-label={ariaLabel}
          aria-current={index === 0 ? "step" : undefined}
          title={label}
        >
          {number}
        </button>
      ))}
    </nav>

    <div class="scroll-cue" id="scroll-cue" aria-hidden="true">
      <span>Scroll to inspect</span>
      <i></i>
    </div>

    <main class="track" id="track">
      <section class="beat" data-stage="0">
        <div class="sr-only"><h2>Complete Cocometric system</h2><p>System design, private infrastructure, and deployment planning.</p></div>
      </section>
      <section class="beat" data-stage="1">
        <div class="sr-only"><h2>Rack and chassis</h2><p>Hardware selection, assembly, integration, and serviceable system builds.</p></div>
      </section>
      <section class="beat" data-stage="2">
        <div class="sr-only"><h2>Storage</h2><p>Backup architecture, redundancy planning, recovery workflows, and data protection.</p></div>
      </section>
      <section class="beat" data-stage="3">
        <div class="sr-only"><h2>Compute</h2><p>Compute sizing, local workloads, system tuning, and performance planning.</p></div>
      </section>
      <section class="beat" data-stage="4">
        <div class="sr-only"><h2>AI accelerators</h2><p>Local AI deployment, inference workflows, private model hosting, and GPU system design.</p></div>
      </section>
      <section class="beat" data-stage="5">
        <div class="sr-only"><h2>Cooling</h2><p>Thermal planning, cooling design, reliability under load, and long-run stability.</p></div>
      </section>
      <section class="beat" data-stage="6">
        <div class="sr-only"><h2>Power and network</h2><p>Power resilience, network setup, secure access, and remote management.</p></div>
      </section>

      <section class="story-exit" id="story-exit" aria-hidden="true"></section>

      <section class="final" id="contact" aria-labelledby="contact-title">
        <div class="final-card">
          <div class="final-heading">
            <p class="step">Cocometric services</p>
            <h2 id="contact-title">Own the hardware, or run it as a managed system.</h2>
            <p class="final-intro">
              Purpose-built local infrastructure for private AI, storage, networking, video, and internal
              tools. Each system is designed around your requirements, documented for ownership, and built
              with a clear path for support and expansion.
            </p>
          </div>

          <div class="service-options">
            <article class="service-option">
              <strong>Build and own it</strong>
              <span>System architecture, hardware selection, purchasing, assembly, deployment, migration, documentation, and handoff.</span>
            </article>
            <article class="service-option">
              <strong>Managed operation</strong>
              <span>Ongoing monitoring, maintenance, backups, recovery testing, data management, upgrades, and hardware expansion.</span>
            </article>
          </div>

          <div class="actions">
            <a class="button button-primary" href="/contact/?topic=cocometric-services#contact-form">Scope a system</a>
          </div>
        </div>
      </section>
    </main>

    <noscript>
      <section class="noscript-card">
        <h2>Private local infrastructure</h2>
        <p>The interactive server model requires JavaScript. Service details and contact options remain available below.</p>
        <a href="#contact">View services</a>
      </section>
    </noscript>

    <script src="../../scripts/cocometric-viewer.js"></script>
    <script is:inline>
      const stageContentByName = {
        "Cocometric system": {
          title: "One system. Every layer visible.",
          note: "A complete private infrastructure stack designed to support storage, local AI, networking, and internal tools.",
          tags: ["System design", "Private infrastructure", "Deployment planning"],
        },
        "Rack + chassis": {
          title: "Hardware built to be owned and serviced.",
          note: "Select, assemble, and deploy serviceable hardware that can grow with your workload and support path.",
          tags: ["Hardware selection", "Assembly + integration", "Serviceable builds"],
        },
        Storage: {
          title: "Storage planned around protection and recovery.",
          note: "Design storage systems with redundancy, backup structure, and recovery workflows that support real operational use.",
          tags: ["Backup architecture", "Redundancy planning", "Recovery workflows", "Data protection"],
        },
        Compute: {
          title: "Compute sized for local workloads.",
          note: "Plan CPU, memory, and system resources for private infrastructure, internal tools, and day-to-day workloads.",
          tags: ["Compute sizing", "Local workloads", "System tuning", "Performance planning"],
        },
        "AI accelerators": {
          title: "Local inference without sending data away.",
          note: "Deploy GPU-backed local AI workflows for private inference, OCR, retrieval, and internal model use.",
          tags: ["Local AI deployment", "Inference workflows", "Private model hosting", "GPU system design"],
        },
        Cooling: {
          title: "Thermal design for reliable long-run operation.",
          note: "Support stable performance with airflow and cooling planned for sustained load and continuous use.",
          tags: ["Thermal planning", "Reliability under load", "Cooling design", "Long-run stability"],
        },
        "Power + network": {
          title: "Reliable power and secure access.",
          note: "Support resilient operation with power planning, network setup, secure remote access, and edge connectivity.",
          tags: ["Power resilience", "Network setup", "Secure access", "Remote management"],
        },
      };

      const stageStep = document.querySelector("#stage-step");
      const stageTitle = document.querySelector("#stage-title");
      const stageNote = document.querySelector("#stage-note");
      const stageTags = document.querySelector("#stage-tags");

      const syncStageContent = () => {
        if (!stageStep || !stageTitle || !stageNote || !stageTags) return;
        const stageName = stageStep.textContent?.split("·")[0]?.trim();
        const content = stageContentByName[stageName];
        if (!content) return;

        stageTitle.textContent = content.title;
        stageNote.textContent = content.note;
        stageTags.replaceChildren(
          ...content.tags.map((label) => {
            const tag = document.createElement("span");
            tag.textContent = label;
            return tag;
          })
        );
      };

      if (stageStep) {
        new MutationObserver(syncStageContent).observe(stageStep, { childList: true });
      }
      syncStageContent();
    </script>
  </body>
</html>
