---
import BackgroundEffects from "../../components/BackgroundEffects.jsx";
import GlobalEffects from "../../components/GlobalEffects.jsx";
import "../../styles/global.css";

// Layers of the exploded-view server graphic in the hero.
// Each links straight down to its matching service card by id.
const layers = [
  { id: "comms", label: "Team tools", tag: "Chat, files, and a shared dashboard", side: "right" },
  { id: "ai", label: "AI compute", tag: "Local inference, no cloud required", side: "left" },
  { id: "video", label: "Video & security", tag: "Camera storage, footage you control", side: "right" },
  { id: "files", label: "Files & documents", tag: "Image and document storage, backed up", side: "left" },
  { id: "network", label: "Network & access", tag: "VLANs, remote access, tunnels, DNS", side: "right" },
  { id: "storage", label: "Storage & backup", tag: "NAS, redundancy, restore-tested", side: "left" },
];

const services = [
  {
    id: "storage",
    label: "Storage & backup",
    body: "NAS layout, redundancy, retention windows, and restore tests you've actually run — not just backups you hope work.",
  },
  {
    id: "files",
    label: "Files & documents",
    body: "Central storage for images, scans, and documents with versioning, search, and access that doesn't depend on a subscription.",
  },
  {
    id: "video",
    label: "Video & security",
    body: "Camera storage and monitoring that stays on your network: retention windows, motion alerts, and footage you control.",
  },
  {
    id: "ai",
    label: "Local AI",
    body: "On-prem AI boxes: model serving, inference routing, storage planning, GPU/CPU tradeoffs, and private workflow design.",
  },
  {
    id: "network",
    label: "Network & access",
    body: "VLAN-aware networks, remote access, DNS, tunnels, firewall rules, and service routing that holds up.",
  },
  {
    id: "comms",
    label: "Team communication",
    body: "Chat, file sharing, and a shared dashboard for a small team or startup — self-hosted, no per-seat pricing.",
  },
  {
    id: "software",
    label: "Frontend & backend",
    body: "Lean web apps, dashboards, forms, APIs, and admin tools built around the workflow you actually run.",
  },
  {
    id: "automation",
    label: "Automation",
    body: "Scheduled jobs, file movement, alerting, backups, and the glue code that keeps the whole box useful.",
  },
];

const process = [
  ["01", "Scope", "Map goals, users, data sensitivity, budget, current hardware, and what has to keep working."],
  ["02", "Design", "Pick an architecture with clear tradeoffs: cloud vs local, storage tiers, access, backups, and failure modes."],
  ["03", "Build", "Configure services, connect tools, document decisions, and leave the system understandable."],
  ["04", "Handoff", "Test recovery, explain operations, and define what to monitor or improve next."],
];

const outcomes = [
  "One server doing storage, video security, and team tools instead of five subscriptions",
  "Private local AI workflow for documents or engineering notes",
  "Camera and video storage that stays local, with retention you set",
  "Central image/document storage with backup and restore you've tested",
  "Team chat and file sharing for a startup, without per-seat SaaS pricing",
  "Clean handoff docs so the system is maintainable without you",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Cocometric builds and configures servers: storage and backup, video security, document storage, local AI, team communication tools, and networking for individuals and small teams."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>Cocometric | Local AI, Data, and Infrastructure</title>
  </head>
  <body class="cocometric-page">
    <BackgroundEffects client:load />
    <div class="site-backdrop" aria-hidden="true"></div>
    <GlobalEffects client:load />
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="coco-header">
      <a class="coco-brand" href="/cocometric/" aria-label="Cocometric home">
        <span class="coco-mark" aria-hidden="true">
          <i></i>
          <i></i>
          <i></i>
        </span>
        <span>Cocometric</span>
      </a>
      <nav aria-label="Cocometric navigation">
        <a href="#services">Services</a>
        <a href="#process">Process</a>
        <a href="#contact">Quote</a>
      </nav>
    </header>

    <main id="main">
      <section class="coco-hero">
        <div class="coco-hero-copy reveal">
          <p class="eyebrow">One box, built by hand</p>
          <h1>A server, exploded. Everything I can build inside it.</h1>
          <p>
            Cocometric builds and configures physical servers — storage, local AI, video security,
            and team tools — on the same stack I run myself. Own the hardware. Skip the subscriptions.
          </p>
          <div class="coco-actions">
            <a class="button button-primary" href="/contact/?topic=cocometric-quote">Request a quote</a>
            <a class="button button-secondary" href="#services">See what's inside</a>
          </div>
        </div>

        <div class="server-exploded reveal">
          <svg
            viewBox="0 0 640 760"
            role="img"
            aria-label="Exploded view of a server, showing team tools, AI compute, video and security, files and documents, network and access, and storage and backup layers stacked above a chassis"
          >
            <line class="spine" x1="320" y1="14" x2="320" y2="662" />
            {layers.map((layer, i) => {
              const y = 20 + i * 108;
              const w = 296;
              const h = 84;
              const x = layer.side === "left" ? 44 : 300;
              const connectorX = layer.side === "left" ? x + w : x;
              return (
                <a href={`#${layer.id}`} class="layer-link" aria-label={`${layer.label}: ${layer.tag}`}>
                  <line class="connector" x1={connectorX} y1={y + h / 2} x2="320" y2={y + h / 2} />
                  <g class="layer-group">
                    <rect class="layer-box" x={x} y={y} width={w} height={h} rx="6" />
                    <text class="layer-label" x={x + 20} y={y + 32}>{layer.label}</text>
                    <text class="layer-tag" x={x + 20} y={y + 56}>{layer.tag}</text>
                  </g>
                </a>
              );
            })}
            <g class="chassis-group">
              <rect class="chassis-box" x="170" y="668" width="300" height="70" rx="6" />
              <text class="chassis-label" x="320" y="698" text-anchor="middle">Cocometric server</text>
              <text class="chassis-tag" x="320" y="720" text-anchor="middle">Built, wired, and handed off</text>
            </g>
          </svg>
        </div>
      </section>

      <section class="coco-section" id="services">
        <div class="coco-section-heading reveal">
          <p class="eyebrow">Services</p>
          <h2>Practical builds for software, AI, data, and infrastructure.</h2>
        </div>

        <div class="service-grid">
          {services.map((service) => (
            <article class="service-card reveal" id={service.id}>
              <h3>{service.label}</h3>
              <p>{service.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="coco-band">
        <div class="coco-band-copy reveal">
          <p class="eyebrow">Good fit</p>
          <h2>Fast delivery without turning the project into a science experiment.</h2>
          <p>
            Cocometric is for individuals, labs, creators, founders, and small teams that need
            something built efficiently: a site, app, backend, AI workflow, local server, storage setup,
            or deployment pipeline that solves the problem without unnecessary layers.
          </p>
        </div>
        <ul class="outcome-list reveal">
          {outcomes.map((outcome) => <li>{outcome}</li>)}
        </ul>
      </section>

      <section class="coco-section" id="process">
        <div class="coco-section-heading reveal">
          <p class="eyebrow">Process</p>
          <h2>Scoped like engineering work, not vague consulting.</h2>
        </div>

        <div class="process-grid">
          {process.map(([number, title, body]) => (
            <article class="process-step reveal">
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="coco-contact" id="contact">
        <div class="reveal">
          <p class="eyebrow">Request a quote</p>
          <h2>Ask for a quote and get a scoped path to the smallest useful version.</h2>
          <p>
            For the fastest quote, include what you want built, what hardware or services already exist,
            what data is sensitive, who needs access, timeline, budget range, and what success looks like.
          </p>
          <a class="button button-primary" href="/contact/?topic=cocometric-quote">Ask for a quote</a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  .cocometric-page {
    min-height: 100vh;
  }

  .coco-header {
    position: sticky;
    top: 16px;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(1440px, calc(100% - 32px));
    margin: 16px auto 0;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(1, 5, 10, 0.96);
    box-shadow: var(--shadow-soft);
  }

  .coco-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--text);
    font-size: 1.06rem;
    font-weight: 850;
  }

  .coco-mark {
    position: relative;
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid rgba(111, 211, 255, 0.34);
    border-radius: 8px;
    background: rgba(111, 211, 255, 0.06);
  }

  .coco-mark i {
    position: absolute;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--graph-amber), var(--graph-coral));
  }

  .coco-mark i:nth-child(1) {
    transform: translateY(-7px);
  }

  .coco-mark i:nth-child(3) {
    transform: translateY(7px);
  }

  .coco-header nav {
    display: flex;
    gap: clamp(16px, 2.2vw, 34px);
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .coco-header nav a:hover {
    color: var(--text);
  }

  .coco-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.75fr);
    gap: clamp(28px, 5vw, 84px);
    align-items: center;
    width: min(1440px, calc(100% - 32px));
    min-height: calc(100vh - 92px);
    margin: 0 auto;
    padding: clamp(70px, 9vh, 120px) 0 clamp(40px, 6vh, 84px);
  }

  .coco-hero h1 {
    max-width: 15ch;
    margin-bottom: 22px;
    font-size: clamp(3rem, 6vw, 6.4rem);
    line-height: 0.98;
  }

  .coco-hero p:not(.eyebrow) {
    max-width: 66ch;
    color: var(--muted-2);
    font-size: clamp(1rem, 1.35vw, 1.28rem);
    line-height: 1.46;
  }

  .coco-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .server-exploded {
    position: relative;
    min-height: 560px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      radial-gradient(circle at 22% 15%, rgba(111, 211, 255, 0.12), transparent 26%),
      radial-gradient(circle at 78% 85%, rgba(232, 111, 78, 0.12), transparent 30%),
      rgba(1, 5, 10, 0.78);
  }

  .server-exploded svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .spine {
    stroke: rgba(111, 211, 255, 0.22);
    stroke-width: 1.5;
    stroke-dasharray: 3 5;
  }

  .connector {
    stroke: rgba(111, 211, 255, 0.4);
    stroke-width: 1.5;
    stroke-dasharray: 2 4;
  }

  .layer-link {
    cursor: pointer;
  }

  .layer-box {
    fill: rgba(6, 16, 28, 0.96);
    stroke: rgba(111, 211, 255, 0.28);
    stroke-width: 1.5;
    transition: stroke 0.15s ease, fill 0.15s ease, transform 0.15s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  .layer-label {
    fill: var(--text);
    font-size: 17px;
    font-weight: 800;
  }

  .layer-tag {
    fill: var(--muted-2);
    font-size: 12px;
  }

  .layer-link:hover .layer-box,
  .layer-link:focus-visible .layer-box {
    stroke: var(--graph-coral);
    transform: scale(1.02);
  }

  .layer-link:hover .connector {
    stroke: var(--graph-coral);
  }

  .chassis-box {
    fill: rgba(6, 16, 28, 0.96);
    stroke: rgba(232, 111, 78, 0.4);
    stroke-width: 1.5;
  }

  .chassis-label {
    fill: var(--text);
    font-size: 16px;
    font-weight: 850;
    letter-spacing: 0.04em;
  }

  .chassis-tag {
    fill: var(--muted-2);
    font-size: 12px;
  }

  .coco-section,
  .coco-band,
  .coco-contact {
    width: min(1440px, calc(100% - 32px));
    margin: 0 auto;
    padding: clamp(56px, 8vh, 96px) 0;
  }

  .coco-section-heading,
  .coco-band-copy {
    max-width: 900px;
    margin-bottom: clamp(22px, 3vw, 38px);
  }

  .coco-section-heading h2,
  .coco-band h2,
  .coco-contact h2 {
    max-width: 16ch;
    font-size: clamp(2.1rem, 4.2vw, 4.6rem);
    line-height: 1;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .service-card,
  .process-step,
  .outcome-list,
  .coco-contact > div {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(1, 5, 10, 0.9);
    box-shadow: var(--shadow-soft);
  }

  .service-card {
    min-height: 230px;
    padding: clamp(22px, 2vw, 30px);
  }

  .service-card h3,
  .process-step h3 {
    margin-bottom: 14px;
    font-size: clamp(1.18rem, 1.5vw, 1.48rem);
  }

  .service-card p,
  .process-step p,
  .coco-band p,
  .coco-contact p {
    color: var(--muted-2);
    font-size: 0.98rem;
    line-height: 1.48;
  }

  .coco-band {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(320px, 0.6fr);
    gap: clamp(24px, 5vw, 76px);
    align-items: start;
  }

  .outcome-list {
    margin: 0;
    padding: clamp(22px, 2vw, 30px);
    list-style: none;
  }

  .outcome-list li {
    display: flex;
    gap: 10px;
    color: var(--muted-2);
    font-size: 0.98rem;
    line-height: 1.38;
  }

  .outcome-list li::before {
    flex: 0 0 auto;
    width: 8px;
    height: 8px;
    margin-top: 0.55em;
    border-radius: 999px;
    background: var(--cta-2);
    content: "";
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .process-step {
    padding: clamp(20px, 1.8vw, 28px);
  }

  .process-step > span {
    display: block;
    margin-bottom: 42px;
    color: var(--accent-2);
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .coco-contact {
    padding-bottom: clamp(70px, 10vh, 120px);
  }

  .coco-contact > div {
    padding: clamp(28px, 4vw, 56px);
  }

  .coco-contact p {
    max-width: 72ch;
    margin: 18px 0 28px;
  }

  @media (max-width: 1100px) {
    .coco-hero,
    .coco-band {
      grid-template-columns: 1fr;
    }

    .server-exploded {
      min-height: 420px;
    }

    .service-grid,
    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .coco-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
      top: 8px;
    }

    .coco-header nav {
      width: 100%;
      justify-content: space-between;
      gap: 10px;
      font-size: 0.82rem;
    }

    .coco-hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 58px;
    }

    .coco-hero h1 {
      max-width: none;
      font-size: clamp(2.6rem, 14vw, 4.2rem);
    }

    .server-exploded {
      min-height: 460px;
    }

    .layer-label {
      font-size: 15px;
    }

    .layer-tag {
      font-size: 11px;
    }

    .service-grid,
    .process-grid {
      grid-template-columns: 1fr;
    }

    .process-step > span {
      margin-bottom: 26px;
    }
  }
</style>