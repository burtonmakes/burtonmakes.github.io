---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";

const getYearsValue = (value) => Number.parseInt(String(value).match(/\d+/)?.[0] ?? "0", 10);
const getBarTone = (years) => {
  if (years >= 8) return "red";
  if (years >= 4) return "green";
  return "blue";
};
const getBarWidth = (years) => Math.max(24, Math.min(100, years * 6.5));
const getBarStyle = (years) => {
  const tone = getBarTone(years);
  const width = getBarWidth(years);
  const gradients = {
    red: "linear-gradient(90deg, #e2b869 0%, #e86f4e 100%)",
    green: "linear-gradient(90deg, #3dd6c8 0%, #6fe5dd 100%)",
    blue: "linear-gradient(90deg, #4c8dff 0%, #6fd3ff 100%)",
  };

  return `width:${width}%; background:${gradients[tone]}; box-shadow:0 0 18px ${
    tone === "red" ? "rgba(232, 111, 78, 0.22)" : tone === "green" ? "rgba(61, 214, 200, 0.26)" : "rgba(76, 141, 255, 0.22)"
  };`;
};

const outdoorActivities = [
